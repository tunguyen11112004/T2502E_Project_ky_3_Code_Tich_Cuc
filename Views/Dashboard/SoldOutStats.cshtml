@model List<Bus_ticket.Services.SoldOutTimeFrameDto>
@{
    ViewData["Title"] = "Thống kê Khung giờ Cháy vé";
}

<!-- CSS của Flatpickr -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<link rel="stylesheet" type="text/css" href="https://npmcdn.com/flatpickr/dist/themes/dark.css">

<div class="p-6 space-y-6">
    <!-- Header -->
    <div class="flex justify-between items-center mb-4">
        <h2 class="text-3xl font-bold text-white">Khung Giờ Cháy Vé</h2>
        <a asp-action="Index" asp-controller="Dashboard" class="bg-gray-700 hover:bg-gray-600 text-white px-4 py-2.5 rounded-lg text-sm font-medium transition-colors">
            &larr; Quay lại Tổng quan
        </a>
    </div>

    <!-- Form lọc & Xuất Excel -->
    <div class="bg-gray-800 p-6 rounded-xl border border-gray-700 shadow-md">
        <form asp-action="SoldOutStats" method="get" class="flex flex-col md:flex-row items-end gap-4">
            <div class="w-full md:w-1/4">
                <label class="block mb-2 text-sm text-gray-400">Từ ngày</label>
                <input type="text" name="fromDate" id="fromDate" value="@ViewBag.FromDate.ToString("yyyy-MM-dd")" class="bg-gray-700 text-white border border-gray-600 rounded-lg p-2.5 w-full focus:border-blue-500 focus:ring-blue-500 text-center" required />
            </div>
            <div class="w-full md:w-1/4">
                <label class="block mb-2 text-sm text-gray-400">Đến ngày</label>
                <input type="text" name="toDate" id="toDate" value="@ViewBag.ToDate.ToString("yyyy-MM-dd")" class="bg-gray-700 text-white border border-gray-600 rounded-lg p-2.5 w-full focus:border-blue-500 focus:ring-blue-500 text-center" required />
            </div>
            
            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2.5 rounded-lg font-medium transition-colors">
                Lọc dữ liệu
            </button>
            
            <a asp-action="ExportSoldOutTimeFrames" asp-controller="Dashboard" asp-route-fromDate="@ViewBag.FromDate.ToString("yyyy-MM-dd")" asp-route-toDate="@ViewBag.ToDate.ToString("yyyy-MM-dd")" class="bg-orange-600 hover:bg-orange-700 text-white px-6 py-2.5 rounded-lg font-medium transition-colors">
                Xuất Excel
            </a>
        </form>
    </div>

    <!-- Bảng kết quả -->
    <div class="bg-gray-800 rounded-xl border border-gray-700 shadow-md overflow-hidden">
        <table class="w-full text-left text-sm text-gray-300">
            <thead class="bg-gray-700 text-gray-200 uppercase font-semibold">
                <tr>
                    <th scope="col" class="px-6 py-4">STT</th>
                    <th scope="col" class="px-6 py-4">Khung Giờ</th>
                    <th scope="col" class="px-6 py-4">Số Lần Cháy Vé</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    int i = 1;
                    foreach (var item in Model)
                    {
                        <tr class="border-b border-gray-700 hover:bg-gray-750 transition-colors">
                            <td class="px-6 py-4">@i</td>
                            <td class="px-6 py-4 font-bold text-yellow-400 text-lg">@item.TimeFrame</td>
                            <td class="px-6 py-4">
                                <span class="bg-red-900 text-red-300 py-1 px-3 rounded-full text-xs font-bold">
                                    @item.SoldOutCount lần
                                </span>
                            </td>
                        </tr>
                        i++;
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3" class="px-6 py-8 text-center text-gray-400">
                            Không có dữ liệu cháy vé trong khoảng thời gian này.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- JS của Flatpickr -->
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        const fpConfig = {
            dateFormat: "Y-m-d", // Chuẩn ngày gửi lên server
            altInput: true,
            altFormat: "d/m/Y"   // Chuẩn hiển thị Việt Nam
        };

        flatpickr("#fromDate", fpConfig);
        flatpickr("#toDate", fpConfig);
    });
</script>