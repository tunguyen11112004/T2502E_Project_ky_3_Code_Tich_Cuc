@model Bus_ticket.ViewModels.LowOccupancyTripsViewModel

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Low Occupancy Trips";

    var fromDateValue = Model.FromDate.ToString("yyyy-MM-dd");
    var toDateValue = Model.ToDate.ToString("yyyy-MM-dd");
}

<div class="p-4 sm:p-6 lg:p-8 space-y-6 max-w-full overflow-x-hidden">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold tracking-tight text-white">
                Low Occupancy Trips
            </h1>
            <p class="text-sm text-gray-400 mt-1">
                Identify frequently empty trips to reduce or merge schedules.
            </p>
        </div>

        <a asp-controller="Dashboard"
           asp-action="ExportLowOccupancyTrips"
           asp-route-fromDate="@fromDateValue"
           asp-route-toDate="@toDateValue"
           asp-route-occupancyThreshold="@Model.OccupancyThreshold"
           class="inline-flex items-center justify-center px-4 py-2.5 text-sm font-semibold text-gray-900 bg-emerald-400 hover:bg-emerald-500 rounded-lg transition-colors duration-200 shadow-sm">
            Export Excel
        </a>
    </div>

    <form method="get"
          asp-controller="Dashboard"
          asp-action="LowOccupancyTrips"
          class="bg-[#1e1e24] border border-gray-700/50 rounded-xl p-4 shadow-xl">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4 items-end">
            <div>
                <label class="block text-sm font-medium text-gray-300 mb-2">
                    From Date
                </label>
                <input type="date"
                       name="fromDate"
                       value="@fromDateValue"
                       class="w-full rounded-lg border border-gray-700 bg-gray-900 px-3 py-2 text-sm text-white focus:border-amber-400 focus:ring-2 focus:ring-amber-400" />
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-300 mb-2">
                    To Date
                </label>
                <input type="date"
                       name="toDate"
                       value="@toDateValue"
                       class="w-full rounded-lg border border-gray-700 bg-gray-900 px-3 py-2 text-sm text-white focus:border-amber-400 focus:ring-2 focus:ring-amber-400" />
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-300 mb-2">
                    Occupancy Threshold (%)
                </label>
                <input type="number"
                       min="0"
                       max="100"
                       step="1"
                       name="occupancyThreshold"
                       value="@Model.OccupancyThreshold.ToString("0")"
                       class="w-full rounded-lg border border-gray-700 bg-gray-900 px-3 py-2 text-sm text-white focus:border-amber-400 focus:ring-2 focus:ring-amber-400" />
            </div>

            <div>
                <button type="submit"
                        class="w-full inline-flex items-center justify-center px-4 py-2.5 text-sm font-semibold text-gray-900 bg-amber-400 hover:bg-amber-500 rounded-lg transition-colors duration-200">
                    Filter Data
                </button>
            </div>
        </div>
    </form>

    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4">
        <div class="bg-[#1e1e24] border border-gray-700/50 rounded-xl p-5 shadow-xl">
            <p class="text-sm text-gray-400">Total Trips</p>
            <p class="text-2xl font-bold text-white mt-2">
                @Model.TotalTrips.ToString("N0")
            </p>
            <p class="text-xs text-gray-500 mt-2">
                Trips in selected date range
            </p>
        </div>

        <div class="bg-[#1e1e24] border border-gray-700/50 rounded-xl p-5 shadow-xl">
            <p class="text-sm text-gray-400">Low Occupancy Trips</p>
            <p class="text-2xl font-bold text-red-400 mt-2">
                @Model.LowOccupancyTripCount.ToString("N0")
            </p>
            <p class="text-xs text-gray-500 mt-2">
                Below @Model.OccupancyThreshold.ToString("N0")% occupancy
            </p>
        </div>

        <div class="bg-[#1e1e24] border border-gray-700/50 rounded-xl p-5 shadow-xl">
            <p class="text-sm text-gray-400">Average Occupancy</p>
            <p class="text-2xl font-bold text-amber-400 mt-2">
                @Model.AverageOccupancyRate.ToString("N2")%
            </p>
            <p class="text-xs text-gray-500 mt-2">
                Average occupancy rate
            </p>
        </div>

        <div class="bg-[#1e1e24] border border-gray-700/50 rounded-xl p-5 shadow-xl">
            <p class="text-sm text-gray-400">Sold Out Trips</p>
            <p class="text-2xl font-bold text-emerald-400 mt-2">
                @Model.SoldOutTripCount.ToString("N0")
            </p>
            <p class="text-xs text-gray-500 mt-2">
                Fully booked trips
            </p>
        </div>
    </div>

    <div class="w-full max-w-full overflow-hidden bg-[#1e1e24] border border-gray-700/50 rounded-xl shadow-xl">
        <div class="p-5 border-b border-gray-700/60">
            <h2 class="text-lg font-semibold text-white">
                Low Occupancy Trip List
            </h2>
            <p class="text-sm text-gray-400 mt-1">
                Trips below the configured occupancy threshold are marked with red warning badges.
            </p>
        </div>

        <div class="w-full overflow-x-auto">
            <table class="w-full min-w-[1100px] table-fixed text-sm text-left text-gray-300">
                <thead class="text-xs uppercase bg-[#141419] text-gray-400 border-b border-gray-700/60">
                    <tr>
                        <th class="w-16 px-4 py-4">No.</th>
                        <th class="px-4 py-4">Trip Code</th>
                        <th class="px-4 py-4">Departure</th>
                        <th class="px-4 py-4">Route</th>
                        <th class="px-4 py-4">Bus</th>
                        <th class="px-4 py-4">Bus Type</th>
                        <th class="w-28 px-4 py-4 text-right">Seats</th>
                        <th class="w-32 px-4 py-4 text-right">Booked</th>
                        <th class="w-32 px-4 py-4 text-right">Empty</th>
                        <th class="w-36 px-4 py-4 text-right">Occupancy</th>
                        <th class="w-40 px-4 py-4 text-center">Warning</th>
                    </tr>
                </thead>

                <tbody class="divide-y divide-gray-700/50">
                    @if (Model.LowOccupancyTrips.Count == 0)
                    {
                        <tr>
                            <td colspan="11" class="px-4 py-8 text-center text-gray-500">
                                No low occupancy trips in this date range.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @for (var i = 0; i < Model.LowOccupancyTrips.Count; i++)
                        {
                            var item = Model.LowOccupancyTrips[i];

                            <tr class="hover:bg-gray-800/30 transition-colors duration-150">
                                <td class="px-4 py-4 text-gray-400">@(i + 1)</td>
                                <td class="px-4 py-4 font-semibold text-white">@item.TripCode</td>
                                <td class="px-4 py-4">@item.DepartureTime.ToString("yyyy-MM-dd HH:mm")</td>
                                <td class="px-4 py-4">@item.RouteName</td>
                                <td class="px-4 py-4">
                                    <div class="font-semibold text-white">@item.BusCode</div>
                                    <div class="text-xs text-gray-500">@item.LicensePlate</div>
                                </td>
                                <td class="px-4 py-4">@item.BusType</td>
                                <td class="px-4 py-4 text-right">@item.TotalSeats.ToString("N0")</td>
                                <td class="px-4 py-4 text-right">@item.BookedSeats.ToString("N0")</td>
                                <td class="px-4 py-4 text-right text-red-400 font-semibold">@item.EmptySeats.ToString("N0")</td>
                                <td class="px-4 py-4 text-right font-semibold text-amber-400">
                                    @item.OccupancyRate.ToString("N2")%
                                </td>
                                <td class="px-4 py-4 text-center">
                                    <span class="inline-flex items-center rounded-full bg-red-900/60 px-3 py-1 text-xs font-semibold text-red-300 border border-red-700">
                                        Low Occupancy
                                    </span>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div class="w-full max-w-full overflow-hidden bg-[#1e1e24] border border-gray-700/50 rounded-xl shadow-xl">
        <div class="p-5 border-b border-gray-700/60">
            <h2 class="text-lg font-semibold text-white">
                Sold Out Time Frames
            </h2>
            <p class="text-sm text-gray-400 mt-1">
                Fully booked time frames updated with the same date filter.
            </p>
        </div>

        <div class="w-full overflow-x-auto">
            <table class="w-full min-w-[700px] table-fixed text-sm text-left text-gray-300">
                <thead class="text-xs uppercase bg-[#141419] text-gray-400 border-b border-gray-700/60">
                    <tr>
                        <th class="w-20 px-4 py-4">No.</th>
                        <th class="px-4 py-4">Time Frame</th>
                        <th class="px-4 py-4 text-right">Sold Out Trips</th>
                        <th class="px-4 py-4 text-right">Total Seats</th>
                        <th class="px-4 py-4 text-right">Booked Seats</th>
                    </tr>
                </thead>

                <tbody class="divide-y divide-gray-700/50">
                    @if (Model.SoldOutTimeFrames.Count == 0)
                    {
                        <tr>
                            <td colspan="5" class="px-4 py-8 text-center text-gray-500">
                                No sold out time frames in this date range.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @for (var i = 0; i < Model.SoldOutTimeFrames.Count; i++)
                        {
                            var item = Model.SoldOutTimeFrames[i];

                            <tr class="hover:bg-gray-800/30 transition-colors duration-150">
                                <td class="px-4 py-4 text-gray-400">@(i + 1)</td>
                                <td class="px-4 py-4 font-semibold text-white">@item.TimeFrame</td>
                                <td class="px-4 py-4 text-right text-emerald-400 font-semibold">
                                    @item.SoldOutTripCount.ToString("N0")
                                </td>
                                <td class="px-4 py-4 text-right">@item.TotalSeats.ToString("N0")</td>
                                <td class="px-4 py-4 text-right">@item.BookedSeats.ToString("N0")</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>