@model Bus_ticket.ViewModels.RouteRevenueReportViewModel

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Doanh thu theo tuyến đường";

    var fromDateValue = Model.FromDate.ToString("yyyy-MM-dd");
    var toDateValue = Model.ToDate.ToString("yyyy-MM-dd");
}

<div class="p-4 sm:p-6 lg:p-8 space-y-6 max-w-full overflow-x-hidden">
    <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold tracking-tight text-white">
                Doanh thu theo tuyến đường
            </h1>
            <p class="text-sm text-gray-400 mt-1">
                Thống kê doanh thu các chặng dạng text thuần, ví dụ: Hà Nội - Sapa, Hà Nội - Hải Phòng.
            </p>
        </div>

        <a asp-controller="Dashboard"
           asp-action="ExportRouteRevenue"
           asp-route-fromDate="@fromDateValue"
           asp-route-toDate="@toDateValue"
           class="inline-flex items-center justify-center px-4 py-2.5 text-sm font-semibold text-gray-900 bg-emerald-400 hover:bg-emerald-500 rounded-lg transition-colors duration-200 shadow-sm">
            Xuất Excel
        </a>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="p-4 text-sm text-red-400 rounded-lg bg-gray-800 border border-red-800">
            @TempData["ErrorMessage"]
        </div>
    }

    <form method="get"
          asp-controller="Dashboard"
          asp-action="RouteRevenue"
          class="bg-[#1e1e24] border border-gray-700/50 rounded-xl p-4 shadow-xl">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4 items-end">
            <div>
                <label class="block text-sm font-medium text-gray-300 mb-2">
                    Từ ngày
                </label>
                <input type="date"
                       name="fromDate"
                       value="@fromDateValue"
                       class="w-full rounded-lg border border-gray-700 bg-gray-900 px-3 py-2 text-sm text-white focus:border-amber-400 focus:ring-2 focus:ring-amber-400" />
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-300 mb-2">
                    Đến ngày
                </label>
                <input type="date"
                       name="toDate"
                       value="@toDateValue"
                       class="w-full rounded-lg border border-gray-700 bg-gray-900 px-3 py-2 text-sm text-white focus:border-amber-400 focus:ring-2 focus:ring-amber-400" />
            </div>

            <div>
                <button type="submit"
                        class="w-full inline-flex items-center justify-center px-4 py-2.5 text-sm font-semibold text-gray-900 bg-amber-400 hover:bg-amber-500 rounded-lg transition-colors duration-200">
                    Lọc dữ liệu
                </button>
            </div>
        </div>
    </form>

    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4">
        <div class="bg-[#1e1e24] border border-gray-700/50 rounded-xl p-5 shadow-xl">
            <p class="text-sm text-gray-400">Tổng doanh thu</p>
            <p class="text-2xl font-bold text-amber-400 mt-2">
                @Model.GrandTotalRevenue.ToString("N0") ₫
            </p>
        </div>

        <div class="bg-[#1e1e24] border border-gray-700/50 rounded-xl p-5 shadow-xl">
            <p class="text-sm text-gray-400">Booking thành công</p>
            <p class="text-2xl font-bold text-white mt-2">
                @Model.GrandTotalBookings
            </p>
        </div>

        <div class="bg-[#1e1e24] border border-gray-700/50 rounded-xl p-5 shadow-xl">
            <p class="text-sm text-gray-400">Số vé bán</p>
            <p class="text-2xl font-bold text-white mt-2">
                @Model.GrandTotalTickets
            </p>
        </div>

        <div class="bg-[#1e1e24] border border-gray-700/50 rounded-xl p-5 shadow-xl">
            <p class="text-sm text-gray-400">Số tuyến có doanh thu</p>
            <p class="text-2xl font-bold text-white mt-2">
                @(Model.Items?.Count ?? 0)
            </p>
        </div>
    </div>

    <div class="bg-[#1e1e24] border border-gray-700/50 rounded-xl p-5 shadow-xl">
        <div class="flex items-center justify-between mb-4">
            <div>
                <h2 class="text-lg font-semibold text-white">
                    Biểu đồ doanh thu theo tuyến
                </h2>
                <p class="text-sm text-gray-400">
                    Tuyến đường hiển thị bằng dấu gạch ngang, không dùng ký tự mũi tên.
                </p>
            </div>
        </div>

        @if (Model.Items == null || !Model.Items.Any())
        {
            <div class="py-10 text-center text-gray-500">
                Không có dữ liệu doanh thu trong khoảng thời gian đã chọn.
            </div>
        }
        else
        {
            <div class="space-y-4">
                @foreach (var item in Model.Items)
                {
                    var width = item.Percentage <= 0 ? 1 : item.Percentage;
                    if (width > 100)
                    {
                        width = 100;
                    }

                    <div>
                        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1 mb-1">
                            <span class="text-sm font-medium text-gray-200 break-words">
                                @item.RouteName
                            </span>
                            <span class="text-sm font-semibold text-amber-400">
                                @item.TotalRevenue.ToString("N0") ₫ (@item.Percentage.ToString("N2")%)
                            </span>
                        </div>

                        <div class="w-full h-3 rounded-full bg-gray-800 overflow-hidden">
                            <div class="h-3 rounded-full bg-amber-400"
                                 style="width:@width%">
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <div class="w-full max-w-full overflow-hidden bg-[#1e1e24] border border-gray-700/50 rounded-xl shadow-xl">
        <div class="p-5 border-b border-gray-700/60">
            <h2 class="text-lg font-semibold text-white">
                Bảng doanh thu theo tuyến đường
            </h2>
            <p class="text-sm text-gray-400 mt-1">
                Dữ liệu bảng này sẽ được dùng chung với file Excel để đảm bảo số liệu khớp 100%.
            </p>
        </div>

        <div class="w-full overflow-x-auto">
            <table class="w-full min-w-[900px] table-fixed text-sm text-left text-gray-300">
                <thead class="text-xs uppercase bg-[#141419] text-gray-400 border-b border-gray-700/60">
                    <tr>
                        <th class="w-16 px-4 py-4 font-semibold tracking-wider">STT</th>
                        <th class="px-4 py-4 font-semibold tracking-wider">Tuyến đường</th>
                        <th class="w-40 px-4 py-4 font-semibold tracking-wider text-right">Booking</th>
                        <th class="w-32 px-4 py-4 font-semibold tracking-wider text-right">Vé bán</th>
                        <th class="w-44 px-4 py-4 font-semibold tracking-wider text-right">Doanh thu</th>
                        <th class="w-32 px-4 py-4 font-semibold tracking-wider text-right">Tỷ trọng</th>
                    </tr>
                </thead>

                <tbody class="divide-y divide-gray-700/50">
                    @if (Model.Items == null || !Model.Items.Any())
                    {
                        <tr>
                            <td colspan="6" class="px-4 py-10 text-center text-gray-500">
                                Không có dữ liệu doanh thu.
                            </td>
                        </tr>
                    }
                    else
                    {
                        var index = 1;

                        foreach (var item in Model.Items)
                        {
                            <tr class="hover:bg-gray-800/30 transition-colors duration-150">
                                <td class="px-4 py-4 text-gray-400">
                                    @index
                                </td>

                                <td class="px-4 py-4 font-semibold text-amber-400 whitespace-normal break-words">
                                    @item.RouteName
                                </td>

                                <td class="px-4 py-4 text-right">
                                    @item.TotalBookings
                                </td>

                                <td class="px-4 py-4 text-right">
                                    @item.TotalTickets
                                </td>

                                <td class="px-4 py-4 text-right font-semibold text-white">
                                    @item.TotalRevenue.ToString("N0") ₫
                                </td>

                                <td class="px-4 py-4 text-right">
                                    @item.Percentage.ToString("N2")%
                                </td>
                            </tr>

                            index++;
                        }
                    }
                </tbody>

                <tfoot class="bg-[#141419] border-t border-gray-700/60">
                    <tr>
                        <td colspan="2" class="px-4 py-4 font-bold text-white">
                            Tổng cộng
                        </td>
                        <td class="px-4 py-4 text-right font-bold text-white">
                            @Model.GrandTotalBookings
                        </td>
                        <td class="px-4 py-4 text-right font-bold text-white">
                            @Model.GrandTotalTickets
                        </td>
                        <td class="px-4 py-4 text-right font-bold text-amber-400">
                            @Model.GrandTotalRevenue.ToString("N0") ₫
                        </td>
                        <td class="px-4 py-4 text-right font-bold text-white">
                            @(Model.GrandTotalRevenue > 0 ? "100.00%" : "0.00%")
                        </td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>