@model Bus_ticket.ViewModels.RouteRevenueReportViewModel
@using System.Text.Json

@{
    var fromDateValue = ViewBag.FromDateValue != null
        ? ((DateTime)ViewBag.FromDateValue).ToString("yyyy-MM-dd")
        : Model.FromDate.ToString("yyyy-MM-dd");

    var toDateValue = ViewBag.ToDateValue != null
        ? ((DateTime)ViewBag.ToDateValue).ToString("yyyy-MM-dd")
        : Model.ToDate.ToString("yyyy-MM-dd");

    var items = Model.Items
        .OrderByDescending(x => x.TotalRevenue)
        .ToList();

    var chartLabels = JsonSerializer.Serialize(items.Select(x => x.RouteName));
    var chartData = JsonSerializer.Serialize(items.Select(x => x.TotalRevenue));
    var chartRows = JsonSerializer.Serialize(items.Select((x, i) => $"route-revenue-row-{i}"));
}

<div class="p-4 sm:p-6 lg:p-8 space-y-6 max-w-full overflow-x-hidden animate-fade-in">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold tracking-tight text-white">
                Thống kê doanh thu theo tuyến đường
            </h1>
            <p class="text-sm text-gray-400 mt-1">
                Doanh thu được sắp xếp giảm dần theo từng tuyến. Click lát biểu đồ để highlight dòng tương ứng.
            </p>
        </div>

        <div class="flex flex-wrap items-center gap-3 self-end sm:self-center">
            <input id="date_range_RouteRevenue"
                   type="text"
                   readonly
                   class="min-w-[260px] rounded-lg border border-gray-700 bg-gray-900 px-3 py-2.5 text-sm text-white cursor-pointer focus:border-amber-400 focus:ring-2 focus:ring-amber-400"
                   placeholder="Chọn khoảng ngày" />

            <a asp-controller="Dashboard"
               asp-action="ExportRouteRevenue"
               asp-route-fromDate="@fromDateValue"
               asp-route-toDate="@toDateValue"
               class="inline-flex items-center justify-center px-4 py-2.5 text-sm font-semibold text-gray-900 bg-emerald-400 hover:bg-emerald-500 rounded-lg transition-colors duration-200 shadow-sm whitespace-nowrap">
                Xuất Excel
            </a>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4">
        <div class="bg-[#1e1e24] border border-gray-700/50 rounded-xl p-5 shadow-xl">
            <p class="text-sm text-gray-400">Tổng doanh thu</p>
            <p class="text-2xl font-bold text-amber-400 mt-2">
                @Model.GrandTotalRevenue.ToString("N0") đ
            </p>
        </div>

        <div class="bg-[#1e1e24] border border-gray-700/50 rounded-xl p-5 shadow-xl">
            <p class="text-sm text-gray-400">Booking thành công</p>
            <p class="text-2xl font-bold text-white mt-2">
                @Model.GrandTotalBookings.ToString("N0")
            </p>
        </div>

        <div class="bg-[#1e1e24] border border-gray-700/50 rounded-xl p-5 shadow-xl">
            <p class="text-sm text-gray-400">Số vé bán</p>
            <p class="text-2xl font-bold text-white mt-2">
                @Model.GrandTotalTickets.ToString("N0")
            </p>
        </div>

        <div class="bg-[#1e1e24] border border-gray-700/50 rounded-xl p-5 shadow-xl">
            <p class="text-sm text-gray-400">Số tuyến có doanh thu</p>
            <p class="text-2xl font-bold text-white mt-2">
                @items.Count.ToString("N0")
            </p>
        </div>
    </div>

    <div class="grid grid-cols-1 2xl:grid-cols-[430px_minmax(0,1fr)] gap-6">
        <div class="bg-[#1e1e24] border border-gray-700/50 rounded-xl p-5 shadow-xl">
            <h2 class="text-lg font-semibold text-white mb-2">
                Biểu đồ phân bổ doanh thu
            </h2>
            <p class="text-sm text-gray-400 mb-4">
                Click vào lát biểu đồ để highlight tuyến tương ứng trong bảng.
            </p>

            @if (!items.Any() || Model.GrandTotalRevenue <= 0)
            {
                <div class="py-16 text-center text-gray-500">
                    Không có dữ liệu doanh thu trong khoảng thời gian này.
                </div>
            }
            else
            {
                <div class="h-[360px] max-w-[390px] mx-auto">
                    <canvas id="routeRevenuePieChart"></canvas>
                </div>
            }
        </div>

        <div class="w-full max-w-full overflow-hidden bg-[#1e1e24] border border-gray-700/50 rounded-xl shadow-xl">
            <div class="p-5 border-b border-gray-700/60">
                <h2 class="text-lg font-semibold text-white">
                    Bảng doanh thu theo tuyến đường
                </h2>
                <p class="text-sm text-gray-400 mt-1">
                    Đã sắp xếp giảm dần theo doanh thu.
                </p>
            </div>

            <div class="w-full overflow-x-auto">
                <table class="w-full min-w-[980px] text-sm text-left text-gray-300">
                    <thead class="text-xs uppercase bg-[#141419] text-gray-400 border-b border-gray-700/60">
                        <tr>
                            <th class="w-[80px] px-4 py-4 whitespace-nowrap">STT</th>
                            <th class="w-[320px] px-4 py-4 whitespace-nowrap">Tuyến đường</th>
                            <th class="w-[170px] px-4 py-4 text-right whitespace-nowrap">Booking</th>
                            <th class="w-[160px] px-4 py-4 text-right whitespace-nowrap">Vé bán</th>
                            <th class="w-[220px] px-4 py-4 text-right whitespace-nowrap">Doanh thu</th>
                            <th class="w-[150px] px-4 py-4 text-right whitespace-nowrap">Tỷ lệ</th>
                        </tr>
                    </thead>

                    <tbody class="divide-y divide-gray-700/50">
                        @if (!items.Any())
                        {
                            <tr>
                                <td colspan="6" class="px-4 py-8 text-center text-gray-500">
                                    Không có dữ liệu hiển thị.
                                </td>
                            </tr>
                        }
                        else
                        {
                            for (var i = 0; i < items.Count; i++)
                            {
                                var item = items[i];

                                <tr id="route-revenue-row-@i"
                                    data-linked-row="true"
                                    class="hover:bg-gray-800/30 transition-colors duration-150 scroll-mt-24">
                                    <td class="px-4 py-4 text-gray-400 whitespace-nowrap">
                                        @(i + 1)
                                    </td>

                                    <td class="px-4 py-4 font-semibold text-white">
                                        <div class="max-w-[320px] leading-6 break-words">
                                            @item.RouteName
                                        </div>
                                    </td>

                                    <td class="px-4 py-4 text-right whitespace-nowrap">
                                        @item.TotalBookings.ToString("N0")
                                    </td>

                                    <td class="px-4 py-4 text-right whitespace-nowrap">
                                        @item.TotalTickets.ToString("N0")
                                    </td>

                                    <td class="px-4 py-4 text-right font-bold text-amber-400 whitespace-nowrap">
                                        @item.TotalRevenue.ToString("N0") đ
                                    </td>

                                    <td class="px-4 py-4 text-right font-semibold text-emerald-400 whitespace-nowrap">
                                        @item.Percentage.ToString("N2")%
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>

                    <tfoot class="bg-[#141419] border-t border-gray-700/60">
                        <tr>
                            <td colspan="2" class="px-4 py-4 font-bold text-white">
                                Tổng cộng
                            </td>
                            <td class="px-4 py-4 text-right font-bold text-white">
                                @Model.GrandTotalBookings.ToString("N0")
                            </td>
                            <td class="px-4 py-4 text-right font-bold text-white">
                                @Model.GrandTotalTickets.ToString("N0")
                            </td>
                            <td class="px-4 py-4 text-right font-bold text-amber-400">
                                @Model.GrandTotalRevenue.ToString("N0") đ
                            </td>
                            <td class="px-4 py-4 text-right font-bold text-white">
                                @(Model.GrandTotalRevenue > 0 ? "100.00%" : "0.00%")
                            </td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
    initializeDashboardDateRangePicker('RouteRevenue', '@fromDateValue', '@toDateValue');

    if (document.getElementById('routeRevenuePieChart')) {
        renderDashboardPieChart(
            'routeRevenuePieChart',
            @Html.Raw(chartLabels),
            @Html.Raw(chartData),
            @Html.Raw(chartRows),
            'Doanh thu'
        );
    }
</script>