@model IEnumerable<Bus_ticket.ViewModels.SeatAnalyticsViewModel>

@{
    var fromDateValue = ViewBag.FromDateValue != null ? ((DateTime)ViewBag.FromDateValue).ToString("yyyy-MM-dd") : DateTime.Today.AddDays(-7).ToString("yyyy-MM-dd");
    var toDateValue = ViewBag.ToDateValue != null ? ((DateTime)ViewBag.ToDateValue).ToString("yyyy-MM-dd") : DateTime.Today.ToString("yyyy-MM-dd");

    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;

    string targetType = "SeatAnalytics";
    string dropdownId = "dropdown_" + targetType;
    string pickerId = "picker_" + targetType;
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/litepicker/dist/plugins/ranges/css/style.css"/>
<script src="https://cdn.jsdelivr.net/npm/litepicker/dist/plugins/ranges.js"></script>

<div class="p-4 sm:p-6 lg:p-8 space-y-6 max-w-full overflow-x-hidden animate-fade-in">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold tracking-tight text-white">
                Thống kê tỷ lệ lấp đầy ghế
            </h1>
            <p class="text-sm text-gray-400 mt-1">
                Xem hiệu suất bán vé (% số ghế đã bán trên tổng số ghế hiện có) theo từng chuyến xe thực tế (Hiển thị
                tối đa 10 chuyến/trang).
            </p>
        </div>

        <div class="flex flex-wrap items-center gap-3 self-end sm:self-center">

            <div class="relative inline-block text-left select-none">
                <button type="button" onclick="toggleDatePickerDropdown(event, '@dropdownId')"
                        class="inline-flex items-center gap-2 px-4 py-2.5 text-sm font-semibold text-white bg-gray-800 hover:bg-gray-700 rounded-lg border border-gray-700 shadow-sm transition-colors">
                    <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                    <span>Lọc khoảng ngày</span>
                    <svg class="w-3 h-3 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                    </svg>
                </button>

                <div id="@dropdownId"
                     class="hidden absolute right-0 mt-2 bg-[#1e1e24] border border-gray-700 rounded-xl shadow-2xl p-0 z-50 flex"
                     style="min-width: 650px;">

                    <div
                        class="w-[140px] min-w-[140px] bg-[#141419] border-r border-gray-700 p-3 flex flex-col gap-1.5 rounded-l-xl">
                        <button type="button" onclick="selectQuickRange('today')"
                                class="w-full text-left px-3 py-2 text-xs font-semibold text-gray-400 hover:text-amber-400 hover:bg-gray-800 rounded-md transition-colors">
                            Hôm nay
                        </button>
                        <button type="button" onclick="selectQuickRange('yesterday')"
                                class="w-full text-left px-3 py-2 text-xs font-semibold text-gray-400 hover:text-amber-400 hover:bg-gray-800 rounded-md transition-colors">
                            Hôm qua
                        </button>
                        <button type="button" onclick="selectQuickRange('7days')"
                                class="w-full text-left px-3 py-2 text-xs font-semibold text-gray-400 hover:text-amber-400 hover:bg-gray-800 rounded-md transition-colors">
                            7 ngày qua
                        </button>
                        <button type="button" onclick="selectQuickRange('30days')"
                                class="w-full text-left px-3 py-2 text-xs font-semibold text-gray-400 hover:text-amber-400 hover:bg-gray-800 rounded-md transition-colors">
                            30 ngày qua
                        </button>
                        <button type="button" onclick="selectQuickRange('thisMonth')"
                                class="w-full text-left px-3 py-2 text-xs font-semibold text-gray-400 hover:text-amber-400 hover:bg-gray-800 rounded-md transition-colors">
                            Tháng này
                        </button>
                        <button type="button" onclick="selectQuickRange('lastMonth')"
                                class="w-full text-left px-3 py-2 text-xs font-semibold text-gray-400 hover:text-amber-400 hover:bg-gray-800 rounded-md transition-colors">
                            Tháng trước
                        </button>
                    </div>

                    <div class="flex-1 p-2 bg-[#1e1e24] rounded-r-xl">
                        <div id="inline_picker_container_@targetType"></div>
                        <input type="hidden" id="@pickerId">
                    </div>

                </div>
            </div>

            <a asp-controller="Dashboard"
               asp-action="ExportSeatAnalytics"
               asp-route-fromDate="@fromDateValue"
               asp-route-toDate="@toDateValue"
               class="inline-flex items-center justify-center px-4 py-2.5 text-sm font-semibold text-gray-900 bg-emerald-400 hover:bg-emerald-500 rounded-lg transition-colors duration-200 shadow-sm whitespace-nowrap">
                Xuất Toàn Bộ Excel
            </a>
        </div>
    </div>

    <div class="bg-[#1e1e24] border border-gray-700/50 rounded-xl p-5 shadow-xl">
        <div class="mb-4">
            <h2 class="text-lg font-semibold text-white">Biểu đồ tỷ lệ lấp đầy theo chuyến xe</h2>
        </div>

        @if (Model == null || !Model.Any())
        {
            <div class="py-10 text-center text-gray-500">Không có dữ liệu chuyến xe.</div>
        }
        else
        {
            <div class="space-y-5">
                @foreach (var item in Model)
                {
                    var width = item.OccupancyRate <= 0 ? 0 : item.OccupancyRate;
                    if (width > 100) width = 100;

                    string progressBgColor = "bg-red-500";
                    if (item.OccupancyRate >= 80) progressBgColor = "bg-emerald-500";
                    else if (item.OccupancyRate >= 50) progressBgColor = "bg-amber-400";

                    <div>
                        <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1 mb-1">
                            <span class="text-sm font-medium text-gray-200">
                                <span
                                    class="text-amber-400 font-semibold">@item.TripCode</span> - @item.RouteName (@item.LicensePlate)
                            </span>
                            <span
                                class="text-xs text-gray-400">Khởi hành: @item.DepartureTime.ToString("dd/MM/yyyy HH:mm")</span>
                        </div>
                        <div class="flex items-center gap-3">
                            <div class="w-full h-3 rounded-full bg-gray-800 overflow-hidden">
                                <div class="h-3 rounded-full @progressBgColor" style="width:@width%"></div>
                            </div>
                            <span class="text-sm font-semibold text-white min-w-[75px] text-right">
                                @item.BookedSeats/@item.TotalSeats (@item.OccupancyRate.ToString("N2")%)
                            </span>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <div class="w-full max-w-full overflow-hidden bg-[#1e1e24] border border-gray-700/50 rounded-xl shadow-xl">
        <div class="p-5 border-b border-gray-700/60">
            <h2 class="text-lg font-semibold text-white">Bảng danh sách chi tiết số ghế</h2>
        </div>

        <div class="w-full overflow-x-auto">
            <table class="w-full min-w-[900px] table-fixed text-sm text-left text-gray-300">
                <thead class="text-xs uppercase bg-[#141419] text-gray-400 border-b border-gray-700/60">
                <tr>
                    <th class="w-24 px-4 py-4 font-semibold">Mã</th>
                    <th class="px-4 py-4 font-semibold">Tuyến đường</th>
                    <th class="w-36 px-4 py-4 font-semibold">Biển số</th>
                    <th class="w-44 px-4 py-4 font-semibold">Giờ xuất phát</th>
                    <th class="w-36 px-4 py-4 font-semibold text-right">Ghế đã đặt</th>
                    <th class="w-32 px-4 py-4 font-semibold text-right">Tỷ lệ</th>
                    <th class="w-32 px-4 py-4 font-semibold text-center">Trạng thái</th>
                </tr>
                </thead>
                <tbody class="divide-y divide-gray-700/50">
                @if (Model == null || !Model.Any())
                {
                    <tr>
                        <td colspan="7" class="px-4 py-10 text-center text-gray-500">Không có dữ liệu.</td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr class="hover:bg-gray-800/30 transition-colors duration-150">
                            <td class="px-4 py-4 font-bold text-gray-400">@item.TripCode</td>
                            <td class="px-4 py-4 font-semibold text-amber-400 break-words">@item.RouteName</td>
                            <td class="px-4 py-4"><span
                                    class="px-2 py-1 text-xs font-semibold text-gray-300 bg-gray-800 border border-gray-700 rounded">@item.LicensePlate</span>
                            </td>
                            <td class="px-4 py-4 text-gray-400">@item.DepartureTime.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="px-4 py-4 text-right font-semibold text-white"><span
                                    class="text-amber-400">@item.BookedSeats</span> / @item.TotalSeats</td>
                            <td class="px-4 py-4 text-right font-bold text-white">@item.OccupancyRate.ToString("N2")%</td>
                            <td class="px-4 py-4 text-center">
                                @if (item.Status?.ToLower() == "scheduled")
                                {
                                    <span
                                        class="px-2.5 py-1 text-xs font-medium text-sky-400 bg-sky-950/50 border border-sky-900 rounded-full">Lên lịch</span>
                                }
                                else if (item.Status?.ToLower() == "completed")
                                {
                                    <span
                                        class="px-2.5 py-1 text-xs font-medium text-emerald-400 bg-emerald-950/50 border border-emerald-900 rounded-full">Xong</span>
                                }
                                else
                                {
                                    <span
                                        class="px-2.5 py-1 text-xs font-medium text-amber-400 bg-amber-950/50 border border-amber-900 rounded-full">@item.Status</span>
                                }
                            </td>
                        </tr>
                    }
                }
                </tbody>
            </table>
        </div>

        @if (totalPages > 1)
        {
            <div
                class="px-5 py-4 bg-[#141419] border-t border-gray-700/60 flex flex-col sm:flex-row items-center justify-between gap-4">
                <div class="text-xs text-gray-400">
                    Hiển thị trang <span class="font-semibold text-white">@currentPage</span> / <span
                        class="font-semibold text-white">@totalPages</span> (Tổng <span
                        class="font-semibold text-white">@ViewBag.TotalItems</span> chuyến xe)
                </div>
                <div class="flex items-center space-x-1.5 flex-wrap justify-center">
                    <a asp-action="SeatAnalytics"
                       asp-route-fromDate="@fromDateValue"
                       asp-route-toDate="@toDateValue"
                       asp-route-page="@(currentPage - 1)"
                       class="px-2.5 py-1.5 text-xs font-medium text-gray-400 bg-gray-800 border border-gray-700 rounded-lg hover:text-white hover:bg-gray-700 @(currentPage == 1 ? "pointer-events-none opacity-40" : "")">
                        Trước
                    </a>

                    @{
                        // Thuật toán hiển thị tối đa 2 trang xung quanh trang hiện tại
                        int maxPagesToShow = 2;
                        int startPage = Math.Max(1, currentPage - maxPagesToShow);
                        int endPage = Math.Min(totalPages, currentPage + maxPagesToShow);

                        // Nếu trang bắt đầu > 1, hiển thị trang 1 và dấu ...
                        if (startPage > 1)
                        {
                            <a asp-action="SeatAnalytics" asp-route-fromDate="@fromDateValue"
                               asp-route-toDate="@toDateValue" asp-route-page="1"
                               class="px-2.5 py-1.5 text-xs font-medium rounded-lg border text-gray-400 bg-gray-800 border-gray-700 hover:text-white hover:bg-gray-700">1</a>
                            if (startPage > 2)
                            {
                                <span class="px-2 py-1 text-xs text-gray-500">...</span>
                            }
                        }

                        // Vòng lặp hiển thị các trang ở giữa
                        for (int i = startPage; i <= endPage; i++)
                        {
                            <a asp-action="SeatAnalytics"
                               asp-route-fromDate="@fromDateValue"
                               asp-route-toDate="@toDateValue"
                               asp-route-page="@i"
                               class="px-2.5 py-1.5 text-xs font-medium rounded-lg border @(i == currentPage ? "bg-amber-400 text-gray-900 border-amber-400 font-bold" : "text-gray-400 bg-gray-800 border-gray-700 hover:text-white hover:bg-gray-700")">
                                @i
                            </a>
                        }

                        // Nếu trang kết thúc < tổng số trang, hiển thị dấu ... và trang cuối
                        if (endPage < totalPages)
                        {
                            if (endPage < totalPages - 1)
                            {
                                <span class="px-2 py-1 text-xs text-gray-500">...</span>
                            }

                            <a asp-action="SeatAnalytics" asp-route-fromDate="@fromDateValue"
                               asp-route-toDate="@toDateValue" asp-route-page="@totalPages"
                               class="px-2.5 py-1.5 text-xs font-medium rounded-lg border text-gray-400 bg-gray-800 border-gray-700 hover:text-white hover:bg-gray-700">@totalPages</a>
                        }
                    }

                    <a asp-action="SeatAnalytics"
                       asp-route-fromDate="@fromDateValue"
                       asp-route-toDate="@toDateValue"
                       asp-route-page="@(currentPage + 1)"
                       class="px-2.5 py-1.5 text-xs font-medium text-gray-400 bg-gray-800 border border-gray-700 rounded-lg hover:text-white hover:bg-gray-700 @(currentPage == totalPages ? "pointer-events-none opacity-40" : "")">
                        Sau
                    </a>
                </div>
            </div>
        }
    </div>
</div>

<script>
    // Khai báo biến lưu trữ đối tượng lịch
    let globalLitepickerInstance = null;

    function initializeThisPicker() {
        const pInput = document.getElementById('@pickerId');
        const pContainer = document.getElementById('inline_picker_container_@targetType');
        if (!pInput || !pContainer) return;

        // Cấu hình Litepicker gốc chạy ở chế độ inlineMode (Luôn mở bung sẵn nằm trong khung bên phải)
        globalLitepickerInstance = new Litepicker({
            element: pInput,
            parentEl: pContainer, // Chỉ định hiển thị chui gọn vào div bên phải
            inlineMode: true,    // ÉP BUỘC LUÔN BUNG SẴN LỊCH KHÔNG CẦN CLICK INPUT
            singleMode: false,
            numberOfMonths: 2,
            numberOfColumns: 2,
            autoApply: true,
            setup: (p) => {
                p.on('selected', (date1, date2) => {
                    const s = date1.format('YYYY-MM-DD');
                    const e = date2.format('YYYY-MM-DD');

                    // Chọn xong trên lịch thì đóng cả cụm bộ lọc lớn lại
                    document.getElementById('@dropdownId')?.classList.add('hidden');

                    if (typeof loadStatistic === "function") {
                        loadStatistic('@targetType', 1, s, e);
                    }
                });
            }
        });

        // Thiết lập khoảng ngày hiện tại
        if ('@fromDateValue' && '@toDateValue') {
            globalLitepickerInstance.setDateRange(new Date('@fromDateValue'), new Date('@toDateValue'));
        }
    }

    // Hàm xử lý tương tác click nhanh vào 6 nút bên cột trái
    window.selectQuickRange = function (rangeType) {
        if (!globalLitepickerInstance) return;

        const today = new Date();
        let start = new Date();
        let end = new Date();

        switch (rangeType) {
            case 'today':
                start = today;
                end = today;
                break;
            case 'yesterday':
                const yest = new Date();
                yest.setDate(today.getDate() - 1);
                start = yest;
                end = yest;
                break;
            case '7days':
                const d7 = new Date();
                d7.setDate(today.getDate() - 6);
                start = d7;
                end = today;
                break;
            case '30days':
                const d30 = new Date();
                d30.setDate(today.getDate() - 29);
                start = d30;
                end = today;
                break;
            case 'thisMonth':
                start = new Date(today.getFullYear(), today.getMonth(), 1);
                end = new Date(today.getFullYear(), today.getMonth() + 1, 0);
                break;
            case 'lastMonth':
                start = new Date(today.getFullYear(), today.getMonth() - 1, 1);
                end = new Date(today.getFullYear(), today.getMonth(), 0);
                break;
        }

        // Đẩy khoảng ngày vừa tính toán vào lịch
        globalLitepickerInstance.setDateRange(start, end);

        // Trích xuất chuỗi và gọi Ajax nạp lại dữ liệu báo cáo
        const sString = globalLitepickerInstance.getStartDate().format('YYYY-MM-DD');
        const eString = globalLitepickerInstance.getEndDate().format('YYYY-MM-DD');

        document.getElementById('@dropdownId')?.classList.add('hidden');

        if (typeof loadStatistic === "function") {
            loadStatistic('@targetType', 1, sString, eString);
        }
    }

    // Kích hoạt ngay khi mã HTML đổ về qua AJAX thành công
    setTimeout(initializeThisPicker, 100);

    // Xử lý cơ chế đóng mở menu toàn cục
    if (typeof window.toggleDatePickerDropdown !== "function") {
        window.toggleDatePickerDropdown = function (event, id) {
            event.stopPropagation();
            const el = document.getElementById(id);
            if (el) el.classList.toggle('hidden');
        };

        document.addEventListener('click', function (e) {
            if (!e.target.closest('.relative') && !e.target.closest('.litepicker')) {
                document.querySelectorAll('[id^="dropdown_"]').forEach(el => el.classList.add('hidden'));
            }
        });
    }
</script>

<style>
    /* CUSTOM STYLE CHO LỊCH KHỚP VỚI KHUNG GIAO DIỆN TỐI */
    .litepicker {
        background-color: transparent !important;
        border: none !important;
        box-shadow: none !important;
        padding: 0 !important;
    }

    .litepicker .container__months {
        background-color: transparent !important;
        display: flex !important;
        gap: 12px !important;
    }

    .litepicker .container__months .month-item-header {
        color: #ffffff !important;
        font-weight: bold;
    }

    .litepicker .container__months .month-item-header button {
        color: #9ca3af !important;
    }

    .litepicker .container__months .month-item-weekdays-row > div {
        color: #6b7280 !important;
    }

    .litepicker .container__months .month-item .container__days .day-item {
        color: #e5e7eb !important;
    }

    .litepicker .container__months .month-item .container__days .day-item:hover {
        background-color: #374151 !important;
        color: #fff !important;
    }

    .litepicker .container__months .month-item .container__days .day-item.is-in-range {
        background-color: rgba(245, 158, 11, 0.15) !important;
        color: #f59e0b !important;
    }

    .litepicker .container__months .month-item .container__days .day-item.is-start-date,
    .litepicker .container__months .month-item .container__days .day-item.is-end-date {
        background-color: #f59e0b !important;
        color: #141419 !important;
        font-weight: bold;
    }
</style>