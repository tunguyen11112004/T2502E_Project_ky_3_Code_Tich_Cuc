@{
    ViewData["Title"] = "Tổng Quan Thống Kê";
}

<!-- CSS của Flatpickr -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<link rel="stylesheet" type="text/css" href="https://npmcdn.com/flatpickr/dist/themes/dark.css">

<div class="p-6 space-y-6">
    <!-- Header & Bộ lọc thời gian -->
    <div class="flex flex-col md:flex-row justify-between items-center bg-gray-800 p-4 rounded-xl border border-gray-700 shadow-md">
        <h2 class="text-2xl font-bold text-white mb-4 md:mb-0">Tổng Quan Hệ Thống</h2>
        
        <div class="flex items-center gap-3">
            <div>
                <input type="text" id="filterFromDate" class="bg-gray-700 border border-gray-600 text-white rounded-lg p-2 focus:ring-blue-500 focus:border-blue-500 w-32 text-center" placeholder="Từ ngày" />
            </div>
            <span class="text-gray-400">-</span>
            <div>
                <input type="text" id="filterToDate" class="bg-gray-700 border border-gray-600 text-white rounded-lg p-2 focus:ring-blue-500 focus:border-blue-500 w-32 text-center" placeholder="Đến ngày" />
            </div>
            <button id="btnFilter" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg font-medium transition-colors">
                Lọc dữ liệu
            </button>
        </div>
    </div>

    <!-- 4 Cards KPI -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <div class="bg-gray-800 p-6 rounded-xl border border-gray-700 shadow-md">
            <p class="text-gray-400 text-sm">Doanh thu</p>
            <p id="cardRevenue" class="text-2xl font-bold text-white">...</p>
        </div>
        <div class="bg-gray-800 p-6 rounded-xl border border-gray-700 shadow-md">
            <p class="text-gray-400 text-sm">Booking thành công</p>
            <p id="cardBookings" class="text-2xl font-bold text-white">...</p>
        </div>
        <div class="bg-gray-800 p-6 rounded-xl border border-gray-700 shadow-md">
            <p class="text-gray-400 text-sm">Vé bán</p>
            <p id="cardTickets" class="text-2xl font-bold text-white">...</p>
        </div>
        <div class="bg-gray-800 p-6 rounded-xl border border-gray-700 shadow-md">
            <p class="text-gray-400 text-sm">Tuyến có doanh thu</p>
            <p id="cardRoutes" class="text-2xl font-bold text-white">...</p>
        </div>
    </div>

    <!-- Progress Bars -->
    <div class="bg-gray-800 p-6 rounded-xl border border-gray-700 shadow-md">
        <h3 class="text-lg font-bold text-white mb-4">Tỷ lệ lấp đầy các tuyến</h3>
        <div id="routeProgressList" class="space-y-4"></div>
    </div>

    <!-- Khu vực Báo Cáo Doanh Thu -->
    <div class="bg-gray-800 p-6 rounded-xl border border-gray-700 shadow-md w-full md:w-1/2">
        <h3 class="text-lg font-bold text-white mb-2">Xuất báo cáo Doanh Thu</h3>
        <p class="text-gray-400 text-sm mb-4">Dữ liệu xuất ra sẽ tương ứng với khoảng thời gian bạn đang lọc ở phía trên.</p>
        <button id="btnExportRevenue" class="bg-green-600 hover:bg-green-700 text-white px-6 py-2.5 rounded-lg font-medium w-full transition-colors">
            Tải Excel Doanh Thu
        </button>
    </div>
</div>

@section Scripts {
    <!-- JS của Flatpickr -->
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const today = new Date().toISOString().split('T')[0];
            
            // Cấu hình Flatpickr ép hiển thị dd/MM/yyyy
            const fpConfig = {
                dateFormat: "Y-m-d", // Giá trị thực tế JavaScript/C# dùng
                altInput: true,      // Hiển thị thanh Input phụ cho người dùng
                altFormat: "d/m/Y",  // Định dạng hiển thị ép kiểu VN
                defaultDate: today
            };

            flatpickr("#filterFromDate", fpConfig);
            flatpickr("#filterToDate", fpConfig);

            function loadDashboard() {
                const from = document.getElementById('filterFromDate').value;
                const to = document.getElementById('filterToDate').value;

                fetch(`/Dashboard/GetDashboardSummary?fromDate=${from}&toDate=${to}`)
                    .then(r => r.json())
                    .then(res => {
                        if(res.success) {
                            document.getElementById('cardRevenue').innerText = res.data.totalRevenue.toLocaleString('vi-VN', {style:'currency', currency:'VND'});
                            document.getElementById('cardBookings').innerText = res.data.successfulBookings;
                            document.getElementById('cardTickets').innerText = res.data.totalTickets;
                            document.getElementById('cardRoutes').innerText = res.data.routesWithRevenue;
                        }
                    });

                fetch(`/Dashboard/GetRouteOccupancy?fromDate=${from}&toDate=${to}`)
                    .then(r => r.json())
                    .then(res => {
                        const container = document.getElementById('routeProgressList');
                        container.innerHTML = res.data.map(item => `
                            <div>
                                <div class="flex justify-between text-white text-sm mb-1"><span>${item.routeName}</span><span>${item.occupancy}%</span></div>
                                <div class="w-full bg-gray-700 h-2 rounded-full"><div class="bg-yellow-400 h-2 rounded-full" style="width: ${item.occupancy}%"></div></div>
                            </div>
                        `).join('');
                    });
            }

            document.getElementById('btnFilter').addEventListener('click', loadDashboard);

            document.getElementById('btnExportRevenue').addEventListener('click', function() {
                const from = document.getElementById('filterFromDate').value;
                const to = document.getElementById('filterToDate').value;
                window.location.href = `/Dashboard/ExportTotalRevenue?fromDate=${from}&toDate=${to}`;
            });

            loadDashboard();
        });
    </script>
}