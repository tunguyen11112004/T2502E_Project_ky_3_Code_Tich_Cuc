@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Admin Dashboard";
}

<div class="p-6 space-y-6">
    <div>
        <h1 class="text-2xl font-bold text-gray-950 dark:text-white mb-1">Xin chào Admin!</h1>
        <p class="text-sm text-gray-600 dark:text-gray-400">Hệ thống gộp báo cáo tổng quan dưới dạng tương tác trực tiếp.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <button onclick="loadStatistic('OperatorRevenue')" class="p-4 bg-blue-500 text-white rounded-lg text-left transition hover:bg-blue-600 focus:outline-none focus:ring-4 focus:ring-blue-300">
            <h3 class="font-semibold text-blue-100">Xếp hạng doanh thu nhà xe</h3>
            <p class="text-2xl font-bold mt-1">Tổng doanh thu của từng nhà xe</p>
            <span class="text-xs text-blue-200 block mt-2">Xem chi tiết doanh thu từng nhà xe →</span>
        </button>
        <button onclick="loadStatistic('BranchCancellation')" class="p-4 bg-green-500 text-white rounded-lg text-left transition hover:bg-green-600 focus:outline-none focus:ring-4 focus:ring-green-300">
            <h3 class="font-semibold text-green-100">Tỷ lệ hủy chuyến</h3>
            <p class="text-2xl font-bold mt-1">Độ uy tín</p>
            <span class="text-xs text-green-200 block mt-2">Xem báo cáo hủy chuyến hệ thống →</span>
        </button>
        <button onclick="loadStatistic('SeatAnalytics')" class="p-4 bg-purple-500 text-white rounded-lg text-left transition hover:bg-purple-600 focus:outline-none focus:ring-4 focus:ring-purple-300">
            <h3 class="font-semibold text-purple-100">Chuyến xe & Ghế trống</h3>
            <p class="text-2xl font-bold mt-1">Hiệu suất lấp đầy</p>
            <span class="text-xs text-purple-200 block mt-2">Xem phân tích lấp đầy ghế →</span>
        </button>
    </div>

    <div id="statisticContainer" class="bg-gray-50 dark:bg-gray-900/40 rounded-xl min-h-[250px] p-4 relative border border-dashed border-gray-300 dark:border-gray-700">
        <div id="placeholderText" class="text-center py-16 text-gray-400">
            <p>Vui lòng click chọn 1 trong 3 Thẻ thông số phía trên để hiển thị biểu đồ và bảng dữ liệu chi tiết.</p>
        </div>

        <div id="loadingSpinner" class="hidden absolute inset-0 bg-white/50 dark:bg-gray-900/60 flex items-center justify-center rounded-xl z-10">
            <div class="animate-spin rounded-full h-10 w-10 border-b-2 border-blue-500"></div>
        </div>

        <div id="dynamicContent"></div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    // Định nghĩa biến toàn cục để lưu trạng thái loại thống kê hiện tại
    let currentType = '';

    async function loadStatistic(type, page = 1, fromDate = '', toDate = '') {
        currentType = type;
        const placeholder = document.getElementById('placeholderText');
        const spinner = document.getElementById('loadingSpinner');
        let contentDiv = document.getElementById('dynamicContent');

        // Tạo vùng chứa dynamicContent nếu chưa có
        if (!contentDiv) {
            contentDiv = document.createElement('div');
            contentDiv.id = 'dynamicContent';
            document.getElementById('statisticContainer')?.appendChild(contentDiv);
        }

        if (placeholder) placeholder.style.display = 'none';
        spinner.classList.remove('hidden');

        try {
            // SỬA ĐỔI: Bổ sung đầy đủ tham số fromDate và toDate vào URL gửi lên Controller
            const url = `/Dashboard/${type}Partial?page=${page}&fromDate=${fromDate}&toDate=${toDate}`;
            const response = await fetch(url);
            if (!response.ok) throw new Error('Lỗi tải dữ liệu hệ thống.');

            const htmlResult = await response.text();
            contentDiv.innerHTML = htmlResult;

            // SỬA ĐỔI: Thay thế eval() bằng cách tạo thẻ script thực thông qua DOM 
            // Điều này giúp trình duyệt tự động biên dịch, nhận diện chính xác thư viện Litepicker và các hàm onclick toàn cục
            const scripts = contentDiv.getElementsByTagName("script");
            for (let i = 0; i < scripts.length; i++) {
                const newScript = document.createElement("script");
                newScript.text = scripts[i].text;
                document.body.appendChild(newScript).parentNode.removeChild(newScript);
            }
        } catch (error) {
            console.error(error);
            alert('Không thể lấy được dữ liệu thống kê, vui lòng kiểm tra lại!');
        } finally {
            spinner.classList.add('hidden');
        }
    }
</script>