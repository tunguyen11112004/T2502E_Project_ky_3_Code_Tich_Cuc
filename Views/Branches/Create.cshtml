@model Bus_ticket.Models.Branch

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Thêm Chi nhánh";
}

<div class="p-6 sm:p-8 max-w-3xl mx-auto space-y-6">
    <div>
        <h1 class="text-2xl font-bold tracking-tight text-white">Thêm Chi nhánh mới</h1>
        <p class="text-sm text-gray-400 mt-1">Nhập thông tin văn phòng hoặc bến xe thuộc hệ thống nhà xe.</p>
    </div>

    <form asp-controller="Branches" asp-action="Create" method="post" class="space-y-5 bg-[#1e1e24] border border-gray-700/50 rounded-xl p-6">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-sm text-red-400"></div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
                <label asp-for="BranchCode" class="block mb-2 text-sm font-medium text-gray-300">Mã chi nhánh</label>
                <input asp-for="BranchCode" class="block w-full px-4 py-2.5 text-sm text-white bg-gray-900 border border-gray-700 rounded-lg focus:ring-2 focus:ring-amber-400 focus:border-amber-400" placeholder="CN-HN-01" />
                <span asp-validation-for="BranchCode" class="text-sm text-red-400"></span>
            </div>

            <div>
                <label asp-for="BranchName" class="block mb-2 text-sm font-medium text-gray-300">Tên chi nhánh</label>
                <input asp-for="BranchName" class="block w-full px-4 py-2.5 text-sm text-white bg-gray-900 border border-gray-700 rounded-lg focus:ring-2 focus:ring-amber-400 focus:border-amber-400" placeholder="Văn phòng Hà Nội" />
                <span asp-validation-for="BranchName" class="text-sm text-red-400"></span>
            </div>
        </div>

        <div>
            <label asp-for="Address" class="block mb-2 text-sm font-medium text-gray-300">Địa chỉ</label>
            <textarea asp-for="Address" rows="3" class="block w-full px-4 py-2.5 text-sm text-white bg-gray-900 border border-gray-700 rounded-lg focus:ring-2 focus:ring-amber-400 focus:border-amber-400" placeholder="Nhập địa chỉ chi nhánh"></textarea>
            <span asp-validation-for="Address" class="text-sm text-red-400"></span>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
                <label asp-for="PhoneNumber" class="block mb-2 text-sm font-medium text-gray-300">Hotline</label>
                <input asp-for="PhoneNumber" class="block w-full px-4 py-2.5 text-sm text-white bg-gray-900 border border-gray-700 rounded-lg focus:ring-2 focus:ring-amber-400 focus:border-amber-400" placeholder="02437685555" />
                <span asp-validation-for="PhoneNumber" class="text-sm text-red-400"></span>
            </div>

            <div>
                <label asp-for="Status" class="block mb-2 text-sm font-medium text-gray-300">Trạng thái</label>
                <select asp-for="Status" class="block w-full px-4 py-2.5 text-sm text-white bg-gray-900 border border-gray-700 rounded-lg focus:ring-2 focus:ring-amber-400 focus:border-amber-400">
                    <option value="Active">Active</option>
                    <option value="Inactive">Inactive</option>
                    <option value="Maintenance">Maintenance</option>
                </select>
                <span asp-validation-for="Status" class="text-sm text-red-400"></span>
            </div>
        </div>

        <div class="flex items-center justify-end gap-3 pt-2">
            <a asp-controller="Branches" asp-action="Index" class="px-4 py-2.5 text-sm font-semibold text-gray-300 bg-gray-800 hover:bg-gray-700 rounded-lg">Hủy</a>
            <button type="submit" class="px-4 py-2.5 text-sm font-semibold text-gray-900 bg-amber-400 hover:bg-amber-500 rounded-lg">Lưu chi nhánh</button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
