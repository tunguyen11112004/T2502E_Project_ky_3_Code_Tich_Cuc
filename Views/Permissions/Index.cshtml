@model IEnumerable<Bus_ticket.Models.Permission>

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Admin Permission";
    
    // Thu thập dữ liệu phân trang từ ViewBag
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    long totalItems = ViewBag.TotalItems ?? 0;
    int pageSize = ViewBag.PageSize ?? 10;
    string searchTerm = ViewBag.SearchTerm ?? "";
    
    // Tính toán khoảng hiển thị bản ghi (Ví dụ: Hiển thị từ 1 đến 10 trong tổng số 25)
    long startItem = totalItems == 0 ? 0 : ((currentPage - 1) * pageSize) + 1;
    long endItem = (currentPage * pageSize) > totalItems ? totalItems : (currentPage * pageSize);
}

<div class="p-6 sm:p-8 space-y-6">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold tracking-tight text-white">Danh sách Quyền (Permissions)</h1>
            <p class="text-sm text-gray-400 mt-1">Quản lý cấu hình các quyền truy cập hệ thống toàn cục.</p>
        </div>
        <div>
            <a asp-controller="Permissions" asp-action="Create" class="inline-flex items-center justify-center px-4 py-2.5 text-sm font-semibold text-gray-900 bg-amber-400 hover:bg-amber-500 rounded-lg transition-colors duration-200 shadow-sm focus:outline-none">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/>
                </svg>
                Thêm Quyền Mới
            </a>
        </div>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="flex items-center p-4 text-sm text-red-400 rounded-lg bg-gray-800 border border-red-800" role="alert">
            <svg class="flex-shrink-0 inline w-4 h-4 mr-3" fill="currentColor" viewBox="0 0 20 20">
                <path d="M10 .5a9.5 9.5 0 1 0 9.5 9.5A9.51 9.51 0 0 0 10 .5ZM9.5 4a1.5 1.5 0 1 1 3 0 1.5 1.5 0 0 1-3 0ZM12 15H8a1 1 0 0 1 0-2h1v-3H8a1 1 0 0 1 0-2h2a1 1 0 0 1 1 1v4h1a1 1 0 0 1 0 2Z"/>
            </svg>
            <div><span class="font-medium">Thất bại!</span> @TempData["ErrorMessage"]</div>
        </div>
    }

    <div class="flex flex-col md:flex-row md:items-center md:justify-end gap-3">
        <form method="get" asp-controller="Permissions" asp-action="Index" class="w-full md:w-80">
            <div class="relative">
                <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                    <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                    </svg>
                </div>
                <input type="text" name="searchTerm" value="@searchTerm" class="block w-full pl-10 pr-4 py-2 text-sm text-white bg-gray-900 border border-gray-700 rounded-lg focus:ring-2 focus:ring-amber-400 focus:border-amber-400 placeholder-gray-500" placeholder="Tìm kiếm quyền..." />
                @if (!string.IsNullOrEmpty(searchTerm))
                {
                    <a asp-action="Index" class="absolute inset-y-0 right-0 flex items-center pr-3 text-xs text-gray-500 hover:text-white">Xóa</a>
                }
            </div>
        </form>
    </div>

    <div class="overflow-hidden bg-[#1e1e24] border border-gray-700/50 rounded-xl shadow-xl">
        <div class="overflow-x-auto">
            <table class="w-full text-sm text-left text-gray-300 whitespace-nowrap">
                <thead class="text-xs uppercase bg-[#141419] text-gray-400 border-b border-gray-700/60">
                    <tr>
                        <th scope="col" class="px-6 py-4 font-semibold tracking-wider">Tên Quyền</th>
                        <th scope="col" class="px-6 py-4 font-semibold tracking-wider">Mô Tả Chức Năng</th>
                        <th scope="col" class="px-6 py-4 font-semibold tracking-wider">Đường Dẫn API / Router</th>
                        <th scope="col" class="px-6 py-4 font-semibold tracking-wider">Phương Thức</th>
                        <th scope="col" class="px-6 py-4 font-semibold tracking-wider text-right">Hành Động</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-700/50">
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="px-6 py-10 text-center text-gray-500 bg-[#1e1e24]">
                                Không tìm thấy kết quả phù hợp nào.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr class="hover:bg-gray-800/30 transition-colors duration-150">
                                <td class="px-6 py-4 font-medium text-white">@item.Name</td>
                                <td class="px-6 py-4 text-gray-400">@item.Description</td>
                                <td class="px-6 py-4">
                                    <span class="font-mono text-xs px-2 py-1 bg-gray-900 rounded border border-gray-700 text-cyan-400">
                                        /@item.Link
                                    </span>
                                </td>
                                <td class="px-6 py-4">
                                    @{
                                        var badgeClass = item.Method == "GET" ? "bg-emerald-500/10 text-emerald-400 border-emerald-500/20" :
                                                         item.Method == "POST" ? "bg-blue-500/10 text-blue-400 border-blue-500/20" :
                                                         item.Method == "PUT" ? "bg-amber-500/10 text-amber-400 border-amber-500/20" :
                                                         "bg-rose-500/10 text-rose-400 border-rose-500/20";
                                    }
                                    <span class="inline-flex items-center px-2.5 py-0.5 text-xs font-semibold rounded-md border @badgeClass">
                                        @item.Method
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-right text-sm font-medium">
                                    <div class="inline-flex items-center gap-3">
                                        <a asp-controller="Permissions" asp-action="Edit" asp-route-id="@item.Id" class="text-amber-400 hover:text-amber-300 font-semibold transition-colors duration-150">Sửa</a>
                                        <span class="text-gray-600">|</span>
                                        <form asp-controller="Permissions" asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Bạn có chắc chắn muốn xóa không?');" class="inline">
                                            <button type="submit" class="text-rose-400 hover:text-rose-300 font-semibold transition-colors duration-150 focus:outline-none">Xóa</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="flex flex-col sm:flex-row items-center justify-between p-4 bg-[#141419] border-t border-gray-700/60 gap-4">
            <span class="text-sm text-gray-400">
                Hiển thị từ <span class="font-semibold text-white">@startItem</span> đến <span class="font-semibold text-white">@endItem</span> trong tổng số <span class="font-semibold text-white">@totalItems</span> bản ghi
            </span>
            
            @if (totalPages > 1)
            {
                <nav class="inline-flex items-center -space-x-px rounded-md shadow-sm" aria-label="Pagination">
                    <a asp-action="Index" asp-route-page="@(currentPage - 1)" asp-route-searchTerm="@searchTerm" 
                       class="relative inline-flex items-center rounded-l-md px-3 py-2 text-sm font-medium border border-gray-700 bg-gray-900 text-gray-400 hover:bg-gray-800 hover:text-white transition-colors @(currentPage == 1 ? "pointer-events-none opacity-40" : "")">
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                    </a>

                    @for (int i = 1; i <= totalPages; i++)
                    {
                        if (i == currentPage)
                        {
                            <span class="relative z-10 inline-flex items-center bg-amber-400 px-4 py-2 text-sm font-semibold text-gray-900 border border-amber-400 focus:z-20">@i</span>
                        }
                        else
                        {
                            <a asp-action="Index" asp-route-page="@i" asp-route-searchTerm="@searchTerm" 
                               class="relative inline-flex items-center border border-gray-700 bg-gray-900 px-4 py-2 text-sm font-medium text-gray-400 hover:bg-gray-800 hover:text-white transition-colors">@i</a>
                        }
                    }

                    <a asp-action="Index" asp-route-page="@(currentPage + 1)" asp-route-searchTerm="@searchTerm" 
                       class="relative inline-flex items-center rounded-r-md px-3 py-2 text-sm font-medium border border-gray-700 bg-gray-900 text-gray-400 hover:bg-gray-800 hover:text-white transition-colors @(currentPage == totalPages ? "pointer-events-none opacity-40" : "")">
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    </a>
                </nav>
            }
        </div>
    </div>
</div>