@model IEnumerable<NewsArticle>
@{
    ViewData["Title"] = "Tin tức - ";
}

<section class="bg-gradient-to-br from-blue-950 via-blue-900 to-slate-900 text-white py-16 sm:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl space-y-4">
            <span class="inline-flex items-center gap-2 bg-orange-500/15 text-orange-300 border border-orange-400/30 px-3 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider">
                <i class="far fa-newspaper"></i>
                Tin tức SRC Travel
            </span>
            <h1 class="text-3xl sm:text-5xl font-black tracking-tight leading-tight">Cập nhật thông tin mới nhất từ nhà xe</h1>
            <p class="text-sm sm:text-base text-blue-100 leading-relaxed max-w-2xl">
                Theo dõi ưu đãi, thông báo lịch chạy, tuyến mới và các thông tin dịch vụ để chuyến đi của bạn luôn chủ động hơn.
            </p>
        </div>
    </div>
</section>

<section class="py-14 bg-slate-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-8">
            <div>
                <h2 class="text-2xl sm:text-3xl font-extrabold text-blue-900 uppercase tracking-tight">Danh sách tin tức</h2>
                <div class="h-1 w-20 bg-orange-500 mt-3 rounded"></div>
            </div>
            <a asp-controller="Home" asp-action="Index" asp-fragment="news" class="text-sm font-bold text-blue-700 hover:text-blue-900 inline-flex items-center gap-2">
                <i class="fas fa-arrow-left"></i> Quay lại trang chủ
            </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            @foreach (var article in Model)
            {
                <article class="bg-white rounded-2xl overflow-hidden border border-slate-200 shadow-sm hover:shadow-xl transition-all duration-300 group flex flex-col">
                    <a asp-controller="News" asp-action="Details" asp-route-id="@article.Slug" class="block h-56 overflow-hidden bg-slate-200">
                        <img src="@article.ImageUrl" alt="@article.Title" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                    </a>
                    <div class="p-5 flex flex-col flex-1">
                        <div class="flex items-center justify-between gap-3 mb-3">
                            <span class="text-[11px] font-extrabold uppercase tracking-wider text-orange-600 bg-orange-50 border border-orange-100 px-2.5 py-1 rounded-full">@article.Category</span>
                            <span class="text-xs text-slate-500"><i class="far fa-clock mr-1"></i>@article.ReadingMinutes phút đọc</span>
                        </div>
                        <h3 class="text-lg font-extrabold text-slate-900 leading-snug mb-2 group-hover:text-blue-700 transition-colors">
                            <a asp-controller="News" asp-action="Details" asp-route-id="@article.Slug">@article.Title</a>
                        </h3>
                        <p class="text-sm text-slate-600 leading-relaxed line-clamp-3 flex-1">@article.Summary</p>
                        <div class="mt-5 pt-4 border-t border-slate-100 flex items-center justify-between">
                            <span class="text-xs font-semibold text-slate-500"><i class="far fa-calendar-alt mr-1"></i>@article.PublishedAt.ToString("dd/MM/yyyy")</span>
                            <a asp-controller="News" asp-action="Details" asp-route-id="@article.Slug" class="text-sm font-bold text-blue-700 hover:text-orange-600 inline-flex items-center gap-1">
                                Xem chi tiết <i class="fas fa-angle-right"></i>
                            </a>
                        </div>
                    </div>
                </article>
            }
        </div>
    </div>
</section>
