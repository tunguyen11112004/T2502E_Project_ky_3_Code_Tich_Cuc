@model IEnumerable<Bus_ticket.Models.News>
@{
    ViewData["Title"] = "Quản lý tin tức";
    // Tùy theo layout gốc của nhóm bạn, thường là dòng dưới này, nếu lỗi thì xóa nó đi nhé
    Layout = "~/Views/Shared/_Layout.cshtml"; 
}

<div class="p-4 sm:p-6 lg:p-8">
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="p-4 mb-4 text-sm text-green-400 rounded-lg bg-gray-800 border border-green-800" role="alert">
            @TempData["SuccessMessage"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="p-4 mb-4 text-sm text-red-400 rounded-lg bg-gray-800 border border-red-800" role="alert">
            @TempData["ErrorMessage"]
        </div>
    }

    <div class="bg-gray-800 relative shadow-md sm:rounded-lg overflow-hidden border border-gray-700">
        
        <div class="flex flex-col md:flex-row items-center justify-between space-y-3 md:space-y-0 md:space-x-4 p-4 border-b border-gray-700">
            <div class="w-full md:w-1/2">
                <h2 class="text-2xl font-bold text-white">Quản Lý Tin Tức Hệ Thống</h2>
                <p class="text-gray-400 text-sm mt-1">Cập nhật và lấy tin tức tự động từ các nguồn báo chí xe khách.</p>
            </div>
            <div class="w-full md:w-auto flex flex-col md:flex-row space-y-2 md:space-y-0 items-stretch md:items-center justify-end md:space-x-3 flex-shrink-0">
                <form asp-action="CrawlNews" asp-controller="Admin" method="post">
                    <button type="submit" class="flex items-center justify-center text-white bg-blue-600 hover:bg-blue-700 focus:ring-4 focus:ring-blue-800 font-medium rounded-lg text-sm px-4 py-2 focus:outline-none">
                        Quét & Đồng Bộ Tin Mới
                    </button>
                </form>
            </div>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-sm text-left text-gray-400">
                <thead class="text-xs text-gray-400 uppercase bg-gray-700 border-b border-gray-600">
                    <tr>
                        <th scope="col" class="px-4 py-3">Hình ảnh</th>
                        <th scope="col" class="px-4 py-3">Tiêu đề bài viết</th>
                        <th scope="col" class="px-4 py-3">Nguồn</th>
                        <th scope="col" class="px-4 py-3">Ngày quét</th>
                        <th scope="col" class="px-4 py-3 text-center">Trạng thái</th>
                        <th scope="col" class="px-4 py-3 text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr class="border-b border-gray-700 hover:bg-gray-600 transition-colors">
                                <td class="px-4 py-3">
                                    <img src="@item.ThumbnailUrl" alt="thumb" class="w-20 h-12 object-cover rounded shadow-sm" />
                                </td>
                                <td class="px-4 py-3 font-medium text-white max-w-xs truncate" title="@item.Title">
                                    @item.Title
                                </td>
                                <td class="px-4 py-3">
                                    <span class="bg-gray-700 text-gray-300 text-xs font-medium px-2 py-1 rounded border border-gray-500">
                                        @item.SourceSite
                                    </span>
                                </td>
                                <td class="px-4 py-3">
                                    @item.CreatedDate.ToString("dd/MM/yyyy HH:mm")
                                </td>
                                
                                <td class="px-4 py-3 text-center">
                                    @if (item.Status == 1)
                                    {
                                        <span class="px-2 py-1 text-xs font-semibold text-green-300 bg-green-900 rounded-full">
                                            Đã duyệt
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="px-2 py-1 text-xs font-semibold text-yellow-300 bg-yellow-900 rounded-full">
                                            Chờ duyệt
                                        </span>
                                    }
                                </td>

                                <td class="px-4 py-3">
                                    <div class="flex items-center justify-center space-x-2">
                                        
                                        @if (item.Status != 1)
                                        {
                                            <form asp-action="ApproveNews" asp-controller="Admin" method="post" class="m-0">
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <button type="submit" class="px-3 py-1.5 text-xs font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700 focus:ring-2 focus:outline-none focus:ring-blue-800 transition">
                                                    Duyệt
                                                </button>
                                            </form>
                                        }

                                        <form asp-action="DeleteNews" asp-controller="Admin" method="post" class="m-0" onsubmit="return confirm('Bạn có chắc chắn muốn xóa vĩnh viễn bài viết này không?');">
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="px-3 py-1.5 text-xs font-medium text-white bg-red-600 rounded-lg hover:bg-red-700 focus:ring-2 focus:outline-none focus:ring-red-800 transition">
                                                Xóa
                                            </button>
                                        </form>

                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="px-4 py-8 text-center text-gray-400">
                                Chưa có dữ liệu tin tức nào trong hệ thống.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>