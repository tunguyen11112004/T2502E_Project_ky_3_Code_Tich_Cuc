@model IEnumerable<Bus_ticket.Models.News>
@{
    ViewData["Title"] = "Quản lý Tin Tức Hệ Thống";
    Layout = "_AdminLayout";
}

<div class="p-6 bg-gray-900 min-h-screen text-white">
    <div class="max-w-7xl mx-auto">
        <div class="flex justify-between items-center mb-6">
            <h1 class="text-2xl font-bold flex items-center gap-2">
                📝 Quản Lý Tin Tức Hệ Thống
            </h1>
            <a asp-action="CrawlNews" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-semibold transition-all">
                ❄️ Quét Link nguồn mới
            </a>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="bg-green-950 border border-green-800 text-green-300 p-4 rounded-lg mb-6 text-sm">
                @TempData["SuccessMessage"]
            </div>
        }

        <div class="bg-gray-800 rounded-xl overflow-hidden border border-gray-700 shadow-xl">
            <table class="w-full text-left text-sm border-collapse">
                <thead>
                    <tr class="bg-gray-750 text-gray-300 uppercase text-xs font-bold border-b border-gray-700">
                        <th class="p-4 w-28">Hình ảnh</th>
                        <th class="p-4">Tiêu đề bài viết</th>
                        <th class="p-4 w-36">Nguồn</th>
                        <th class="p-4 w-36">Trạng thái</th>
                        <th class="p-4 w-44">Ngày tạo</th>
                        <th class="p-4 w-32 text-center">Hành động</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-700/50">
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr class="hover:bg-gray-750/30 transition-all">
                                <td class="p-4">
                                    <img src="@item.ThumbnailUrl" class="w-20 h-12 object-cover rounded border border-gray-700" alt="Thumbnail" />
                                </td>
                                <td class="p-4 font-semibold text-gray-100">
                                    @item.Title
                                </td>
                                <td class="p-4">
                                    <span class="bg-gray-700 text-gray-300 text-xs px-2.5 py-1 rounded-md">
                                        @item.SourceSite
                                    </span>
                                </td>
                                <td class="p-4">
                                    @if (item.IsApproved)
                                    {
                                        <span class="bg-green-950 text-green-400 border border-green-900 text-xs px-2.5 py-1 rounded-full font-medium">
                                            Đã Xuất Bản
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="bg-yellow-950 text-yellow-400 border border-yellow-900 text-xs px-2.5 py-1 rounded-full font-medium">
                                            Bản Nháp (Chờ Duyệt)
                                        </span>
                                    }
                                </td>
                                <td class="p-4 text-gray-400 text-xs">
                                    @item.CreatedDate.ToString("dd/MM/yyyy HH:mm")
                                </td>
                                <td class="p-4 text-center">
                                    <a asp-action="EditNews" asp-route-id="@item.Id" 
                                       class="bg-blue-600 hover:bg-blue-700 text-white text-xs font-semibold px-3 py-1.5 rounded-lg transition-all inline-flex items-center gap-1">
                                        Biên tập ✏️
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="p-8 text-center text-gray-500">
                                Chưa có liên kết hoặc tin tức nháp nào được lưu trong hệ thống.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>