@{
    ViewData["Title"] = "Thêm Xe";
}

<div class="p-6 bg-white rounded-lg shadow sm:p-8">
    <h2 class="text-xl font-semibold mb-4">Thêm xe mới</h2>

    <form action="/Admin/Products/Create" method="post" enctype="multipart/form-data" class="space-y-4">
        <div>
            <label class="block text-sm font-medium text-gray-700">Biển số xe</label>
            <input name="LicensePlate" type="text" required class="mt-1 block w-full rounded-md border-gray-300 shadow-sm" />
        </div>

        <div>
            <label class="block text-sm font-medium text-gray-700">Lớp xe</label>
            <select name="VehicleClass" required class="mt-1 block w-full rounded-md border-gray-300 shadow-sm">
                <option value="Express">Express</option>
                <option value="Luxury">Luxury</option>
                <option value="VolvoNonAC">Volvo Non A/C</option>
                <option value="VolvoAC">Volvo A/C</option>
            </select>
        </div>

        <div>
            <label class="block text-sm font-medium text-gray-700">Tuyến đường</label>
            <input name="Route" type="text" required class="mt-1 block w-full rounded-md border-gray-300 shadow-sm" />
        </div>

        <div>
            <label class="block text-sm font-medium text-gray-700">Quãng đường (km)</label>
            <input name="DistanceKm" type="number" min="0" step="0.1" required class="mt-1 block w-full rounded-md border-gray-300 shadow-sm" />
        </div>

        <div>
            <label class="block text-sm font-medium text-gray-700">Ảnh xe</label>
            <input id="imageInput" name="ImageFile" type="file" accept="image/*" class="mt-1" />
        </div>

        <div id="previewContainer" class="mt-2">
            <p class="text-sm text-gray-500">Xem trước ảnh:</p>
            <img id="imagePreview" src="/admin-assets/images/illustrations/500.svg" alt="Preview" class="mt-2 max-h-40 rounded border" style="display:none;" />
        </div>

        <div>
            <button type="submit" class="inline-flex items-center px-4 py-2 bg-blue-600 text-white rounded">Lưu</button>
            <a href="/Admin" class="ml-2 text-sm text-gray-600">Hủy</a>
        </div>
    </form>
</div>

<script>
document.getElementById('imageInput').addEventListener('change', function (event) {
    const file = event.target.files && event.target.files[0];
    const preview = document.getElementById('imagePreview');
    if (!file) {
        preview.style.display = 'none';
        preview.src = '';
        return;
    }

    const reader = new FileReader();
    reader.onload = function (e) {
        preview.src = e.target.result;
        preview.style.display = 'block';
    };
    reader.readAsDataURL(file);
});
</script>
