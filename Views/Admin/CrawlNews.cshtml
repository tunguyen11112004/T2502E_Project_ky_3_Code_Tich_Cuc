@model List<string>
@{
    Layout = "_AdminLayout"; // Đảm bảo sử dụng đúng layout admin của nhà xe
    ViewData["Title"] = "Crawl Tin Tức Động";
}

<div class="p-6 space-y-6">
    <div class="flex justify-between items-center">
        <h2 class="text-2xl font-bold text-gray-800">🕸️ Quét Link nguồn bằng CSS Selector</h2>
        <a asp-action="ManageNews" class="text-sm bg-gray-500 hover:bg-gray-600 text-white px-4 py-2 rounded-lg transition">
            Quay lại quản lý tin
        </a>
    </div>

    <!-- Thông báo trạng thái -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="p-4 mb-4 text-sm text-green-700 bg-green-100 rounded-lg">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["InfoMessage"] != null)
    {
        <div class="p-4 mb-4 text-sm text-yellow-700 bg-yellow-100 rounded-lg">@TempData["InfoMessage"]</div>
    }

    <!-- Form cấu hình URL & Selector -->
    <div class="bg-white p-6 rounded-xl shadow-sm border border-gray-200">
        <form asp-controller="Admin" asp-action="CrawlNews" method="POST" class="space-y-4">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">URL Nguồn (Ví dụ: https://vietnamnet.vn/the-thao)</label>
                    <input type="url" name="sourceUrl" value="@ViewBag.SourceUrl" required
                           placeholder="Dán link trang danh mục cần lấy tin..." 
                           class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-1">CSS Selector (Ví dụ: .vnn-title a)</label>
                    <input type="text" name="cssSelector" value="@ViewBag.CssSelector" required
                           placeholder="Nhập QuerySelector..." 
                           class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 font-mono" />
                </div>
            </div>
            <div class="flex justify-end">
                <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-medium px-6 py-2.5 rounded-lg transition flex items-center gap-2">
                    Bắt đầu Quét Link 🚀
                </button>
            </div>
        </form>
    </div>

    <!-- Danh sách link thu thập được -->
    @if (Model != null && Model.Any())
    {
        <div class="bg-white rounded-xl shadow border border-gray-200 overflow-hidden">
            <div class="p-4 border-b border-gray-200 bg-gray-50 flex justify-between items-center">
                <h3 class="text-lg font-semibold text-gray-700">Đã quét được @Model.Count link con</h3>
            </div>
            <div class="max-h-[500px] overflow-y-auto">
                <table class="w-full text-left border-collapse text-sm">
                    <thead>
                        <tr class="bg-gray-100 text-xs font-semibold text-gray-500 uppercase border-b">
                            <th class="p-4 w-12">STT</th>
                            <th class="p-4">Link con chi tiết</th>
                            <th class="p-4 text-right">Gửi Queue</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-200">
                        @for (int i = 0; i < Model.Count; i++)
                        {
                            <tr class="hover:bg-gray-50">
                                <td class="p-4 text-gray-400 font-mono">@(i + 1)</td>
                                <td class="p-4 text-blue-600 font-mono text-xs break-all">
                                    <a href="@Model[i]" target="_blank" class="hover:underline">@Model[i]</a>
                                </td>
                                <td class="p-4 text-right">
                                    <form asp-controller="Admin" asp-action="PushToQueue" method="POST" class="inline">
                                        <input type="hidden" name="targetUrl" value="@Model[i]" />
                                        <button type="submit" class="bg-green-500 hover:bg-green-600 text-white text-xs px-3 py-1.5 rounded transition">
                                            Push Queue
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>