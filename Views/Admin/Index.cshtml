@{
    // Ép trang này phải sử dụng bộ khung Layout Admin mà chúng ta vừa ráp
    Layout = "_AdminLayout";
    ViewData["Title"] = "Admin Dashboard";
}

<div class="p-6 bg-white rounded-lg shadow dark:bg-gray-850">
    <h1 class="text-2xl font-bold text-gray-950 dark:text-white mb-2">Xin chào Admin!</h1>
    <p class="text-gray-600 dark:text-gray-400">Bạn đã cắt và tích hợp giao diện tĩnh Flowbite sang .NET Core MVC thành công.</p>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mt-6">
        <div class="p-4 bg-blue-500 text-white rounded-lg">
            <h3 class="font-semibold">Tổng doanh thu</h3>
            <p class="text-2xl font-bold mt-1">$15,240</p>
        </div>
        <div class="p-4 bg-green-500 text-white rounded-lg">
            <h3 class="font-semibold">Vé đã bán</h3>
            <p class="text-2xl font-bold mt-1">420 Vé</p>
        </div>
        <div class="p-4 bg-purple-500 text-white rounded-lg">
            <h3 class="font-semibold">Chuyến xe đang chạy</h3>
            <p class="text-2xl font-bold mt-1">12 Chuyến</p>
        </div>
    </div>
</div>