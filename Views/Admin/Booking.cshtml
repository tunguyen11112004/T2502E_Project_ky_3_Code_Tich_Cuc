@* /// <summary>
    /// Giao diện Booking & Enquiry biến đổi từ trang Products cũ.
    /// Giữ nguyên cấu trúc lưới bảng dữ liệu để chuẩn bị cho việc đổ danh sách chuyến xe sau này.
    /// </summary>
*@

@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản Lý Chuyến Xe & Đặt Vé";
}

<style>
    .src-bg-main { background-color: #0d235c; }
    .src-seat { width: 40px; height: 40px; border-radius: 6px; display: flex; align-items: center; justify-content: center; font-weight: bold; cursor: pointer; }
    .src-seat-available { background-color: #10b981; color: white; }
    .src-seat-occupied { background-color: #cbd5e1; color: #94a3b8; cursor: not-allowed; }
</style>

<div class="p-4 bg-gray-50 min-h-screen dark:bg-gray-900" style="font-family: 'Inter', sans-serif;">
    
    <div class="src-bg-main text-center py-6 px-4 rounded-xl mb-6 text-white shadow">
        <h1 class="text-2xl lg:text-4xl font-black mb-2">SRC Travel Agencies</h1>
        <p class="text-xs lg:text-sm opacity-75 max-w-xl mx-auto">Connecting destinations, elevating journeys.</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        
        <div id="employee-table-wrapper" class="lg:col-span-2 space-y-6">
            <div class="bg-white p-4 rounded-xl shadow border border-gray-200 dark:bg-gray-800">
                
                <div class="flex flex-col md:flex-row justify-between items-center gap-4 mb-4">
                    <div class="w-full md:w-72">
                        <input type="text" id="txtSearchTrip" class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg block w-full p-2" placeholder="Tìm kiếm chuyến xe...">
                    </div>
                    <button type="button" onclick="handleMockupSearch()" class="text-white src-bg-main hover:bg-blue-900 font-bold rounded-lg text-sm px-4 py-2 shadow w-full md:w-auto">
                        + Add new booking (Search)
                    </button>
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full text-sm text-left text-gray-500 dark:text-gray-400">
                        <thead class="text-xs text-gray-700 uppercase bg-gray-50 dark:bg-gray-700 dark:text-gray-400">
                            <tr>
                                <th class="p-3">Mã Chuyến</th>
                                <th class="p-3">Tuyến Đường</th>
                                <th class="p-3">Giờ Đi</th>
                                <th class="p-3">Giá Vé</th>
                                <th class="p-3">Trạng Thái Ghế</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr class="border-b dark:border-gray-700 hover:bg-gray-50">
                                <td class="p-3 font-bold text-gray-900 dark:text-white">#SRC1945</td>
                                <td class="p-3">Hà Nội → Quảng Ninh</td>
                                <td class="p-3">08:00 AM</td>
                                <td class="p-3 font-semibold text-slate-800">550.000đ</td>
                                <td class="p-3"><span class="bg-green-100 text-green-800 text-xs font-semibold px-2 py-0.5 rounded">Còn 12 ghế trống</span></td>
                            </tr>
                            <tr class="border-b dark:border-gray-700 hover:bg-gray-50">
                                <td class="p-3 font-bold text-gray-900 dark:text-white">#SRC6232</td>
                                <td class="p-3">Hà Nội → Hải Phòng</td>
                                <td class="p-3">10:30 AM</td>
                                <td class="p-3 font-semibold text-slate-800">250.000đ</td>
                                <td class="p-3"><span class="bg-red-100 text-red-800 text-xs font-semibold px-2 py-0.5 rounded">Hết ghế</span></td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div id="seat-matrix-wrapper" class="hidden mt-6 bg-gray-50 p-4 rounded-lg border dark:bg-gray-700">
                    <h4 class="text-sm font-bold text-green-600 mb-2">Sơ Đồ Ma Trận Ghế Trống Thực Tế</h4>
                    <div class="bg-white p-4 rounded-xl max-w-xs mx-auto border space-y-3 dark:bg-gray-800">
                        <div class="flex justify-center gap-3">
                            <div class="src-seat src-seat-available" onclick="selectSeatCode('A1')">A1</div>
                            <div class="src-seat src-seat-available" onclick="selectSeatCode('A2')">A2</div>
                            <div class="src-seat src-seat-occupied">A3</div>
                        </div>
                        <div class="flex justify-center gap-3">
                            <div class="src-seat src-seat-occupied">B1</div>
                            <div class="src-seat src-seat-available" onclick="selectSeatCode('B2')">B2</div>
                            <div class="src-seat src-seat-available" onclick="selectSeatCode('B3')">B3</div>
                        </div>
                    </div>
                </div>

            </div>
        </div>

        <div class="lg:col-span-1">
            <div class="bg-white p-4 rounded-xl shadow border border-gray-200 dark:bg-gray-800 space-y-4">
                <h3 class="text-sm font-bold text-gray-700 uppercase dark:text-white border-b pb-2">Booking Form</h3>
                <form id="formBooking" class="space-y-3">
                    <div>
                        <label class="block mb-1 text-xs font-medium text-gray-900 dark:text-white">Tên hành khách</label>
                        <input type="text" id="txtPassengerName" class="bg-gray-50 border border-gray-300 text-gray-900 text-xs rounded-lg block w-full p-2" placeholder="Họ tên khách">
                    </div>
                    <div>
                        <label class="block mb-1 text-xs font-medium text-gray-900 dark:text-white">
                            Nhập tuổi hành khách
                        </label>

                        <input type="number"
                               id="txtPassengerAge"
                               min="0"
                               max="120"
                               oninput="calculateTicketLive()"
                               onchange="calculateTicketLive()"
                               class="bg-gray-50 border border-gray-300 text-gray-900 text-xs rounded-lg block w-full p-2"
                               placeholder="Ví dụ: 25">

                        <p id="lblDiscountNote" class="mt-1 text-[11px] text-gray-500">
                            Nhập tuổi để hệ thống tự tính ưu đãi.
                        </p>
                    </div>
                    <div>
                        <label class="block mb-1 text-xs font-medium text-gray-900 dark:text-white">
                            Lớp xe
                        </label>

                        <select id="ddlBusClass"
                                onchange="calculateTicketLive()"
                                class="bg-gray-50 border border-gray-300 text-gray-900 text-xs rounded-lg block w-full p-2">
                            <option value="Express Seat" data-price="250000">
                                Express Seat - 250.000đ
                            </option>

                            <option value="Luxury Sleeper" data-price="500000" selected>
                                Luxury Sleeper - 500.000đ
                            </option>

                            <option value="Limousine Sleeper" data-price="750000">
                                Limousine Sleeper - 750.000đ
                            </option>

                            <option value="VIP Cabin" data-price="950000">
                                VIP Cabin - 950.000đ
                            </option>
                        </select>
                    </div>
                    <div>
                        <label class="block mb-1 text-xs font-medium text-gray-900 dark:text-white">Tuyến đường</label>
                        <input type="text" id="txtRoute" class="bg-gray-100 border text-gray-400 text-xs rounded-lg block w-full p-2" readonly value="Hà Nội → Quảng Ninh">
                    </div>
                    <div>
                        <label class="block mb-1 text-xs font-medium text-gray-900 dark:text-white">Số ghế chọn</label>
                        <input type="text" id="txtSeatNum" class="bg-yellow-50 border border-yellow-300 text-yellow-900 font-bold text-xs rounded-lg block w-full p-2" readonly placeholder="Chọn trên sơ đồ">
                    </div>

                    <div class="flex gap-2 justify-end pt-2">
                        <button type="button" onclick="createNewTicketMockup()" class="bg-green-600 hover:bg-green-700 text-white font-bold text-xs rounded-lg px-3 py-2 shadow">New</button>
                        <button type="button" onclick="alert('Đã cập nhật!')" class="bg-yellow-500 hover:bg-yellow-600 text-white text-xs rounded-lg px-3 py-2 shadow">Update</button>
                        <button type="button" onclick="clearBookingData()" class="bg-red-600 hover:bg-red-700 text-white text-xs rounded-lg px-3 py-2 shadow">Cancel</button>
                    </div>
                </form>
            </div> 
            <div id="liveTicketPreview"
     class="mt-4 bg-white rounded-xl shadow border-2 border-dashed border-blue-900 p-4 dark:bg-gray-800">

    <div class="text-center border-b pb-2 mb-3">
        <h4 class="text-base font-black text-gray-800 dark:text-white">
            PHÔI VÉ IN - LIVE PREVIEW
        </h4>
        <p class="text-xs text-blue-700 font-bold">
            Tự động cập nhật khi đổi tuổi hoặc lớp xe
        </p>
    </div>

    <div class="space-y-1.5 text-xs text-gray-700 dark:text-gray-200">
        <div class="flex justify-between">
            <span>Khách hàng:</span>
            <span id="previewPassenger" class="font-bold">-</span>
        </div>

        <div class="flex justify-between">
            <span>Lớp xe:</span>
            <span id="previewBusClass" class="font-bold">Luxury Sleeper</span>
        </div>

        <div class="flex justify-between">
            <span>Tuyến đường:</span>
            <span id="previewRouteInfo" class="font-bold">Hà Nội → Quảng Ninh</span>
        </div>

        <div class="flex justify-between">
            <span>Ghế chọn:</span>
            <span id="previewSeatInfo" class="bg-green-600 text-white text-xs px-1.5 py-0.5 rounded font-bold">-</span>
        </div>

        <hr class="border-dashed my-2">

        <div class="flex justify-between text-gray-500">
            <span>Giá vé gốc theo lớp xe:</span>
            <span id="previewOriginalFare">500.000 VND</span>
        </div>

        <div class="flex justify-between text-green-600">
            <span>Khấu trừ/giảm giá:</span>
            <span id="previewDiscountAmount">0 VND</span>
        </div>

        <div class="flex justify-between text-gray-500">
            <span>Tiền vé sau giảm:</span>
            <span id="previewBaseFare">500.000 VND</span>
        </div>

        <div class="flex justify-between text-gray-500">
            <span>Thuế GTGT (VAT 10%):</span>
            <span id="previewVatAmount">50.000 VND</span>
        </div>

        <div class="flex justify-between pt-2 border-t font-extrabold text-sm text-gray-900 dark:text-white">
            <span>TỔNG TIỀN:</span>
            <span id="previewFinalAmount" class="text-red-600">550.000 VND</span>
        </div>
    </div>
</div>
        </div>

    </div>
</div>

<div id="invoiceTicketModal" tabindex="-1" aria-hidden="true" class="fixed top-0 left-0 right-0 z-50 hidden w-full p-4 overflow-x-hidden overflow-y-auto md:inset-0 h-full bg-gray-900/50 flex items-center justify-center animate__animated animate__fadeIn">
    <div class="relative w-full max-w-sm max-h-full bg-white rounded-xl shadow-2xl border-2 border-dashed border-blue-900 p-4">
        <div class="text-center border-b pb-2 mb-3">
            <h4 class="text-base font-black text-gray-800">PHÔI VÉ ĐIỆN TỬ - SRC TRAVEL</h4>
            <p class="text-xs text-blue-700 font-bold">Mã Vé: SRC-2026</p>
        </div>
        <div class="space-y-1.5 text-xs">
            <div class="flex justify-between"><span>Khách hàng:</span> <span id="lblPassenger" class="font-bold">-</span></div>
            <div class="flex justify-between"><span>Tuyến đường:</span> <span id="lblRouteInfo" class="font-bold">-</span></div>
            <div class="flex justify-between"><span>Ghế chọn:</span> <span id="lblSeatInfo" class="bg-green-600 text-white text-xs px-1.5 py-0.5 rounded font-bold">-</span></div>
            <hr class="border-dashed my-2">
            <div class="flex justify-between">
                <span>Lớp xe:</span>
                <span id="lblBusClass" class="font-bold">Luxury Sleeper</span>
            </div>

            <div class="flex justify-between text-gray-500">
                <span>Giá vé gốc theo lớp xe:</span>
                <span id="lblOriginalFare">500.000 VND</span>
            </div>

            <div class="flex justify-between text-green-600">
                <span>Khấu trừ/giảm giá:</span>
                <span id="lblDiscountAmount">0 VND</span>
            </div>

            <div class="flex justify-between text-gray-500">
                <span>Tiền vé sau giảm:</span>
                <span id="lblBaseFare">500.000 VND</span>
            </div>

            <div class="flex justify-between text-gray-500">
                <span>Thuế GTGT (VAT 10%):</span>
                <span id="lblVatAmount">50.000 VND</span>
            </div>

            <div class="flex justify-between pt-2 border-t font-extrabold text-sm text-gray-900">
                <span>TỔNG TIỀN:</span>
                <span id="lblFinalAmount" class="text-red-600">550.000 VND</span>
            </div>
        </div>
        <div class="mt-4 text-center">
            <button type="button" onclick="closeInvoiceModal()" class="text-white src-bg-main hover:bg-blue-900 font-bold text-xs rounded-lg px-6 py-2 shadow">Đóng</button>
        </div>
    </div>
</div>

<script>
    const VAT_RATE = 0.10;

    function getElement(id) {
        return document.getElementById(id);
    }

    function getPassengerAge() {
        const rawAge = getElement("txtPassengerAge")?.value;
        const age = Number(rawAge);

        if (rawAge === "" || Number.isNaN(age) || age < 0) {
            return null;
        }

        return age;
    }

    function getSelectedBusClassInfo() {
        const busClassSelect = getElement("ddlBusClass");
        const selectedOption = busClassSelect.options[busClassSelect.selectedIndex];

        return {
            name: busClassSelect.value,
            originalFare: Number(selectedOption.dataset.price || 0)
        };
    }

    function formatCurrency(amount) {
        const safeAmount = Number.isFinite(amount) ? amount : 0;

        return new Intl.NumberFormat("vi-VN", {
            style: "currency",
            currency: "VND",
            maximumFractionDigits: 0
        }).format(Math.round(safeAmount)).replace("₫", "VND");
    }

    function calculateTicketLive() {
        const age = getPassengerAge();
        const busClassInfo = getSelectedBusClassInfo();
        const originalFare = busClassInfo.originalFare;

        let discountRate = 0;
        let discountNote = "Không áp dụng ưu đãi theo tuổi.";

        if (age === null) {
            discountRate = 0;
            discountNote = "Nhập tuổi hợp lệ để hệ thống tự tính ưu đãi.";
        } else if (age < 5) {
            discountRate = 1;
            discountNote = "Trẻ em dưới 5 tuổi: miễn phí 100% tiền vé.";
        } else if (age >= 5 && age <= 12) {
            discountRate = 0.5;
            discountNote = "Hành khách từ 5 đến 12 tuổi: giảm 50% tiền vé.";
        } else if (age > 50) {
            discountRate = 0.3;
            discountNote = "Người cao tuổi trên 50 tuổi: giảm 30% tiền vé.";
        }

        const discountAmount = originalFare * discountRate;
        const baseFareAfterDiscount = Math.max(originalFare - discountAmount, 0);
        const vatAmount = baseFareAfterDiscount * VAT_RATE;
        const finalAmount = baseFareAfterDiscount + vatAmount;

        const passengerName = getElement("txtPassengerName")?.value?.trim() || "-";
        const route = getElement("txtRoute")?.value || "-";
        const seat = getElement("txtSeatNum")?.value || "-";

        const renderMap = {
            previewPassenger: passengerName,
            previewBusClass: busClassInfo.name,
            previewRouteInfo: route,
            previewSeatInfo: seat,
            previewOriginalFare: formatCurrency(originalFare),
            previewDiscountAmount: "-" + formatCurrency(discountAmount),
            previewBaseFare: formatCurrency(baseFareAfterDiscount),
            previewVatAmount: formatCurrency(vatAmount),
            previewFinalAmount: formatCurrency(finalAmount),

            lblPassenger: passengerName,
            lblBusClass: busClassInfo.name,
            lblRouteInfo: route,
            lblSeatInfo: seat,
            lblOriginalFare: formatCurrency(originalFare),
            lblDiscountAmount: "-" + formatCurrency(discountAmount),
            lblBaseFare: formatCurrency(baseFareAfterDiscount),
            lblVatAmount: formatCurrency(vatAmount),
            lblFinalAmount: formatCurrency(finalAmount)
        };

        Object.entries(renderMap).forEach(([id, value]) => {
            const element = getElement(id);

            if (element) {
                element.innerText = value;
            }
        });

        const discountNoteElement = getElement("lblDiscountNote");

        if (discountNoteElement) {
            discountNoteElement.innerText = discountNote;
        }

        return {
            age,
            originalFare,
            discountAmount,
            baseFareAfterDiscount,
            vatAmount,
            finalAmount
        };
    }

    function handleMockupSearch() {
        getElement("seat-matrix-wrapper").classList.remove("hidden");
    }

    function selectSeatCode(seatName) {
        getElement("txtSeatNum").value = seatName;
        calculateTicketLive();
    }

    function createNewTicketMockup() {
        const name = getElement("txtPassengerName").value.trim();
        const age = getPassengerAge();
        const seat = getElement("txtSeatNum").value;

        if (!name || age === null || !seat) {
            alert("Vui lòng điền tên, nhập tuổi hợp lệ và chọn ghế!");
            return;
        }

        calculateTicketLive();
        getElement("invoiceTicketModal").classList.remove("hidden");
    }

    function closeInvoiceModal() {
        getElement("invoiceTicketModal").classList.add("hidden");
    }

    function clearBookingData() {
        getElement("formBooking").reset();
        getElement("txtSeatNum").value = "";
        getElement("seat-matrix-wrapper").classList.add("hidden");
        calculateTicketLive();
    }

    document.addEventListener("DOMContentLoaded", function () {
        ["txtPassengerName", "txtPassengerAge", "ddlBusClass"].forEach(function (id) {
            const element = getElement(id);

            if (!element) {
                return;
            }

            element.addEventListener("input", calculateTicketLive);
            element.addEventListener("change", calculateTicketLive);
        });

        calculateTicketLive();
    });
</script>