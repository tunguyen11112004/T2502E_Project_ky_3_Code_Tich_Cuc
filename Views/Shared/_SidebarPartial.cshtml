@using System.Security.Claims

@{
    var fullName = User.Identity?.Name ?? "Unknown User";
    var employeeCode = User.FindFirst("EmployeeCode")?.Value ?? "N/A";
    var role = User.FindFirst(ClaimTypes.Role)?.Value ?? "Unknown";
}

<aside id="sidebar"
       class="fixed top-0 left-0 z-20 flex flex-col flex-shrink-0 hidden w-64 h-full pt-16 font-normal duration-75 lg:flex transition-width"
       aria-label="Sidebar">

    <div class="relative flex flex-col flex-1 min-h-0 pt-0 bg-white border-r border-gray-200 dark:bg-gray-800 dark:border-gray-700">

        <div class="flex flex-col flex-1 pt-5 pb-4 overflow-y-auto">
            <div class="flex-1 px-3 space-y-1 bg-white dark:bg-gray-800">

                <ul class="pb-2 space-y-2">

                    @if (User.IsInRole("Admin"))
                    {
                        <li>
                            <a href="/Admin"
                               class="flex items-center p-2 text-base text-gray-900 rounded-lg hover:bg-gray-100 group dark:text-gray-200 dark:hover:bg-gray-700">
                                <span class="ml-3">Admin Dashboard</span>
                            </a>
                        </li>

                        <li>
                            <a href="#"
                               class="flex items-center p-2 text-base text-gray-900 rounded-lg hover:bg-gray-100 group dark:text-gray-200 dark:hover:bg-gray-700">
                                <span class="ml-3">Manage Employees</span>
                            </a>
                        </li>

                        <li>
                            <a href="#"
                               class="flex items-center p-2 text-base text-gray-900 rounded-lg hover:bg-gray-100 group dark:text-gray-200 dark:hover:bg-gray-700">
                                <span class="ml-3">Manage Buses</span>
                            </a>
                        </li>

                        <li>
                            <a href="#"
                               class="flex items-center p-2 text-base text-gray-900 rounded-lg hover:bg-gray-100 group dark:text-gray-200 dark:hover:bg-gray-700">
                                <span class="ml-3">Manage Routes</span>
                            </a>
                        </li>

                        <li>
                            <a href="#"
                               class="flex items-center p-2 text-base text-gray-900 rounded-lg hover:bg-gray-100 group dark:text-gray-200 dark:hover:bg-gray-700">
                                <span class="ml-3">Manage Price List</span>
                            </a>
                        </li>
                    }

                    @if (User.IsInRole("Employee"))
                    {
                        <li>
                            <a href="/Employee"
                               class="flex items-center p-2 text-base text-gray-900 rounded-lg hover:bg-gray-100 group dark:text-gray-200 dark:hover:bg-gray-700">
                                <span class="ml-3">Employee Counter</span>
                            </a>
                        </li>

                        <li>
                            <a href="#"
                               class="flex items-center p-2 text-base text-gray-900 rounded-lg hover:bg-gray-100 group dark:text-gray-200 dark:hover:bg-gray-700">
                                <span class="ml-3">Search Trips</span>
                            </a>
                        </li>

                        <li>
                            <a href="#"
                               class="flex items-center p-2 text-base text-gray-900 rounded-lg hover:bg-gray-100 group dark:text-gray-200 dark:hover:bg-gray-700">
                                <span class="ml-3">Book Ticket</span>
                            </a>
                        </li>

                        <li>
                            <a href="#"
                               class="flex items-center p-2 text-base text-gray-900 rounded-lg hover:bg-gray-100 group dark:text-gray-200 dark:hover:bg-gray-700">
                                <span class="ml-3">Price List</span>
                            </a>
                        </li>

                        <li>
                            <a href="#"
                               class="flex items-center p-2 text-base text-gray-900 rounded-lg hover:bg-gray-100 group dark:text-gray-200 dark:hover:bg-gray-700">
                                <span class="ml-3">Policy</span>
                            </a>
                        </li>
                    }

                </ul>
            </div>
        </div>

        <div class="p-4 border-t border-gray-200 dark:border-gray-700">
            <div class="text-sm font-semibold text-gray-900 dark:text-white">
                @fullName
            </div>

            <div class="text-xs text-gray-500 dark:text-gray-400">
                Code: @employeeCode
            </div>

            <div class="text-xs text-gray-500 dark:text-gray-400">
                Role: @role
            </div>

            <form asp-controller="Account" asp-action="Logout" method="post" class="mt-3">
                <button type="submit"
                        class="w-full px-3 py-2 text-sm font-medium text-white bg-red-600 rounded-lg hover:bg-red-700">
                    Logout
                </button>
            </form>
        </div>

    </div>
</aside>