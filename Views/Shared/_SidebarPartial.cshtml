@using System.Security.Claims
@using Bus_ticket.Services
@inject SidebarPermissionService SidebarPermissionService

@{
    var fullName = User.Identity?.Name ?? "Unknown User";
    var employeeCode = User.FindFirst("EmployeeCode")?.Value ?? "N/A";
    var role = User.FindFirst(ClaimTypes.Role)?.Value ?? "Unknown";

    var permissionNames = await SidebarPermissionService.GetCurrentUserPermissionNamesAsync(User);

    var isAdmin = User.IsInRole("Admin");
    var isEmployee = User.IsInRole("Employee");

    var canViewBooking = SidebarPermissionService.HasPermission(
        permissionNames,
        "Booking",
        "Book",
        "Ticket",
        "/Booking"
    );

    var canViewUsers = SidebarPermissionService.HasPermission(
        permissionNames,
        "User",
        "Users",
        "Employee",
        "Employees",
        "/Admin/Users"
    );

    var canViewDynamicRoles = SidebarPermissionService.HasPermission(
        permissionNames,
        "DynamicRole",
        "DynamicRoles",
        "Role",
        "Roles",
        "/DynamicRoles"
    );

    var canViewPermissions = SidebarPermissionService.HasPermission(
        permissionNames,
        "Permission",
        "Permissions",
        "/Permissions"
    );
    var canViewBranches = SidebarPermissionService.HasPermission(
        permissionNames,
        "Branch",
        "Branches",
        "/Branches"
    );
    var canViewBusClasses = SidebarPermissionService.HasPermission(
        permissionNames,
        "BusClass",
        "BusClasses",
        "/BusClasses"
    );

    var canManageBuses = SidebarPermissionService.HasPermission(
        permissionNames,
        "Bus",
        "Buses",
        "/Admin/Buses"
    );

    var canManageRoutes = SidebarPermissionService.HasPermission(
        permissionNames,
        "Route",
        "Routes",
        "BusRoute",
        "/Admin/Routes"
    );

    var canManagePrices = SidebarPermissionService.HasPermission(
        permissionNames,
        "Price",
        "Prices",
        "PriceList",
        "Fare",
        "/Admin/Prices"
    );

    var canViewEmployeeCounter = SidebarPermissionService.HasPermission(
        permissionNames,
        "Employee",
        "Counter",
        "Booking",
        "Trip",
        "Ticket"
    );

    var canSearchTrips = SidebarPermissionService.HasPermission(
        permissionNames,
        "Trip",
        "Route",
        "Search",
        "BusRoute"
    );

    var canBookTicket = SidebarPermissionService.HasPermission(
        permissionNames,
        "Booking",
        "Book",
        "Ticket"
    );

    var canViewPriceList = SidebarPermissionService.HasPermission(
        permissionNames,
        "Price",
        "Fare",
        "PriceList"
    );

    var canViewPolicy = SidebarPermissionService.HasPermission(
        permissionNames,
        "Policy",
        "Refund",
        "Cancel",
        "Cancellation"
    );
    var canViewRouteRevenue = isAdmin
                              || SidebarPermissionService.HasPermission(
                                  permissionNames,
                                  "Dashboard",
                                  "Report",
                                  "Revenue",
                                  "Route",
                                  "RouteRevenue",
                                  "/Dashboard/RouteRevenue"
                              );
    var showDashboardMenu = isAdmin || canViewRouteRevenue;

    var showCrudMenu = canViewBooking
                       || canViewBranches
                       || canViewBusClasses
                       || canManagePrices
                       || canViewUsers
                       || canViewDynamicRoles
                       || canViewPermissions;

    var showSrcAdminFlow = canViewUsers
                           || canManageBuses
                           || canManageRoutes
                           || canManagePrices;

    var showEmployeeMenu = canViewEmployeeCounter
                           || canSearchTrips
                           || canBookTicket
                           || canViewPriceList
                           || canViewPolicy;

    var menuItemClass = "nav-link-item flex items-center p-2 text-base text-gray-900 rounded-lg hover:bg-gray-100 group dark:text-gray-200 dark:hover:bg-gray-700 transition-all duration-150";
    var subMenuItemClass = "nav-link-item flex items-center p-2 text-base text-gray-900 transition duration-75 rounded-lg pl-11 group hover:bg-gray-100 dark:text-gray-200 dark:hover:bg-gray-700 transition-all duration-150";
    var buttonMenuClass = "flex items-center w-full p-2 text-base text-gray-900 transition duration-75 rounded-lg group hover:bg-gray-100 dark:text-gray-200 dark:hover:bg-gray-700";
}

<aside id="sidebar"
       class="fixed top-0 left-0 z-20 flex flex-col flex-shrink-0 hidden w-64 h-full pt-16 font-normal duration-75 lg:flex transition-width"
       aria-label="Sidebar">

    <div class="relative flex flex-col flex-1 min-h-0 pt-0 bg-white border-r border-gray-200 dark:bg-gray-800 dark:border-gray-700">

        <div class="flex flex-col flex-1 pt-5 pb-4 overflow-y-auto [&::-webkit-scrollbar]:hidden [-ms-overflow-style:none] [scrollbar-width:none]">
            <div class="flex-1 px-3 space-y-1 bg-white divide-y divide-gray-200 dark:bg-white/5 dark:divide-gray-700">

                <ul class="pb-2 space-y-2">

                    <li>
                        <form action="#" method="GET" class="lg:hidden">
                            <label for="mobile-search" class="sr-only">Search</label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none">
                                    <svg class="w-5 h-5 text-gray-500" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M8 4a4 4 0 100 8 4 4 0 000-8zM2 8a6 6 0 1110.89 3.476l4.817 4.817a1 1 0 01-1.414 1.414l-4.816-4.816A6 6 0 012 8z" clip-rule="evenodd"></path>
                                    </svg>
                                </div>
                                <input type="text"
                                       name="search"
                                       id="mobile-search"
                                       class="bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-500 focus:border-primary-500 block w-full pl-10 p-2.5 dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-gray-200"
                                       placeholder="Search">
                            </div>
                        </form>
                    </li>
                    @if (showDashboardMenu)
                    {
                        <li>
                            <button type="button" class="@buttonMenuClass" aria-controls="dropdown-dashboard" data-collapse-toggle="dropdown-dashboard">
                                <span class="w-6 text-center text-gray-500">📊</span>
                                <span class="flex-1 ml-3 text-left whitespace-nowrap" sidebar-toggle-item>Dashboard</span>
                                <svg sidebar-toggle-item class="w-6 h-6 transition-transform duration-150" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"></path>
                                </svg>
                            </button>

                            <ul id="dropdown-dashboard" class="hidden py-2 space-y-2">
                                @if (isAdmin)
                                {
                                    <li>
                                        <a href="/Admin" class="@subMenuItemClass">
                                            Overview
                                        </a>
                                    </li>
                                }

                                @if (canViewRouteRevenue)
                                {
                                    <li>
                                        <a asp-controller="Dashboard"
                                           asp-action="RouteRevenue"
                                           class="@subMenuItemClass">
                                            Route Revenue
                                        </a>
                                    </li>
                                }
                                
                                @if (canViewRouteRevenue)
                                {
                                    <li>
                                        <a asp-controller="Dashboard"
                                           asp-action="SeatAnalytics"
                                           class="@subMenuItemClass">
                                            SeatAnalytics
                                        </a>
                                    </li>
                                }
                            </ul>
                        </li>
                    }
                    @* ================= SYSTEM ADMIN ONLY ================= *@
                    @if (isAdmin)
                    {
                        <li>
                            <button type="button" class="@buttonMenuClass" aria-controls="dropdown-layouts" data-collapse-toggle="dropdown-layouts">
                                <span class="w-6 text-center text-gray-500">🧩</span>
                                <span class="flex-1 ml-3 text-left whitespace-nowrap" sidebar-toggle-item>Layouts</span>
                                <svg sidebar-toggle-item class="w-6 h-6 transition-transform duration-150" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"></path>
                                </svg>
                            </button>
                            <ul id="dropdown-layouts" class="hidden py-2 space-y-2">
                                <li><a href="/Admin/Layouts/Stacked" class="@subMenuItemClass">Stacked</a></li>
                                <li><a href="/Admin/Layouts/Sidebar" class="@subMenuItemClass">Sidebar</a></li>
                            </ul>
                        </li>
                    }

                    @* ================= CRUD - PERMISSION BASED ================= *@
                    @if (showCrudMenu)
                    {
                        <li>
                            <button type="button" class="@buttonMenuClass" aria-controls="dropdown-crud" data-collapse-toggle="dropdown-crud">
                                <span class="w-6 text-center text-gray-500">🗂️</span>
                                <span class="flex-1 ml-3 text-left whitespace-nowrap" sidebar-toggle-item>CRUD</span>
                                <svg sidebar-toggle-item class="w-6 h-6 transition-transform duration-150" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"></path>
                                </svg>
                            </button>

                            <ul id="dropdown-crud" class="hidden py-2 space-y-2">
                                @if (canViewBooking)
                                {
                                    <li>
                                        <a asp-controller="Booking" asp-action="Index" class="@subMenuItemClass">
                                            Booking
                                        </a>
                                    </li>
                                }

                                @if (canViewBranches)
                                {
                                    <li>
                                        <a asp-controller="Branches" asp-action="Index" class="@subMenuItemClass">
                                            Branches
                                        </a>
                                    </li>
                                }

                                @if (canViewBusClasses)
                                {
                                    <li>
                                        <a asp-controller="BusClasses" asp-action="Index" class="@subMenuItemClass">
                                            BusClasses
                                        </a>
                                    </li>
                                }

                                @if (canManagePrices)
                                {
                                    <li>
                                        <a asp-controller="Admin" asp-action="PriceConfig" class="@subMenuItemClass">
                                            Pricing
                                        </a>
                                    </li>
                                }

                                @if (canViewUsers)
                                {
                                    <li>
                                        <a href="/Admin/Users" class="@subMenuItemClass">
                                            Users
                                        </a>
                                    </li>
                                }

                                @if (canViewDynamicRoles)
                                {
                                    <li>
                                        <a asp-controller="DynamicRoles" asp-action="Index" class="@subMenuItemClass">
                                            DynamicRoles
                                        </a>
                                    </li>
                                }

                                @if (canViewPermissions)
                                {
                                    <li>
                                        <a asp-controller="Permissions" asp-action="Index" class="@subMenuItemClass">
                                            Permissions
                                        </a>
                                    </li>
                                }
                            </ul>
                        </li>
                    }

                    @* ================= SYSTEM ADMIN ONLY ================= *@
                    @if (isAdmin)
                    {
                        <li>
                            <a href="/Admin/Settings" class="@menuItemClass">
                                <span class="w-6 text-center text-gray-500">⚙️</span>
                                <span class="ml-3" sidebar-toggle-item>Settings</span>
                            </a>
                        </li>

                        <li>
                            <button type="button" class="@buttonMenuClass" aria-controls="dropdown-pages" data-collapse-toggle="dropdown-pages">
                                <span class="w-6 text-center text-gray-500">📄</span>
                                <span class="flex-1 ml-3 text-left whitespace-nowrap" sidebar-toggle-item>Pages</span>
                                <svg sidebar-toggle-item class="w-6 h-6 transition-transform duration-150" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"></path>
                                </svg>
                            </button>
                            <ul id="dropdown-pages" class="hidden py-2 space-y-2">
                                <li><a href="/Admin/Pages/Pricing" class="@subMenuItemClass">Pricing</a></li>
                                <li><a href="/Admin/Pages/Maintenance" class="@subMenuItemClass">Maintenance</a></li>
                                <li><a href="/Admin/Pages/404" class="@subMenuItemClass">404 not found</a></li>
                                <li><a href="/Admin/Pages/500" class="@subMenuItemClass">500 server error</a></li>
                            </ul>
                        </li>

                        <li>
                            <button type="button" class="@buttonMenuClass" aria-controls="dropdown-auth" data-collapse-toggle="dropdown-auth">
                                <span class="w-6 text-center text-gray-500">🔐</span>
                                <span class="flex-1 ml-3 text-left whitespace-nowrap" sidebar-toggle-item>Authentication</span>
                                <svg sidebar-toggle-item class="w-6 h-6 transition-transform duration-150" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"></path>
                                </svg>
                            </button>
                            <ul id="dropdown-auth" class="hidden py-2 space-y-2">
                                <li><a href="/Account/Login" class="@subMenuItemClass">Sign in</a></li>
                                <li><a href="/Account/Register" class="@subMenuItemClass">Sign up</a></li>
                                <li><a href="/Account/ForgotPassword" class="@subMenuItemClass">Forgot password</a></li>
                                <li><a href="/Account/ResetPassword" class="@subMenuItemClass">Reset password</a></li>
                            </ul>
                        </li>

                        <li>
                            <button type="button" class="@buttonMenuClass" aria-controls="dropdown-playground" data-collapse-toggle="dropdown-playground">
                                <span class="w-6 text-center text-gray-500">🧪</span>
                                <span class="flex-1 ml-3 text-left whitespace-nowrap" sidebar-toggle-item>Playground</span>
                                <svg sidebar-toggle-item class="w-6 h-6 transition-transform duration-150" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"></path>
                                </svg>
                            </button>
                            <ul id="dropdown-playground" class="hidden py-2 space-y-2">
                                <li><a href="/Admin/Playground/Stacked" class="@subMenuItemClass">Stacked</a></li>
                                <li><a href="/Admin/Playground/Sidebar" class="@subMenuItemClass">Sidebar</a></li>
                            </ul>
                        </li>
                    }

                    @* ================= SRC ADMIN FLOW - PERMISSION BASED ================= *@
                    @if (showSrcAdminFlow)
                    {
                        <li>
                            <button type="button" class="@buttonMenuClass" aria-controls="dropdown-src-admin" data-collapse-toggle="dropdown-src-admin">
                                <span class="w-6 text-center text-gray-500">🚌</span>
                                <span class="flex-1 ml-3 text-left whitespace-nowrap" sidebar-toggle-item>SRC Admin Flow</span>
                                <svg sidebar-toggle-item class="w-6 h-6 transition-transform duration-150" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"></path>
                                </svg>
                            </button>

                            <ul id="dropdown-src-admin" class="hidden py-2 space-y-2">
                                @if (canViewUsers)
                                {
                                    <li>
                                        <a href="/Admin/Users" class="@subMenuItemClass">
                                            Manage Employees
                                        </a>
                                    </li>
                                }
                  
                                @if (canViewBranches)
                                {
                                    <li>
                                        <a asp-controller="Branches" asp-action="Index" class="@subMenuItemClass">
                                            Manage Branches
                                        </a>
                                    </li>
                                }

                                @if (canManageBuses)
                                {
                                    <li>
                                        <a href="/Admin/Buses" class="@subMenuItemClass">
                                            Manage Buses
                                        </a>
                                    </li>
                                }

                                @if (canManageRoutes)
                                {
                                    <li>
                                        <a href="/Admin/Routes" class="@subMenuItemClass">
                                            Manage Routes
                                        </a>
                                    </li>
                                }

                                @if (canManagePrices)
                                {
                                    <li>
                                        <a href="/Admin/Prices" class="@subMenuItemClass">
                                            Manage Price List
                                        </a>
                                    </li>
                                }
                            </ul>
                        </li>
                    }

                    @* ================= EMPLOYEE FLOW - PERMISSION BASED ================= *@
                    @if (showEmployeeMenu)
                    {
                        if (canViewEmployeeCounter)
                        {
                            <li>
                                <a href="/Employee" class="@menuItemClass">
                                    <span class="w-6 text-center text-gray-500">🎫</span>
                                    <span class="ml-3">Employee Counter</span>
                                </a>
                            </li>
                        }

                        if (canSearchTrips)
                        {
                            <li>
                                <a href="/Employee/SearchTrips" class="@menuItemClass">
                                    <span class="w-6 text-center text-gray-500">🔎</span>
                                    <span class="ml-3">Search Trips</span>
                                </a>
                            </li>
                        }

                        if (canBookTicket)
                        {
                            <li>
                                <a href="/Employee/BookTicket" class="@menuItemClass">
                                    <span class="w-6 text-center text-gray-500">🧾</span>
                                    <span class="ml-3">Book Ticket</span>
                                </a>
                            </li>
                        }

                        if (canViewPriceList)
                        {
                            <li>
                                <a href="/Employee/PriceList" class="@menuItemClass">
                                    <span class="w-6 text-center text-gray-500">💰</span>
                                    <span class="ml-3">Price List</span>
                                </a>
                            </li>
                        }

                        if (canViewPolicy)
                        {
                            <li>
                                <a href="/Employee/Policy" class="@menuItemClass">
                                    <span class="w-6 text-center text-gray-500">📌</span>
                                    <span class="ml-3">Policy</span>
                                </a>
                            </li>
                        }
                    }

                    @if (!isAdmin && !canViewRouteRevenue && !showCrudMenu && !showSrcAdminFlow && !showEmployeeMenu)
                    {
                        <li>
                            <div class="p-3 text-sm text-gray-500 rounded-lg bg-gray-50 dark:bg-gray-700 dark:text-gray-300">
                                No menu assigned. Please contact admin.
                            </div>
                        </li>
                    }
                </ul>

                @* ================= RESOURCE LINKS - SYSTEM ADMIN ONLY ================= *@
                @if (isAdmin)
                {
                    <div class="pt-2 space-y-2">
                        <a href="https://flowbite.com/application-ui/demo/" target="_blank" class="@menuItemClass">
                            <span class="w-6 text-center text-gray-500">🚀</span>
                            <span class="ml-3">View Pro Version</span>
                        </a>
                        <a href="https://github.com/themesberg/flowbite-admin-dashboard" target="_blank" class="@menuItemClass">
                            <span class="w-6 text-center text-gray-500">💻</span>
                            <span class="ml-3">GitHub Repository</span>
                        </a>
                        <a href="https://flowbite.com/docs/getting-started/introduction/" target="_blank" class="@menuItemClass">
                            <span class="w-6 text-center text-gray-500">📚</span>
                            <span class="ml-3">Flowbite Docs</span>
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="fixed inset-0 z-10 hidden bg-gray-900/50 dark:bg-gray-900/90" id="sidebarBackdrop"></div>
</aside>

