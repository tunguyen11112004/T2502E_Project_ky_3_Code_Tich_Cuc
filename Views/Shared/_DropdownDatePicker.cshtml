@{
string targetType = ViewBag.TargetType ?? "Global";
string fromDate = ViewBag.CurrentFromDate ?? "";
string toDate = ViewBag.CurrentToDate ?? "";
string dropdownId = "dropdown_" + targetType;
string pickerId = "picker_" + targetType;
}

<div class="relative inline-block text-left">
    <button type="button" onclick="toggleDatePickerDropdown('@dropdownId')"
            class="inline-flex items-center gap-2 px-4 py-2 text-sm font-semibold text-white bg-gray-800 hover:bg-gray-700 rounded-lg border border-gray-700 shadow-sm transition-colors">
        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
        <span>Bộ lọc thời gian</span>
        <svg class="w-3 h-3 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
    </button>

    <div id="@dropdownId" class="hidden absolute right-0 mt-2 w-72 bg-[#1e1e24] border border-gray-700 rounded-xl shadow-2xl p-4 z-50 animate-fade-in">
        <div class="space-y-3">
            <label class="block text-xs font-semibold text-gray-400 uppercase tracking-wider">Chọn khoảng ngày dữ liệu:</label>

            <div class="relative">
                <input type="text" id="@pickerId"
                       class="w-full bg-gray-900 border border-gray-700 text-white text-xs rounded-lg p-2.5 cursor-pointer focus:ring-amber-500 focus:border-amber-500 font-semibold"
                       placeholder="Từ ngày - Đến ngày...">
            </div>
        </div>
    </div>
</div>

<script>
    (function() {
        // Khởi tạo Litepicker cho ô input nằm trong dropdown này
        const pickerElement = document.getElementById('@pickerId');
        if (!pickerElement) return;

        const picker = new Litepicker({
            element: pickerElement,
            singleMode: false,
            numberOfMonths: 2,
            numberOfColumns: 2,
            inlineMode: false,
            setup: (picker) => {
                picker.on('selected', (date1, date2) => {
                    const start = date1.format('YYYY-MM-DD');
                    const end = date2.format('YYYY-MM-DD');

                    // Bắn sự kiện thay đổi ngày lên hàm cha quản lý ở file Index.cshtml
                    if (typeof onGlobalDateChanged === "function") {
                        onGlobalDateChanged(start, end);
                    }
                });
            }
        });

        // Gán ngày hiện tại nếu có dữ liệu sẵn
        const start = '@fromDate';
        const end = '@toDate';
        if (start && end) {
            picker.setDateRange(new Date(start), new Date(end));
        }
    })();

    // Hàm đóng mở Dropdown bộ lọc
    if (typeof toggleDatePickerDropdown !== "function") {
        window.toggleDatePickerDropdown = function(id) {
            const el = document.getElementById(id);
            if (el) {
                el.classList.toggle('hidden');
            }
        }

        // Click ra ngoài thì tự động đóng menu dropdown lại cho tinh tế
        document.addEventListener('click', function(e) {
            if (!e.target.closest('.relative')) {
                document.querySelectorAll('[id^="dropdown_"]').forEach(el => el.classList.add('hidden'));
            }
        });
    }
</script>