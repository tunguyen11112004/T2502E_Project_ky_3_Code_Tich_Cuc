@* /// <summary>
    /// Trang chủ Dashboard điều hướng nội bộ dành cho SRC Travel Agencies.
    /// Giữ nguyên cấu trúc giao diện mẫu nhưng tối ưu hóa theo nghiệp vụ quản lý.
    /// </summary>
*@

@{
    Layout = "_Layout";
    ViewData["Title"] = "Dashboard Điều Hành - SRC Travel Agencies";

    // Quy tắc 3 & 4.1: Đặt tên biến bool có tiền tố rõ ràng, mỗi câu lệnh trên một dòng riêng biệt.
    bool isAdmin = true;
    bool isStaff = true;
}

<main class="pb-10">
    <section>
        <div class="mx-auto container px-4">
            <div class="hero min-h-[40vh] lg:min-h-[50vh] rounded-[20px]" style="background-image: url('./client-assets/images/banner.png'); background-position: center; background-size: cover;">
                <div class="hero-overlay rounded-[20px] bg-opacity-60"></div>
                <div class="hero-content text-center text-neutral-content p-4">
                    <div class="w-full lg:w-3/5 mx-auto">
                        <h1 class="mb-5 text-3xl lg:text-5xl font-bold text-white">SRC Travel Agencies <br> <span class="text-2xl lg:text-3xl font-light">Hệ Thống Điều Hành Nội Bộ</span> </h1>
                        <p class="mb-5 text-priColor">Chào mừng nhân viên trở lại hệ thống quản lý. Vui lòng sử dụng các lối tắt bên dưới để xử lý nghiệp vụ bán vé và quản lý đội xe nhanh chóng.</p>
                    </div>
                </div>
            </div>

            <div class="myCard lg:flex justify-evenly lg:mt-[-56px] relative z-10 p-4 lg:p-0 gap-4">
                <div class="card card-side shadow-xl border-b-4 border-secColor px-7 bg-white w-full lg:w-[48%] py-4">
                    <figure><img src="~/client-assets/images/stoppage.png" alt="Buses" class="w-16 h-16"/></figure>
                    <div class="card-body p-4 justify-center">
                        <h2 class="card-title font-bold lg:text-4xl text-3xl text-slate-800">42 Xe</h2>
                        <p class="text-sm text-gray-500 m-0">Tổng số xe hiện có (Mã định danh 5 số: e.g. 29001)</p>
                    </div>
                </div>
                
                <div class="card card-side shadow-xl border-b-4 border-secColor px-7 bg-white w-full lg:w-[48%] py-4">
                    <figure><img src="~/client-assets/images/people.png" alt="Employees" class="w-16 h-16"/></figure>
                    <div class="card-body p-4 justify-center">
                        <h2 class="card-title font-bold lg:text-4xl text-3xl text-slate-800">150 Nhân Viên</h2>
                        <p class="text-sm text-gray-500 m-0">Đang vận hành hệ thống (Mã nhân viên 6 số: e.g. 100204)</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="mt-12">
        <div class="mx-auto container px-4">
            
            @if (isStaff)
            {
                <div class="mb-8">
                    <h2 class="text-2xl font-bold mb-6 text-white border-b border-gray-700 pb-2">🎯 Nghiệp Vụ Quầy Vé & Tra Cứu</h2>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        
                        <a href="@Url.Action("Enquiry", "Booking")" class="flex items-center justify-between bg-white rounded-xl p-5 shadow-lg border-2 border-transparent hover:border-secColor transition-all group">
                            <div class="flex items-center gap-4">
                                <span class="text-4xl">🔍</span>
                                <div>
                                    <h3 class="text-xl font-bold text-slate-800 group-hover:text-secColor transition-colors">Tra Cứu Chuyến Đi</h3>
                                    <p class="text-gray-500 text-sm mt-1">Enquiry Form - Kiểm tra lịch trình, giá vé và số ghế trống.</p>
                                </div>
                            </div>
                            <span class="text-2xl text-gray-400 group-hover:translate-x-2 transition-transform">→</span>
                        </a>

                        <a href="@Url.Action("Create", "Booking")" class="flex items-center justify-between bg-white rounded-xl p-5 shadow-lg border-2 border-transparent hover:border-secColor transition-all group">
                            <div class="flex items-center gap-4">
                                <span class="text-4xl">🎟️</span>
                                <div>
                                    <h3 class="text-xl font-bold text-slate-800 group-hover:text-secColor transition-colors">Đặt Vé Xe Khách</h3>
                                    <p class="text-gray-500 text-sm mt-1">Booking Form - Giữ chỗ và xuất vé trực tiếp cho khách hàng.</p>
                                </div>
                            </div>
                            <span class="text-2xl text-gray-400 group-hover:translate-x-2 transition-transform">→</span>
                        </a>

                    </div>
                </div>
            }

            @if (isAdmin)
            {
                <div class="mt-10">
                    <h2 class="text-2xl font-bold mb-6 text-red-400 border-b border-gray-700 pb-2">🔒 Quản Trị Hệ Thống (Admin Only)</h2>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        
                        <a href="@Url.Action("Index", "Buses")" class="flex items-center justify-between bg-slate-800 rounded-xl p-5 shadow-lg border-2 border-transparent hover:border-red-400 transition-all group">
                            <div class="flex items-center gap-4">
                                <span class="text-4xl">🚌</span>
                                <div>
                                    <h3 class="text-xl font-bold text-white group-hover:text-red-400 transition-colors">Quản Lý Đội Xe</h3>
                                    <p class="text-gray-400 text-sm mt-1">Buses Management - Cập nhật trạng thái xe và quản lý đầu xe.</p>
                                </div>
                            </div>
                            <span class="text-2xl text-gray-400 group-hover:translate-x-2 transition-transform">→</span>
                        </a>

                        <a href="@Url.Action("Index", "Employees")" class="flex items-center justify-between bg-slate-800 rounded-xl p-5 shadow-lg border-2 border-transparent hover:border-red-400 transition-all group">
                            <div class="flex items-center gap-4">
                                <span class="text-4xl">👔</span>
                                <div>
                                    <h3 class="text-xl font-bold text-white group-hover:text-red-400 transition-colors">Quản Lý Nhân Viên</h3>
                                    <p class="text-gray-400 text-sm mt-1">Employees Management - Quản lý hồ sơ tài xế và phân quyền nhân viên.</p>
                                </div>
                            </div>
                            <span class="text-2xl text-gray-400 group-hover:translate-x-2 transition-transform">→</span>
                        </a>

                    </div>
                </div>
            }

        </div>
    </section>
</main>