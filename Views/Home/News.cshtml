@model IEnumerable<Bus_ticket.Models.News>

@{
    ViewData["Title"] = "Tin Tức Chuyên Ngành Xe Khách";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

<div class="bg-gray-50/50 py-12 min-h-screen">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <div class="text-center max-w-3xl mx-auto mb-16">
            <span class="text-xs font-bold text-blue-600 uppercase tracking-widest bg-blue-50 px-3 py-1.5 rounded-full">Góc Tin Tức</span>
            <h1 class="text-3xl sm:text-4xl font-black text-gray-900 mt-4 mb-4 tracking-tight">Cẩm Nang Di Chuyển & Tin Tức Xe</h1>
            <p class="text-base text-gray-500 leading-relaxed">Tổng hợp những thông tin mới nhất về hạ tầng giao thông, lịch trình di chuyển và các xu hướng vận tải hành khách chất lượng cao.</p>
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                @foreach (var item in Model)
                {
                    <div class="bg-white rounded-2xl border border-gray-100 flex flex-col justify-between overflow-hidden shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
                        
                        <div class="relative h-52 w-full overflow-hidden bg-gray-100">
                            <img src="@item.ThumbnailUrl" 
                                 class="w-full h-full object-cover transform group-hover:scale-105 transition-transform duration-500" 
                                 alt="@item.Title"
                                 onerror="this.src='https://images.unsplash.com/photo-1544620347-c4fd4a3d5957?q=80&w=600&auto=format&fit=crop';"/>
                            
                            <span class="absolute bottom-3 left-3 bg-gray-900/80 backdrop-blur-sm text-white text-[11px] font-semibold px-2.5 py-1 rounded-md shadow-sm">
                                <i class="fa-solid fa-feather mr-1 text-blue-400"></i> @item.SourceSite
                            </span>
                        </div>

                        <div class="p-6 flex-1 flex flex-col justify-between">
                            <div>
                                <div class="flex items-center gap-2 text-xs text-gray-400 mb-3 font-medium">
                                    <i class="far fa-calendar-alt text-gray-300"></i> 
                                    <span>@item.CreatedDate.ToString("dd/MM/yyyy")</span>
                                </div>
                                
                                <h3 class="font-extrabold text-gray-900 text-lg mb-2.5 line-clamp-2 group-hover:text-blue-600 transition-colors duration-200">
                                    <a asp-controller="Home" asp-action="NewsDetail" asp-route-id="@item.Id">
                                        @item.Title
                                    </a>
                                </h3>
                                
                                <p class="text-gray-500 text-sm leading-relaxed line-clamp-3 mb-6">
                                    @(string.IsNullOrEmpty(item.Description) || item.Description.Contains("Trang chủ") ? "Nhấp vào liên kết phía dưới để cập nhật thêm các nội dung và thông báo chi tiết liên quan đến bài viết này từ nhà xe Sơn Hải..." : item.Description)
                                </p>
                            </div>

                            <div class="pt-4 border-t border-gray-50 flex items-center justify-between">
                                <a asp-controller="Home" asp-action="NewsDetail" asp-route-id="@item.Id" 
                                   class="inline-flex items-center text-xs font-bold text-blue-600 hover:text-blue-700 gap-1.5 group/btn">
                                    Chi tiết bài viết 
                                    <i class="fas fa-arrow-right text-[10px] transform group-hover/btn:translate-x-1 transition-transform"></i>
                                </a>
                                <span class="text-[11px] text-gray-300 font-medium italic">Đọc nhanh 2 phút</span>
                            </div>
                        </div>

                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-24 bg-white rounded-3xl border border-dashed border-gray-200 shadow-sm max-w-xl mx-auto">
                <div class="w-16 h-16 bg-blue-50 text-blue-500 rounded-full flex items-center justify-center mx-auto mb-4 text-2xl">
                    <i class="fa-regular fa-newspaper"></i>
                </div>
                <h3 class="text-gray-900 font-bold text-lg mb-1">Chưa tìm thấy tin tức</h3>
                <p class="text-gray-400 text-sm max-w-xs mx-auto">Vui lòng truy cập trang quản trị Admin và nhấn nút đồng bộ dữ liệu bài viết mới.</p>
            </div>
        }
        
    </div>
</div>