@model List<Bus_ticket.Models.PriceConfigViewModel>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Bảng Giá Xe & Tiện Nghi";
}

<div class="container mx-auto px-4 py-10 max-w-5xl">
    
    <!-- Quy Định Cấu Hình Tính Giá Vé -->
    <div class="bg-blue-50 border-l-4 border-ternaryColor p-6 rounded-r-lg mb-10 shadow-sm">
        <h2 class="text-xl font-bold text-titleColor mb-2 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-ternaryColor" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span data-vi="Quy Định Cấu Hình Tính Giá Vé" data-en="Ticket Pricing Regulations">Quy Định Cấu Hình Tính Giá Vé</span>
        </h2>
        <p class="text-gray-600 leading-relaxed mb-3">
            <span data-vi="Hệ thống tính toán giá vé tự động một cách minh bạch. Mức giá cuối cùng áp dụng cho mỗi lượt đặt vé của hành khách sẽ phụ thuộc trực tiếp vào" 
                  data-en="The system calculates ticket prices automatically and transparently. The final fare applied to each passenger booking depends directly on">
                Hệ thống tính toán giá vé tự động một cách minh bạch. Mức giá cuối cùng áp dụng cho mỗi lượt đặt vé của hành khách sẽ phụ thuộc trực tiếp vào
            </span> 
            <span class="font-semibold text-titleColor" data-vi="3 yếu tố cốt lõi" data-en="3 core factors">3 yếu tố cốt lõi</span> 
            <span data-vi="sau:" data-en="following:">sau:</span>
        </p>
        <ul class="list-disc list-inside space-y-1.5 text-gray-600 pl-2">
            <li>
                <span class="font-medium text-titleColor" data-vi="Loại xe:" data-en="Vehicle Type:">Loại xe:</span> 
                <span data-vi="Mỗi dòng xe có mức giá sàn khác nhau (Tăng dần từ Express đến dòng cao cấp VIP)." data-en="Each vehicle line has a different base rate (Increasing from Express to VIP premium lines).">Mỗi dòng xe có mức giá sàn khác nhau (Tăng dần từ Express đến dòng cao cấp VIP).</span>
            </li>
            <li>
                <span class="font-medium text-titleColor" data-vi="Khoảng cách di chuyển:" data-en="Travel Distance:">Khoảng cách di chuyển:</span> 
                <span data-vi="Tính dựa trên số kilomet thực tế giữa điểm đi và điểm đến." data-en="Calculated based on the actual kilometers between the departure and destination points.">Tính dựa trên số kilomet thực tế giữa điểm đi và điểm đến.</span>
            </li>
            <li>
                <span class="font-medium text-titleColor" data-vi="Độ tuổi hành khách:" data-en="Passenger Age:">Độ tuổi hành khách:</span> 
                <span data-vi="Áp dụng chính sách giảm giá riêng cho Trẻ em và Người cao tuổi." data-en="Separate discount policies apply to Children and Senior citizens.">Áp dụng chính sách giảm giá riêng cho Trẻ em và Người cao tuổi.</span>
            </li>
        </ul>
    </div>

    <!-- Bảng thông tin xe & giá thành -->
    <div class="bg-white rounded-xl shadow-md overflow-hidden border border-gray-100">
        <div class="p-6 border-b border-gray-100 flex justify-between items-center bg-gray-50">
            <div>
                <h3 class="text-lg font-bold text-titleColor" data-vi="Thông Tin Xe & Giá Tham Khảo" data-en="Vehicle Information & Reference Rates">Thông Tin Xe & Giá Tham Khảo</h3>
                <p class="text-xs text-gray-500 mt-1" data-vi="* Giá tính trên khoảng cách tiêu chuẩn dành cho người lớn" data-en="* Price calculated on standard distance for adults">* Giá tính trên khoảng cách tiêu chuẩn dành cho người lớn</p>
            </div>
            <span class="badge badge-success text-white p-3 font-semibold bg-ternaryColor border-none" data-vi="Dữ liệu hệ thống" data-en="System Data">Dữ liệu hệ thống</span>
        </div>
        
        <div class="overflow-x-auto">
            <table class="table w-full text-left border-collapse">
                <thead>
                    <tr class="text-gray-700 bg-gray-100/70 border-b border-gray-200">
                        <th class="p-4 font-bold text-sm" data-vi="Hình Ảnh" data-en="Image">Hình Ảnh</th>
                        <th class="p-4 font-bold text-sm" data-vi="Loại Xe / Sức Chứa" data-en="Vehicle Type / Capacity">Loại Xe / Sức Chứa</th>
                        <th class="p-4 font-bold text-sm" data-vi="Tiện Nghi Đi Kèm" data-en="Amenities Included">Tiện Nghi Đi Kèm</th>
                        <th class="p-4 font-bold text-sm text-right" data-vi="Giá Cơ Bản" data-en="Base Fare">Giá Cơ Bản</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100 text-gray-600">
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            string rowClass = item.IsHot ? "bg-green-50/30 hover:bg-green-50/50" : "hover:bg-gray-50/80";
                            
                            // Tách chuỗi ngôn ngữ "Việt|Anh" thành mảng
                            var nameParts = item.ClassName.Split('|');
                            var typeParts = item.BusType.Split('|');
                            var amenityParts = item.Amenities.Split('|');

                            string nameVi = nameParts[0];
                            string nameEn = nameParts.Length > 1 ? nameParts[1] : nameParts[0];

                            string typeVi = typeParts[0];
                            string enType = typeParts.Length > 1 ? typeParts[1] : typeParts[0];

                            <tr class="@rowClass transition-colors">
                                <td class="p-4 w-32">
                                    <div class="avatar">
                                        <div class="w-24 h-16 rounded-lg overflow-hidden border border-gray-200 shadow-sm">
                                            <img src="@item.ImageUrl" alt="Bus Image" class="object-cover w-full h-full" onerror="this.onerror=null;this.src='/images/default-bus.jpg';" />
                                        </div>
                                    </div>
                                </td>
                                
                                <td class="p-4">
                                    <div class="font-bold text-gray-800 text-base flex items-center gap-2">
                                        <!-- In Tên xe theo 2 thẻ data để Javascript tự dịch -->
                                        <span data-vi="@nameVi" data-en="@nameEn">@nameVi</span>
                                        @if (item.IsHot)
                                        {
                                            <span class="badge badge-error badge-xs text-white">Hot</span>
                                        }
                                    </div>
                                    <div class="text-xs text-gray-500 mt-0.5">
                                        <span data-vi="Sức chứa:" data-en="Capacity:">Sức chứa:</span> 
                                        <span class="font-semibold text-gray-700">@item.TotalSeats</span> 
                                        <span data-vi="chỗ" data-en="seats">chỗ</span> 
                                        (<span data-vi="@typeVi" data-en="@enType">@typeVi</span>)
                                    </div>
                                </td>
                                
                                <td class="p-4">
                                    @if (amenityParts.Length > 0)
                                    {
                                        // Cắt nhỏ từng tiện nghi
                                        var itemsVi = amenityParts[0].Split(',');
                                        var itemsEn = amenityParts.Length > 1 ? amenityParts[1].Split(',') : amenityParts[0].Split(',');

                                        for (int i = 0; i < itemsVi.Length; i++)
                                        {
                                            string amVi = itemsVi[i].Trim();
                                            string amEn = i < itemsEn.Length ? itemsEn[i].Trim() : amVi;

                                            <span class="badge badge-ghost badge-sm mr-1 mb-1 text-gray-600 font-medium" 
                                                  data-vi="@amVi" data-en="@amEn">
                                                @amVi
                                            </span>
                                        }
                                    }
                                </td>
                                
                                <td class="p-4 text-right font-bold @(item.IsHot ? "text-ternaryColor text-lg" : "text-gray-900 text-base")">
                                    @string.Format("{0:N0}", item.BasePrice) đ
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="p-8 text-center text-gray-400 font-medium" 
                                data-vi="Chưa có dữ liệu loại xe nào trong cơ sở dữ liệu." 
                                data-en="No vehicle type data available in the database.">
                                Chưa có dữ liệu loại xe nào trong cơ sở dữ liệu.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>