@{
    ViewData["Title"] = "Liên Hệ - ";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Contact Us - SRC Travel Agencies</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-slate-50 text-slate-800 font-sans">
    
    <section class="bg-white border-b border-slate-200 py-6 px-6">
        <div class="max-w-7xl mx-auto flex justify-center items-center">
            <h1 class="text-2xl font-bold text-blue-900 tracking-tight uppercase"
                data-vi="LIÊN HỆ VỚI CHÚNG TÔI"
                data-en="Contact Us">
                Contact Us
            </h1>
        </div>
    </section>

    <main class="max-w-7xl mx-auto py-12 px-6 grid grid-cols-1 lg:grid-cols-12 gap-10">
        
        <section class="lg:col-span-5 space-y-8">
            <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm">
                <h3 class="text-lg font-bold text-blue-900 mb-4 flex items-center">
                    <i class="fas fa-map-marker-alt text-orange-500 mr-2"></i> 
                    <span data-vi="Hệ thống Chi nhánh & Văn phòng" data-en="Our Branches & Offices">Our Branches & Offices</span>
                </h3>
                <ul class="space-y-4 text-sm leading-relaxed text-slate-600">
                    <li class="border-b border-slate-100 pb-3">
                        <strong class="text-slate-900 block">
                            <i class="fas fa-location-dot mr-1 text-slate-400"></i>
                            <span data-vi="Trụ sở chính Hà Nội:" data-en="Hanoi Head Office:">Hanoi Head Office:</span>
                        </strong>
                        <span data-vi="13 Phố Phan Tây Nhạc, Phường Xuân Phương, Quận Nam Từ Liêm, Thành phố Hà Nội." data-en="13 Phan Tay Nhac Street, Xuan Phuong Ward, Nam Tu Liem District, Hanoi City.">13 Phan Tay Nhac Street, Xuan Phuong Ward, Nam Tu Liem District, Hanoi City.</span>
                    </li>
                    <li class="border-b border-slate-100 pb-3">
                        <strong class="text-slate-900 block">
                            <i class="fas fa-location-dot mr-1 text-slate-400"></i>
                            <span data-vi="Văn phòng TP. Hồ Chí Minh:" data-en="Ho Chi Minh Head Office:">Ho Chi Minh Head Office:</span>
                        </strong>
                        <span data-vi="21 Đường Bạch Đằng, Phường 2, Quận Tân Bình, Thành phố Hồ Chí Minh." data-en="21 Bach Dang Street, Ward 2, Tan Binh District, Ho Chi Minh City.">21 Bach Dang Street, Ward 2, Tan Binh District, Ho Chi Minh City.</span>
                    </li>
                    <li class="border-b border-slate-100 pb-3">
                        <strong class="text-slate-900 block">
                            <i class="fas fa-location-dot mr-1 text-slate-400"></i>
                            <span data-vi="Chi nhánh Đà Nẵng:" data-en="Da Nang Branch:">Da Nang Branch:</span>
                        </strong>
                        <span data-vi="137 Đường Nguyễn Thị Thập, Phường Hòa Minh, Quận Liên Chiểu, Thành phố Đà Nẵng." data-en="137 Nguyen Thi Thap Street, Hoa Minh Ward, Lien Chieu District, Da Nang City.">137 Nguyen Thi Thap Street, Hoa Minh Ward, Lien Chieu District, Da Nang City.</span>
                    </li>
                    <li class="pb-1">
                        <strong class="text-slate-900 block">
                            <i class="fas fa-location-dot mr-1 text-slate-400"></i>
                            <span data-vi="Chi nhánh Quy Nhơn:" data-en="Quy Nhon Branch:">Quy Nhon Branch:</span>
                        </strong>
                        <span data-vi="107A Đường Thanh Niên, Phường Quang Trung, Thành phố Quy Nhơn." data-en="107A Thanh Nien Street, Quang Trung Ward, Quy Nhon City.">107A Thanh Nien Street, Quang Trung Ward, Quy Nhon City.</span>
                    </li>
                </ul>
            </div>
            
            <div class="bg-white p-6 rounded-xl border border-slate-200 shadow-sm">
                <h3 class="text-lg font-bold text-blue-900 mb-4 flex items-center">
                    <i class="fas fa-phone-alt text-green-600 mr-2"></i> 
                    <span data-vi="Kênh Hỗ trợ Trực tuyến" data-en="Communication Channels">Communication Channels</span>
                </h3>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
                    <div class="space-y-2">
                        <span class="font-semibold text-slate-900 block" data-vi="Đường dây nóng:" data-en="Hotlines:">Hotlines:</span>
                        <a href="tel:19001999" class="text-blue-600 block hover:underline"><i class="fas fa-headset mr-1"></i>1900.1999</a>
                        <a href="tel:0906061999" class="text-blue-600 block hover:underline"><i class="fas fa-mobile-alt mr-1"></i>0906061999</a>
                    </div>
                    <div class="space-y-2">
                        <span class="font-semibold text-slate-900 block" data-vi="Hỗ trợ trực tuyến:" data-en="Online Support:">Online Support:</span>
                        <a href="mailto:support@srctravel.com" class="text-blue-600 block hover:underline"><i class="fas fa-envelope mr-1"></i>support@srctravel.com</a>
                        <span class="text-slate-600 block">
                            <i class="fab fa-facebook text-blue-700 mr-1"></i>
                            <a href="https://www.facebook.com/ntd.606" class="text-blue-600 hover:underline" rel="nofollow" target="_blank">Facebook</a>
                        </span>
                    </div>
                </div>
                <div class="mt-4 pt-4 border-t border-slate-100 text-xs text-slate-500">
                    <i class="fas fa-id-card mr-1"></i> <span data-vi="Mã số thuế: 666888999" data-en="Tax Code: 666888999">Tax Code: 666888999</span>
                </div>
            </div>
        </section>

        <section class="lg:col-span-7 bg-white p-8 rounded-xl border border-slate-200 shadow-sm">
            <h2 class="text-xl font-bold text-slate-900 mb-2" data-vi="Gửi Yêu cầu Tư vấn" data-en="Send Us an Enquiry">Send Us an Enquiry</h2>
            <p class="text-sm text-slate-500 mb-6"
               data-vi="Bạn có thắc mắc hoặc phản hồi? Hãy điền thông tin vào mẫu dưới đây, đội ngũ của chúng tôi sẽ liên hệ lại trong vòng 24 giờ."
               data-en="Have questions or feedback? Fill out the form below, and our team will get back to you within 24 hours.">
               Have questions or feedback? Fill out the form below, and our team will get back to you within 24 hours.
            </p>
            
            <form id="enquiryForm" 
                  action="https://docs.google.com/forms/d/e/1FAIpQLSdQvHUWMPCoSvwhvdEuU6n2n3uHEUCOs3OOsl31nYG8JbN5Qg/formResponse" 
                  method="POST" 
                  target="hidden_iframe" 
                  enctype="application/x-www-form-urlencoded" 
                  class="space-y-4">
                
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs font-semibold text-slate-600 uppercase tracking-wider mb-1" data-vi="Họ và Tên *" data-en="Full Name *">Full Name *</label>
                        <input type="text" name="entry.1545679060" required placeholder="John Doe" 
                               class="w-full text-sm px-4 py-2.5 rounded-lg border border-slate-200 focus:outline-none focus:border-blue-500 bg-slate-50/50 transition-colors">
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-slate-600 uppercase tracking-wider mb-1" data-vi="Số điện thoại *" data-en="Phone Number *">Phone Number *</label>
                        <input type="tel" name="entry.291558798" required placeholder="0934xxxxxx" 
                               class="w-full text-sm px-4 py-2.5 rounded-lg border border-slate-200 focus:outline-none focus:border-blue-500 bg-slate-50/50 transition-colors">
                    </div>
                </div>
                
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div>
                        <label class="block text-xs font-semibold text-slate-600 uppercase tracking-wider mb-1" data-vi="Địa chỉ" data-en="Address">Address</label>
                        <input type="text" name="entry.1914429505" placeholder="Hanoi, Vietnam" 
                               class="w-full text-sm px-4 py-2.5 rounded-lg border border-slate-200 focus:outline-none focus:border-blue-500 bg-slate-50/50 transition-colors">
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-slate-600 uppercase tracking-wider mb-1" data-vi="Địa chỉ Email" data-en="Email Address">Email Address</label>
                        <input type="email" name="entry.594246472" placeholder="example@domain.com" 
                               class="w-full text-sm px-4 py-2.5 rounded-lg border border-slate-200 focus:outline-none focus:border-blue-500 bg-slate-50/50 transition-colors">
                    </div>
                </div>
                
                <div>
                    <label class="block text-xs font-semibold text-slate-600 uppercase tracking-wider mb-1" data-vi="Tiêu đề *" data-en="Subject *">Subject *</label>
                    <input type="text" name="entry.791339830" required placeholder="Ticket booking inquiry, Refund issue, etc." 
                           class="w-full text-sm px-4 py-2.5 rounded-lg border border-slate-200 focus:outline-none focus:border-blue-500 bg-slate-50/50 transition-colors">
                </div>
                
                <div>
                    <label class="block text-xs font-semibold text-slate-600 uppercase tracking-wider mb-1" data-vi="Nội dung lời nhắn *" data-en="Message Content *">Message Content *</label>
                    <textarea name="entry.1727653371" rows="4" required placeholder="Please write your detailed request here..." 
                              class="w-full text-sm px-4 py-2.5 rounded-lg border border-slate-200 focus:outline-none focus:border-blue-500 bg-slate-50/50 transition-colors resize-none"></textarea>
                </div>
                
                <div class="flex items-center space-x-3 pt-2">
                    <button type="submit" class="px-6 py-2.5 bg-blue-600 hover:bg-blue-700 text-white font-medium text-sm rounded-lg shadow-sm hover:shadow transition-all">
                        <i class="fas fa-paper-plane mr-1.5"></i> <span data-vi="Gửi Lời Nhắn" data-en="Submit Enquiry">Submit Enquiry</span>
                    </button>
                    <button type="reset" class="px-5 py-2.5 bg-slate-100 hover:bg-slate-200 text-slate-700 font-medium text-sm rounded-lg transition-all" data-vi="Nhập lại" data-en="Reset Form">
                        Reset Form
                    </button>
                </div>
            </form>

            <iframe name="hidden_iframe" id="hidden_iframe" style="display:none;" onload="if(submitted) { alert('Thank you! Your enquiry has been submitted successfully.'); window.location.reload(); }"></iframe>
        </section>
    </main>

    <section class="max-w-7xl mx-auto px-6 pb-12">
        <div class="bg-white p-4 rounded-xl border border-slate-200 shadow-sm h-[400px] overflow-hidden">
            <iframe 
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3723.940292723933!2d105.74492727593672!3d21.035074887556756!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3134e18d7dbbffdff%3A0xd286abeb441ea212!2zMTMgUC4gUGhhbiBUw6F5IE5o4bqhYywgWHXDom4gUGjGsMahbmcsIE5hbSBU4burIExpw6ptLCBIw6AgTuG7mWksIFZp4buHdCBOYW0!5e0!3m2!1svi!2svn!4v1718200000000!5m2!1svi!2svn" 
                class="w-full h-full border-0" 
                allowfullscreen="" 
                loading="lazy" 
                referrerpolicy="no-referrer-when-downgrade">
            </iframe>
        </div>
    </section>

    <script type="text/javascript">
        var submitted = false;
        document.getElementById('enquiryForm').addEventListener('submit', function() {
            submitted = true;
        });
    </script>
</body>
</html>