@{
    ViewData["Title"] = "Employee Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="p-4 sm:ml-64">
    <div class="p-4 mt-14">

        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">
            Employee Dashboard
        </h1>

        <p class="mt-2 text-gray-600 dark:text-gray-400">
            Only Employee users can access this page.
        </p>

        <button type="submit">
            Logout
        </button>
        <div class="p-4 bg-[#111827] text-gray-100 min-h-screen antialiased mt-6 rounded-xl">
            <div
                class="w-full bg-gradient-to-r from-blue-900 to-indigo-950 p-6 rounded-xl text-center shadow-lg border border-blue-800/40 mb-6">
                <h1 class="text-2xl md:text-3xl font-extrabold text-white tracking-wide">SRC Travel Agencies</h1>
                <p class="text-gray-300 text-xs mt-1 uppercase tracking-widest">Connecting destinations, elevating
                    journeys.</p>
            </div>

            <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">

                <div class="xl:col-span-2 bg-[#1f2937] border border-gray-700/60 rounded-xl p-5 shadow-xl">
                    <div class="flex justify-between items-center border-b border-gray-700 pb-3 mb-4">
                        <h2 class="text-md font-bold uppercase tracking-wider text-gray-200">🔍 Tìm kiếm chuyến xe</h2>
                        <button type="button"
                                class="text-xs bg-blue-600 hover:bg-blue-700 text-white font-semibold py-1.5 px-3 rounded-lg transition">
                            + Add new booking (Search)
                        </button>
                    </div>

                    <form id="employee-search-form" class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label class="block mb-1.5 text-xs font-semibold text-gray-400 uppercase">Điểm đi</label>
                            <input type="text" placeholder="Ví dụ: Hà Nội"
                                   class="bg-[#111827] border border-gray-600 text-white text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5">
                        </div>
                        <div>
                            <label class="block mb-1.5 text-xs font-semibold text-gray-400 uppercase">Điểm đến</label>
                            <input type="text" placeholder="Ví dụ: Quảng Ninh"
                                   class="bg-[#111827] border border-gray-600 text-white text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5">
                        </div>
                        <div>
                            <label class="block mb-1.5 text-xs font-semibold text-gray-400 uppercase">Ngày khởi
                                hành</label>
                            <input type="date"
                                   class="bg-[#111827] border border-gray-600 text-white text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5">
                        </div>
                        <div>
                            <label class="block mb-1.5 text-xs font-semibold text-gray-400 uppercase">Lớp xe</label>
                            <select
                                class="bg-[#111827] border border-gray-600 text-gray-300 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5">
                                <option value="">-- Tất cả lớp xe --</option>
                                <option value="vip">Limousine VIP</option>
                                <option value="bed">Giường nằm cao cấp</option>
                            </select>
                        </div>
                    </form>

                    <div class="mt-6 overflow-x-auto">
                        <table class="w-full text-sm text-left text-gray-400">
                            <thead class="text-xs uppercase bg-[#111827] text-gray-400 border-b border-gray-700">
                            <tr>
                                <th class="px-4 py-3">Mã Chuyến</th>
                                <th class="px-4 py-3">Tuyến Đường</th>
                                <th class="px-4 py-3">Giờ Đi</th>
                                <th class="px-4 py-3">Trạng Thái</th>
                            </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-700">
                            <tr class="bg-[#1f2937] hover:bg-gray-800/60 transition">
                                <td class="px-4 py-3 font-bold text-white">#SRC1945</td>
                                <td class="px-4 py-3">Hà Nội → Quảng Ninh</td>
                                <td class="px-4 py-3 text-blue-400 font-medium">08:00 AM</td>
                                <td class="px-4 py-3"><span
                                        class="bg-green-900/40 text-green-400 text-xs font-medium px-2.5 py-0.5 rounded-full border border-green-800">Còn 12 ghế trống</span>
                                </td>
                            </tr>
                            <tr class="bg-[#1f2937] hover:bg-gray-800/60 transition">
                                <td class="px-4 py-3 font-bold text-white">#SRC6232</td>
                                <td class="px-4 py-3">Hà Nội → Hải Phòng</td>
                                <td class="px-4 py-3 text-blue-400 font-medium">10:30 AM</td>
                                <td class="px-4 py-3"><span
                                        class="bg-red-900/40 text-red-400 text-xs font-medium px-2.5 py-0.5 rounded-full border border-red-800">Hết ghế</span>
                                </td>
                            </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <div
                    class="bg-[#1f2937] border border-gray-700/60 rounded-xl p-5 shadow-xl flex flex-col justify-between">
                    <div>
                        <h2 class="text-md font-bold uppercase tracking-wider text-gray-200 border-b border-gray-700 pb-3 mb-4">
                            💺 Sơ đồ ma trận lưới 40 ghế</h2>

                        <div
                            class="grid grid-cols-2 gap-2 text-xs font-medium mb-5 bg-[#111827] p-3 rounded-lg border border-gray-700/50">
                            <div class="flex items-center"><span
                                    class="w-3.5 h-3.5 bg-slate-700 border border-gray-500 rounded mr-2 inline-block"></span>Trống
                                (Xám đậm)
                            </div>
                            <div class="flex items-center"><span
                                    class="w-3.5 h-3.5 bg-blue-600 rounded mr-2 inline-block"></span>Trống (Xanh T2)
                            </div>
                            <div class="flex items-center"><span
                                    class="w-3.5 h-3.5 bg-amber-400 rounded mr-2 inline-block"></span>Đang chọn (Vàng)
                            </div>
                            <div class="flex items-center"><span
                                    class="w-3.5 h-3.5 bg-gray-600 text-gray-400 rounded mr-2 inline-block"></span>Đã
                                đặt (Xám nhạt)
                            </div>
                        </div>

                        <div
                            class="grid grid-cols-4 gap-2 text-center max-w-[280px] mx-auto bg-[#111827] p-3 rounded-xl border border-gray-700">
                            <div
                                class="p-2 bg-slate-700 border border-gray-600 text-white rounded cursor-pointer font-bold text-xs hover:bg-amber-400 hover:text-gray-900 transition shadow-sm">
                                01
                            </div>
                            <div
                                class="p-2 bg-slate-700 border border-gray-600 text-white rounded cursor-pointer font-bold text-xs hover:bg-amber-400 hover:text-gray-900 transition shadow-sm">
                                02
                            </div>
                            <div
                                class="p-2 bg-blue-600/40 border border-blue-500 text-blue-200 rounded cursor-pointer font-bold text-xs hover:bg-amber-400 hover:text-gray-900 transition shadow-sm">
                                03
                            </div>
                            <div
                                class="p-2 bg-blue-600/40 border border-blue-500 text-blue-200 rounded cursor-pointer font-bold text-xs hover:bg-amber-400 hover:text-gray-900 transition shadow-sm">
                                04
                            </div>

                            <div
                                class="p-2 bg-amber-400 text-gray-900 font-extrabold text-xs rounded shadow-md border border-amber-500">
                                05
                            </div>
                            <div
                                class="p-2 bg-amber-400 text-gray-900 font-extrabold text-xs rounded shadow-md border border-amber-500">
                                06
                            </div>
                            <div
                                class="p-2 bg-slate-700 border border-gray-600 text-white rounded cursor-pointer font-bold text-xs hover:bg-amber-400 hover:text-gray-900 shadow-sm">
                                07
                            </div>
                            <div
                                class="p-2 bg-blue-600/40 border border-blue-500 text-blue-200 rounded cursor-pointer font-bold text-xs hover:bg-amber-400 hover:text-gray-900 shadow-sm">
                                08
                            </div>

                            <div
                                class="p-2 bg-gray-600 text-gray-400 border border-gray-600 rounded cursor-not-allowed font-medium text-xs">
                                09
                            </div>
                            <div
                                class="p-2 bg-gray-600 text-gray-400 border border-gray-600 rounded cursor-not-allowed font-medium text-xs">
                                10
                            </div>
                            <div
                                class="p-2 bg-slate-700 border border-gray-600 text-white rounded cursor-pointer font-bold text-xs hover:bg-amber-400 hover:text-gray-900 shadow-sm">
                                11
                            </div>
                            <div
                                class="p-2 bg-slate-700 border border-gray-600 text-white rounded cursor-pointer font-bold text-xs hover:bg-amber-400 hover:text-gray-900 shadow-sm">
                                12
                            </div>

                            @for (int i = 13; i <= 40; i++)
                            {
                                <div
                                    class="p-2 bg-slate-700 border border-gray-600 text-white rounded cursor-pointer font-bold text-xs hover:bg-amber-400 hover:text-gray-900 transition shadow-sm">@i.ToString("D2")</div>
                            }
                        </div>
                    </div>

                    <div class="flex justify-end gap-2 mt-6 pt-4 border-t border-gray-700">
                        <button type="button"
                                class="bg-green-600 hover:bg-green-700 text-white text-xs font-bold py-2 px-4 rounded-lg transition">
                            New
                        </button>
                        <button type="button"
                                class="bg-amber-500 hover:bg-amber-600 text-gray-900 text-xs font-bold py-2 px-4 rounded-lg transition">
                            Update
                        </button>
                        <button type="button"
                                class="bg-red-600 hover:bg-red-700 text-white text-xs font-bold py-2 px-4 rounded-lg transition">
                            Cancel
                        </button>
                    </div>
                </div>

            </div>
        </div>
    </div>
</div>