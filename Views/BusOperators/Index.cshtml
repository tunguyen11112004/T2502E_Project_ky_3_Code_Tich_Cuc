<div id="deleteOperatorModal" tabindex="-1" aria-hidden="true"
     class="hidden overflow-y-auto overflow-x-hidden fixed top-0 right-0 left-0 z-50 justify-center items-center w-full md:inset-0 h-[calc(100%-1rem)] max-h-full">
    <div class="relative p-4 w-full max-w-md max-h-full">
        <div class="relative bg-[#1e1e24] border border-gray-700/50 rounded-xl shadow-xl p-5 space-y-4">
            <h3 class="text-lg font-semibold text-white">Ngưng hợp tác đối tác</h3>
            <p class="text-sm text-gray-400">Bạn có chắc muốn chuyển <span id="deleteOperatorLabel" class="text-white font-semibold"></span> sang trạng thái Inactive?</p>
            <form id="deleteOperatorForm" asp-controller="BusOperators" asp-action="Delete" method="post" class="flex justify-end gap-3">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="deleteOperatorId" />
                <input type="hidden" name="returnSearchTerm" value="@searchTerm" />
                <input type="hidden" name="returnStatus" value="@status" />
                <input type="hidden" name="returnPage" value="@currentPage" />
                <button type="button" class="px-4 py-2.5 text-sm font-semibold text-gray-300 bg-gray-800 border border-gray-700 rounded-lg hover:bg-gray-700" data-modal-hide="deleteOperatorModal">Hủy</button>
                <button type="submit" class="px-4 py-2.5 text-sm font-semibold text-white bg-rose-600 hover:bg-rose-500 rounded-lg">Xác nhận</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const operatorCodePattern = /^OP-[A-Z]{2}-\d{2}$/;
            const emailPattern = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;
            const hotlinePattern = /^(0\d{8,10}|1900\d{4,6})$/;

            function normalizeHotline(value) {
                return (value || '').trim().replace(/[\s\-\.\(\)]/g, '');
            }

            function ensureErrorElement(wrapper) {
                let errorEl = wrapper.querySelector('.operator-error');
                if (!errorEl) {
                    errorEl = document.createElement('p');
                    errorEl.className = 'operator-error hidden text-xs text-red-400 mt-1';
                    wrapper.appendChild(errorEl);
                }
                return errorEl;
            }

            function getFieldValidation(field) {
                const rawValue = field.value ?? '';
                const value = rawValue.trim();

                if (!value) {
                    return { invalid: true, message: 'Vui lòng điền thông tin' };
                }

                if (field.name === 'OperatorCode' && !operatorCodePattern.test(value.toUpperCase())) {
                    return { invalid: true, message: 'Mã nhà xe phải theo format OP-HL-03' };
                }

                if (field.name === 'PhoneNumber') {
                    const normalizedPhone = normalizeHotline(value);
                    if (!normalizedPhone) {
                        return { invalid: true, message: 'Vui lòng điền thông tin' };
                    }

                    if (!hotlinePattern.test(normalizedPhone)) {
                        return { invalid: true, message: 'Hotline không hợp lệ (ví dụ: 0900123456)' };
                    }
                }

                if (field.type === 'email' && !emailPattern.test(value)) {
                    return { invalid: true, message: 'Email không đúng định dạng' };
                }

                return { invalid: false, message: '' };
            }

            function clearFieldError(field) {
                const wrapper = field.closest('.operator-field');
                if (!wrapper) return;

                const label = wrapper.querySelector('.operator-label');
                const errorEl = ensureErrorElement(wrapper);

                field.classList.remove('border-red-500', 'ring-2', 'ring-red-500/40', 'focus:ring-red-500', 'focus:border-red-500');
                field.classList.add('border-gray-700', 'focus:ring-amber-400', 'focus:border-amber-400');
                if (label) {
                    label.classList.remove('text-red-400');
                    label.classList.add('text-gray-400');
                }
                errorEl.textContent = '';
                errorEl.classList.add('hidden');
            }

            function setFieldError(field, message) {
                const wrapper = field.closest('.operator-field');
                if (!wrapper) return;

                const label = wrapper.querySelector('.operator-label');
                const errorEl = ensureErrorElement(wrapper);

                field.classList.remove('border-gray-700', 'focus:ring-amber-400', 'focus:border-amber-400');
                field.classList.add('border-red-500', 'ring-2', 'ring-red-500/40', 'focus:ring-red-500', 'focus:border-red-500');
                if (label) {
                    label.classList.remove('text-gray-400');
                    label.classList.add('text-red-400');
                }
                errorEl.textContent = message;
                errorEl.classList.remove('hidden');
            }

            function validateOperatorForm(form) {
                let isValid = true;
                let firstInvalid = null;

                form.querySelectorAll('[data-required]').forEach(function (field) {
                    const validation = getFieldValidation(field);
                    if (validation.invalid) {
                        setFieldError(field, validation.message);
                        isValid = false;
                        if (!firstInvalid) {
                            firstInvalid = field;
                        }
                    } else {
                        clearFieldError(field);
                    }
                });

                if (!isValid && firstInvalid) {
                    firstInvalid.focus();
                }

                return isValid;
            }

            function bindOperatorFormValidation(form) {
                if (!form) return;

                form.querySelectorAll('.operator-field').forEach(function (wrapper) {
                    ensureErrorElement(wrapper);
                });

                form.querySelectorAll('[data-required]').forEach(function (field) {
                    field.addEventListener('input', function () {
                        const validation = getFieldValidation(field);
                        if (validation.invalid) {
                            setFieldError(field, validation.message);
                        } else {
                            clearFieldError(field);
                        }
                    });
                    field.addEventListener('change', function () {
                        const validation = getFieldValidation(field);
                        if (validation.invalid) {
                            setFieldError(field, validation.message);
                        } else {
                            clearFieldError(field);
                        }
                    });
                });

                form.addEventListener('submit', function (event) {
                    form.querySelectorAll('[name="PhoneNumber"]').forEach(function (field) {
                        const trimmed = (field.value || '').trim();
                        if (trimmed) {
                            field.value = normalizeHotline(trimmed);
                        }
                    });

                    if (!validateOperatorForm(form)) {
                        event.preventDefault();
                    }
                });
            }

            bindOperatorFormValidation(document.getElementById('createOperatorForm'));
            bindOperatorFormValidation(document.getElementById('editOperatorForm'));

            const createNameInput = document.getElementById('createOperatorName');
            const createCodeInput = document.getElementById('createOperatorCode');

            if (createNameInput && createCodeInput) {
                createNameInput.addEventListener('blur', async function () {
                    const name = createNameInput.value.trim();
                    if (!name) return;

                    const response = await fetch('/BusOperators/SuggestOperatorCode?operatorName=' + encodeURIComponent(name));
                    if (!response.ok) return;

                    const data = await response.json();
                    if (data.code) {
                        createCodeInput.value = data.code;
                    }
                });
            }

            document.querySelectorAll('.btn-edit-operator').forEach(function (button) {
                button.addEventListener('click', function () {
                    const id = button.dataset.id;
                    document.getElementById('editOperatorId').value = id;
                    document.getElementById('editOperatorForm').action = '/BusOperators/Edit/' + id;
                    document.getElementById('editOperatorCode').value = button.dataset.operatorCode || '';
                    document.getElementById('editOperatorName').value = button.dataset.operatorName || '';
                    document.getElementById('editOperatorPhone').value = button.dataset.operatorPhone || '';
                    document.getElementById('editOperatorEmail').value = button.dataset.operatorEmail || '';
                    document.getElementById('editOperatorAddress').value = button.dataset.operatorAddress || '';
                    document.getElementById('editOperatorContact').value = button.dataset.operatorContact || '';
                    document.getElementById('editOperatorStatus').value = button.dataset.operatorStatus || 'Active';
                });
            });

            document.querySelectorAll('.btn-delete-operator').forEach(function (button) {
                button.addEventListener('click', function () {
                    document.getElementById('deleteOperatorId').value = button.dataset.id || '';
                    const label = (button.dataset.operatorCode || '') + ' - ' + (button.dataset.operatorName || '');
                    document.getElementById('deleteOperatorLabel').textContent = label;
                });
            });

            @if (openCreateModal)
            {
                <text>
                const createModal = document.getElementById('createOperatorModal');
                if (createModal) createModal.classList.remove('hidden');
                </text>
            }

            @if (!string.IsNullOrWhiteSpace(openEditModalId))
            {
                <text>
                const editButton = document.querySelector('.btn-edit-operator[data-id="@openEditModalId"]');
                if (editButton) {
                    editButton.click();
                }
                </text>
            }
        });
    </script>
}
