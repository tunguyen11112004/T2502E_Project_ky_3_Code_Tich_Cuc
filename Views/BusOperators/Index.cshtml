@model IEnumerable<Bus_ticket.Models.BusOperator>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý Đối tác Nhà xe";

    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
    long totalItems = ViewBag.TotalItems ?? 0;
    int pageSize = ViewBag.PageSize ?? 10;
    string searchTerm = ViewBag.SearchTerm ?? string.Empty;
    string status = ViewBag.Status ?? string.Empty;
    string suggestedOperatorCode = ViewBag.SuggestedOperatorCode ?? "OP-XX-01";
    bool openCreateModal = ViewBag.OpenCreateModal ?? false;
    string? openEditModalId = ViewBag.OpenEditModalId as string;

    long startItem = totalItems == 0 ? 0 : ((currentPage - 1) * pageSize) + 1;
    long endItem = (currentPage * pageSize) > totalItems ? totalItems : (currentPage * pageSize);

    string? activeSelected = status == "Active" ? "selected" : null;
    string? inactiveSelected = status == "Inactive" ? "selected" : null;
}

<div class="p-6 sm:p-8 space-y-6">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold tracking-tight text-white">Danh sách Đối tác Nhà xe</h1>
            <p class="text-sm text-gray-400 mt-1">Quản lý thông tin đối tác nhà xe (merchant) trên hệ thống.</p>
        </div>
        <button type="button"
                data-modal-target="createOperatorModal"
                data-modal-toggle="createOperatorModal"
                class="inline-flex items-center justify-center px-4 py-2.5 text-sm font-semibold text-gray-900 bg-amber-400 hover:bg-amber-500 rounded-lg transition-colors shadow-sm">
            + Thêm đối tác
        </button>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="p-4 text-sm text-emerald-400 rounded-lg bg-gray-800 border border-emerald-700">
            @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="p-4 text-sm text-red-400 rounded-lg bg-gray-800 border border-red-700">
            @TempData["ErrorMessage"]
        </div>
    }

    <form method="get" asp-controller="BusOperators" asp-action="Index" class="grid grid-cols-1 md:grid-cols-4 gap-3">
        <input type="text" name="searchTerm" value="@searchTerm"
               class="md:col-span-2 block w-full px-4 py-2.5 text-sm text-white bg-gray-900 border border-gray-700 rounded-lg focus:ring-2 focus:ring-amber-400 focus:border-amber-400"
               placeholder="Tìm theo tên, mã, email, số điện thoại..." />

        <select name="status"
                class="block w-full px-4 py-2.5 text-sm text-white bg-gray-900 border border-gray-700 rounded-lg focus:ring-2 focus:ring-amber-400 focus:border-amber-400">
            <option value="">Tất cả trạng thái</option>
            <option value="Active" selected="@activeSelected">Active</option>
            <option value="Inactive" selected="@inactiveSelected">Inactive</option>
        </select>

        <button type="submit" class="px-4 py-2.5 text-sm font-semibold text-gray-900 bg-amber-400 hover:bg-amber-500 rounded-lg transition-colors">
            Tìm kiếm
        </button>
    </form>

    <div class="overflow-hidden bg-[#1e1e24] border border-gray-700/50 rounded-xl shadow-xl">
        <div class="overflow-x-auto">
            <table class="w-full text-sm text-left text-gray-300 whitespace-nowrap">
                <thead class="text-xs uppercase bg-[#141419] text-gray-400 border-b border-gray-700/60">
                    <tr>
                        <th class="px-6 py-4">Tên nhà xe</th>
                        <th class="px-6 py-4">Mã nhà xe</th>
                        <th class="px-6 py-4">Địa chỉ</th>
                        <th class="px-6 py-4">Email</th>
                        <th class="px-6 py-4">Hotline</th>
                        <th class="px-6 py-4">Người liên hệ</th>
                        <th class="px-6 py-4">Trạng thái</th>
                        <th class="px-6 py-4 text-right">Hành động</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-700/50">
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="8" class="px-6 py-10 text-center text-gray-500 bg-[#1e1e24]">
                                Không có đối tác nhà xe phù hợp.
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            var badgeClass = item.Status == "Active"
                                ? "bg-emerald-500/10 text-emerald-400 border-emerald-500/20"
                                : "bg-rose-500/10 text-rose-400 border-rose-500/20";

                            <tr class="hover:bg-gray-800/30 transition-colors">
                                <td class="px-6 py-4 font-semibold text-white">@item.OperatorName</td>
                                <td class="px-6 py-4 text-amber-400 font-semibold">@item.OperatorCode</td>
                                <td class="px-6 py-4 text-gray-400 max-w-xs truncate" title="@item.Address">@item.Address</td>
                                <td class="px-6 py-4 text-gray-400">@item.Email</td>
                                <td class="px-6 py-4 text-gray-400">@item.PhoneNumber</td>
                                <td class="px-6 py-4 text-gray-400">@item.ContactPerson</td>
                                <td class="px-6 py-4">
                                    <span class="inline-flex items-center px-2.5 py-0.5 text-xs font-semibold rounded-md border @badgeClass">
                                        @item.Status
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <div class="inline-flex items-center gap-3">
                                        <button type="button"
                                                class="text-amber-400 hover:text-amber-300 font-semibold btn-edit-operator"
                                                data-modal-target="editOperatorModal"
                                                data-modal-toggle="editOperatorModal"
                                                data-id="@item.Id"
                                                data-operator-code="@item.OperatorCode"
                                                data-operator-name="@item.OperatorName"
                                                data-operator-phone="@item.PhoneNumber"
                                                data-operator-email="@item.Email"
                                                data-operator-address="@item.Address"
                                                data-operator-contact="@item.ContactPerson"
                                                data-operator-status="@item.Status">
                                            Sửa
                                        </button>
                                        @if (item.Status == "Active")
                                        {
                                            <button type="button"
                                                    class="text-rose-400 hover:text-rose-300 font-semibold btn-delete-operator"
                                                    data-modal-target="deleteOperatorModal"
                                                    data-modal-toggle="deleteOperatorModal"
                                                    data-id="@item.Id"
                                                    data-operator-name="@item.OperatorName"
                                                    data-operator-code="@item.OperatorCode">
                                                Xóa
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div class="flex flex-col md:flex-row md:items-center justify-between gap-3 px-6 py-4 bg-[#141419] border-t border-gray-700/60 text-sm text-gray-400">
            <div>Hiển thị @startItem - @endItem trong tổng số @totalItems đối tác nhà xe</div>
            <div class="flex items-center justify-end shrink-0">
                <div class="grid grid-cols-3 gap-2 w-[13.5rem]">
                    @if (currentPage > 1)
                    {
                        <a asp-action="Index"
                           asp-route-page="@(currentPage - 1)"
                           asp-route-searchTerm="@searchTerm"
                           asp-route-status="@status"
                           class="h-9 flex items-center justify-center rounded-md border border-gray-700 text-sm text-gray-300 hover:bg-gray-800 hover:text-white transition-colors">
                            Trước
                        </a>
                    }
                    else
                    {
                        <span class="h-9 flex items-center justify-center rounded-md border border-gray-700/40 text-sm text-gray-600 cursor-not-allowed select-none"
                              aria-disabled="true">
                            Trước
                        </span>
                    }

                    <span class="h-9 flex items-center justify-center rounded-md bg-gray-800 text-sm text-white">
                        @currentPage / @(totalPages == 0 ? 1 : totalPages)
                    </span>

                    @if (currentPage < totalPages)
                    {
                        <a asp-action="Index"
                           asp-route-page="@(currentPage + 1)"
                           asp-route-searchTerm="@searchTerm"
                           asp-route-status="@status"
                           class="h-9 flex items-center justify-center rounded-md border border-gray-700 text-sm text-gray-300 hover:bg-gray-800 hover:text-white transition-colors">
                            Sau
                        </a>
                    }
                    else
                    {
                        <span class="h-9 flex items-center justify-center rounded-md border border-gray-700/40 text-sm text-gray-600 cursor-not-allowed select-none"
                              aria-disabled="true">
                            Sau
                        </span>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div id="createOperatorModal" tabindex="-1" aria-hidden="true"
     class="hidden overflow-y-auto overflow-x-hidden fixed top-0 right-0 left-0 z-50 justify-center items-center w-full md:inset-0 h-[calc(100%-1rem)] max-h-full">
    <div class="relative p-4 w-full max-w-2xl max-h-full">
        <div class="relative bg-[#1e1e24] border border-gray-700/50 rounded-xl shadow-xl">
            <div class="flex items-center justify-between p-5 border-b border-gray-700/60">
                <h3 class="text-lg font-semibold text-white">Thêm đối tác nhà xe</h3>
                <button type="button" class="px-3 py-1.5 text-sm font-semibold text-gray-300 bg-gray-800 border border-gray-700 rounded-lg hover:bg-gray-700" data-modal-hide="createOperatorModal">Đóng</button>
            </div>
            <form id="createOperatorForm" asp-controller="BusOperators" asp-action="Create" method="post" class="p-5 space-y-4" novalidate>
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnSearchTerm" value="@searchTerm" />
                <input type="hidden" name="returnStatus" value="@status" />
                <input type="hidden" name="returnPage" value="@currentPage" />

                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="operator-field">
                        <label class="operator-label block mb-1 text-sm text-gray-400">Tên nhà xe <span class="text-red-500">*</span></label>
                        <input type="text" name="OperatorName" id="createOperatorName" required maxlength="150" data-required="true"
                               class="operator-input block w-full px-4 py-2.5 text-sm text-white bg-gray-900 border border-gray-700 rounded-lg focus:ring-2 focus:ring-amber-400 focus:border-amber-400" />
                    </div>
                    <div class="operator-field">
                        <label class="operator-label block mb-1 text-sm text-gray-400">Mã nhà xe <span class="text-red-500">*</span></label>
                        <input type="text" name="OperatorCode" id="createOperatorCode" value="@suggestedOperatorCode" required maxlength="30" data-required="true"
                               class="operator-input block w-full px-4 py-2.5 text-sm text-white bg-gray-900 border border-gray-700 rounded-lg focus:ring-2 focus:ring-amber-400 focus:border-amber-400" />
                    </div>
                    <div class="operator-field">
                        <label class="operator-label block mb-1 text-sm text-gray-400">Hotline <span class="text-red-500">*</span></label>
                        <input type="text" name="PhoneNumber" required maxlength="20" data-required="true" inputmode="tel"
                               placeholder="Ví dụ: 0900123456"
                               class="operator-input block w-full px-4 py-2.5 text-sm text-white bg-gray-900 border border-gray-700 rounded-lg focus:ring-2 focus:ring-amber-400 focus:border-amber-400" />
                    </div>
                    <div class="operator-field">
                        <label class="operator-label block mb-1 text-sm text-gray-400">Email <span class="text-red-500">*</span></label>
                        <input type="email" name="Email" required maxlength="120" data-required="true"
                               class="operator-input block w-full px-4 py-2.5 text-sm text-white bg-gray-900 border border-gray-700 rounded-lg focus:ring-2 focus:ring-amber-400 focus:border-amber-400" />
                    </div>
                    <div class="operator-field md:col-span-2">
                        <label class="operator-label block mb-1 text-sm text-gray-400">Địa chỉ <span class="text-red-500">*</span></label>
                        <input type="text" name="Address" required maxlength="255" data-required="true"
                               class="operator-input block w-full px-4 py-2.5 text-sm text-white bg-gray-900 border border-gray-700 rounded-lg focus:ring-2 focus:ring-amber-400 focus:border-amber-400" />
                    </div>
                    <div class="operator-field">
                        <label class="operator-label block mb-1 text-sm text-gray-400">Người liên hệ <span class="text-red-500">*</span></label>
                        <input type="text" name="ContactPerson" required maxlength="120" data-required="true"
                               class="operator-input block w-full px-4 py-2.5 text-sm text-white bg-gray-900 border border-gray-700 rounded-lg focus:ring-2 focus:ring-amber-400 focus:border-amber-400" />
                    </div>
                    <div class="operator-field">
                        <label class="operator-label block mb-1 text-sm text-gray-400">Trạng thái <span class="text-red-500">*</span></label>
                        <select name="Status" required data-required="true"
                                class="operator-input block w-full px-4 py-2.5 text-sm text-white bg-gray-900 border border-gray-700 rounded-lg focus:ring-2 focus:ring-amber-400 focus:border-amber-400">
                            <option value="Active" selected>Active</option>
                            <option value="Inactive">Inactive</option>
                        </select>
                    </div>
                </div>

                <div class="flex justify-end gap-3 pt-2">
                    <button type="button" class="px-4 py-2.5 text-sm font-semibold text-gray-300 bg-gray-800 border border-gray-700 rounded-lg hover:bg-gray-700" data-modal-hide="createOperatorModal">Hủy</button>
                    <button type="submit" class="px-4 py-2.5 text-sm font-semibold text-gray-900 bg-amber-400 hover:bg-amber-500 rounded-lg">Lưu</button>
                </div>
            </form>
        </div>
    </div>
</div>

