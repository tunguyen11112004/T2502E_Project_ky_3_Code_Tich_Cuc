@model Bus_ticket.ViewModels.BookingIndexViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản Lý Chuyến Xe & Đặt Vé";
    var tripCount = Model.Trips?.Count ?? 0;
}

<div class="p-6 sm:p-8 space-y-6">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold tracking-tight text-white">Danh sách Chuyến Xe & Đặt Vé</h1>
            <p class="text-sm text-gray-400 mt-1">Quản lý chuyến xe, chọn ghế và đặt vé tại quầy cho hành khách.</p>
        </div>
        <div>
            <button type="button" onclick="clearBookingData()"
                    class="inline-flex items-center justify-center px-4 py-2.5 text-sm font-semibold text-gray-900 bg-amber-400 hover:bg-amber-500 rounded-lg transition-colors duration-200 shadow-sm">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                </svg>
                Làm mới form
            </button>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="flex items-center p-4 text-sm text-emerald-400 rounded-lg bg-gray-800 border border-emerald-800">
            <svg class="flex-shrink-0 inline w-4 h-4 mr-3" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <div><span class="font-medium">Thành công!</span> @TempData["SuccessMessage"]</div>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="flex items-center p-4 text-sm text-red-400 rounded-lg bg-gray-800 border border-red-800">
            <svg class="flex-shrink-0 inline w-4 h-4 mr-3" fill="currentColor" viewBox="0 0 20 20">
                <path d="M10 .5a9.5 9.5 0 1 0 9.5 9.5A9.51 9.51 0 0 0 10 .5ZM9.5 4a1.5 1.5 0 1 1 3 0 1.5 1.5 0 0 1-3 0ZM12 15H8a1 1 0 0 1 0-2h1v-3H8a1 1 0 0 1 0-2h2a1 1 0 0 1 1 1v4h1a1 1 0 0 1 0 2Z"/>
            </svg>
            <div><span class="font-medium">Thất bại!</span> @TempData["ErrorMessage"]</div>
        </div>
    }

    <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">
        <div class="xl:col-span-2 space-y-4">
            <p class="text-sm text-gray-400">Click dòng chuyến để tải sơ đồ ghế</p>

            <div class="overflow-hidden bg-[#1e1e24] border border-gray-700/50 rounded-xl shadow-xl">
                <div class="overflow-x-auto">
                    <table class="w-full text-sm text-left text-gray-300 whitespace-nowrap">
                        <thead class="text-xs uppercase bg-[#141419] text-gray-400 border-b border-gray-700/60">
                        <tr>
                            <th scope="col" class="px-6 py-4 font-semibold tracking-wider">Mã Chuyến</th>
                            <th scope="col" class="px-6 py-4 font-semibold tracking-wider">Tuyến</th>
                            <th scope="col" class="px-6 py-4 font-semibold tracking-wider">Giờ Đi</th>
                            <th scope="col" class="px-6 py-4 font-semibold tracking-wider">Giá Vé</th>
                            <th scope="col" class="px-6 py-4 font-semibold tracking-wider">Trạng Thái</th>
                        </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-700/50" id="trip-table-body">
                        @if (Model.Trips != null && Model.Trips.Any())
                        {
                            foreach (var trip in Model.Trips)
                            {
                                <tr class="hover:bg-gray-800/30 transition-colors duration-150 cursor-pointer trip-row"
                                    data-trip-id="@trip.TripId"
                                    onclick="loadSeatMatrix('@trip.TripId')">
                                    <td class="px-6 py-4 font-semibold text-amber-400">
                                        @trip.TripCode
                                        @if (trip.IsReturnLeg)
                                        {
                                            <span class="ml-1 text-[10px] text-blue-400 font-normal">(Chiều về)</span>
                                        }
                                    </td>
                                    <td class="px-6 py-4 text-gray-300 text-xs">
                                        @trip.DeparturePoint → @trip.DestinationPoint
                                    </td>
                                    <td class="px-6 py-4 text-gray-300">@trip.DepartureTime.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="px-6 py-4 font-semibold text-white">@trip.BaseFare.ToString("N0") đ</td>
                                    <td class="px-6 py-4">
                                        <span class="inline-flex items-center px-2.5 py-0.5 text-xs font-semibold rounded-md border bg-emerald-500/10 text-emerald-400 border-emerald-500/20">
                                            @trip.Status
                                        </span>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="px-6 py-10 text-center text-gray-500 bg-[#1e1e24]">
                                    Không tìm thấy chuyến xe phù hợp. Thử bỏ trống điểm đi/đến để xem tất cả chuyến.
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>

                <div class="flex flex-col sm:flex-row items-center justify-between p-4 bg-[#141419] border-t border-gray-700/60 gap-4">
                    <span class="text-sm text-gray-400">
                        Hiển thị tổng số <span class="font-semibold text-white">@tripCount</span> chuyến xe
                    </span>
                </div>
            </div>
        </div>

        <div class="space-y-4">
            <div class="overflow-hidden bg-[#1e1e24] border border-gray-700/50 rounded-xl shadow-xl p-6">
                <h2 class="text-sm font-semibold uppercase tracking-wider text-gray-400 border-b border-gray-700/60 pb-3 mb-4">
                    Sơ đồ ma trận ghế
                </h2>

                <div class="grid grid-cols-2 gap-2 text-xs font-medium mb-5 p-3 rounded-lg bg-[#141419] border border-gray-700/50 text-gray-400">
                    <div class="flex items-center"><span class="w-3.5 h-3.5 bg-gray-700 border border-gray-600 rounded mr-2 inline-block"></span>Trống</div>
                    <div class="flex items-center"><span class="w-3.5 h-3.5 bg-amber-400 rounded mr-2 inline-block"></span>Đang chọn</div>
                    <div class="flex items-center"><span class="w-3.5 h-3.5 bg-amber-500 rounded mr-2 inline-block"></span>Giữ chỗ</div>
                    <div class="flex items-center"><span class="w-3.5 h-3.5 bg-gray-600 rounded mr-2 inline-block"></span>Đã đặt</div>
                </div>

                <p id="lblBusType" class="text-xs text-gray-400 mb-3 text-center">Chọn chuyến xe để hiển thị sơ đồ</p>

                <div id="grid-seats" class="grid grid-cols-4 gap-2 text-center max-w-[280px] mx-auto p-3 rounded-lg bg-[#141419] border border-gray-700/50 min-h-[120px] mb-5">
                    <p class="col-span-4 text-xs text-gray-500 py-8">Chưa có sơ đồ ghế</p>
                </div>

                <form asp-action="BookTicket" asp-controller="Booking" method="post" id="formBooking" class="space-y-4 border-t border-gray-700/60 pt-4">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="tripId" id="hidTripId" />
                    <div id="hidden-seats-container"></div>

                    <h3 class="text-sm font-semibold text-white">Thông tin đặt vé</h3>

                    <div>
                        <label class="block mb-1.5 text-xs font-semibold text-gray-400 uppercase tracking-wider">Tên hành khách</label>
                        <input type="text" name="passengerName" id="txtPassengerName" required
                               class="block w-full px-4 py-2 text-sm text-white bg-gray-900 border border-gray-700 rounded-lg focus:ring-2 focus:ring-amber-400 focus:border-amber-400 placeholder-gray-500"
                               placeholder="Họ tên khách mua vé">
                    </div>
                    <div>
                        <label class="block mb-1.5 text-xs font-semibold text-gray-400 uppercase tracking-wider">Số điện thoại</label>
                        <input type="tel" name="passengerPhone" id="txtPassengerPhone" required pattern="[0-9]{9,11}"
                               class="block w-full px-4 py-2 text-sm text-white bg-gray-900 border border-gray-700 rounded-lg focus:ring-2 focus:ring-amber-400 focus:border-amber-400 placeholder-gray-500"
                               placeholder="0912345678">
                    </div>
                    <div>
                        <label class="block mb-1.5 text-xs font-semibold text-gray-400 uppercase tracking-wider">Email</label>
                        <input type="email" name="passengerEmail" id="txtPassengerEmail"
                               class="block w-full px-4 py-2 text-sm text-white bg-gray-900 border border-gray-700 rounded-lg focus:ring-2 focus:ring-amber-400 focus:border-amber-400 placeholder-gray-500"
                               placeholder="email@example.com">
                    </div>
                    <div>
                        <label class="block mb-1.5 text-xs font-semibold text-gray-400 uppercase tracking-wider">Tuổi</label>
                        <input type="number" name="passengerAge" id="txtPassengerAge" min="1" max="100" required value="20"
                               class="block w-full px-4 py-2 text-sm text-white bg-gray-900 border border-gray-700 rounded-lg focus:ring-2 focus:ring-amber-400 focus:border-amber-400 placeholder-gray-500">
                        <p class="text-[10px] text-amber-400/80 mt-1">* Giảm giá theo chính sách tuổi (trẻ em, sinh viên, người cao tuổi).</p>
                    </div>
                    <div>
                        <label class="block mb-1.5 text-xs font-semibold text-gray-400 uppercase tracking-wider">Số ghế chọn</label>
                        <input type="text" id="txtSeatNum" readonly
                               class="block w-full px-4 py-2 text-sm font-semibold text-amber-400 bg-amber-400/10 border border-amber-400/30 rounded-lg"
                               placeholder="Chọn trực tiếp trên sơ đồ xe">
                    </div>

                    <div class="flex flex-wrap justify-end gap-2 pt-2">
                        <button type="submit"
                                class="inline-flex items-center justify-center px-4 py-2.5 text-sm font-semibold text-gray-900 bg-amber-400 hover:bg-amber-500 rounded-lg transition-colors duration-200 shadow-sm">
                            Đặt vé
                        </button>
                        <button type="button" onclick="alert('Tính năng nâng cao đang phát triển!')"
                                class="inline-flex items-center justify-center px-4 py-2.5 text-sm font-semibold text-gray-300 bg-gray-800 hover:bg-gray-700 border border-gray-700 rounded-lg transition-colors duration-200">
                            Cập nhật
                        </button>
                        <button type="button" onclick="clearBookingData()"
                                class="inline-flex items-center justify-center px-4 py-2.5 text-sm font-semibold text-rose-400 bg-gray-800 hover:bg-gray-700 border border-gray-700 rounded-lg transition-colors duration-200">
                            Hủy
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    const selectedSeats = [];
    const container = document.getElementById('hidden-seats-container');
    const txtSeatNum = document.getElementById('txtSeatNum');
    const gridSeats = document.getElementById('grid-seats');

    async function loadSeatMatrix(tripId) {
        document.querySelectorAll('.trip-row').forEach(r => {
            r.classList.remove('bg-amber-500/10', 'ring-1', 'ring-amber-400/50');
        });
        const activeRow = document.querySelector(`[data-trip-id="${tripId}"]`);
        if (activeRow) {
            activeRow.classList.add('bg-amber-500/10', 'ring-1', 'ring-amber-400/50');
        }

        selectedSeats.length = 0;
        container.innerHTML = '';
        txtSeatNum.value = '';
        document.getElementById('hidTripId').value = tripId;

        try {
            const response = await fetch(`/Booking/GetSeats?tripId=${encodeURIComponent(tripId)}`, {
                credentials: 'same-origin'
            });
            if (!response.ok) {
                alert(`Không thể kết nối lấy dữ liệu ghế! (${response.status})`);
                return;
            }
            const data = await response.json();
            gridSeats.innerHTML = '';

            const columns = data.totalColumns || 4;
            gridSeats.style.gridTemplateColumns = `repeat(${columns}, minmax(0, 1fr))`;
            document.getElementById('lblBusType').innerText = `Sơ đồ xe: ${data.busType || 'Standard Layout'}`;

            const allSeats = data.realtimeSeats || data.seats || [];
            if (allSeats.length === 0) {
                gridSeats.innerHTML = '<p class="col-span-4 text-xs text-rose-400 py-8 text-center">Chưa có dữ liệu ghế</p>';
                return;
            }

            allSeats.forEach(seat => {
                const cell = document.createElement('div');
                cell.textContent = seat.seatType === 'VIP' ? `${seat.seatNumber}⭐` : seat.seatNumber;
                cell.className = 'p-2 rounded font-bold text-xs border transition shadow-sm';

                if (seat.status === 'Booked') {
                    cell.className += ' bg-gray-600 text-gray-400 border-gray-600 cursor-not-allowed';
                    cell.title = `Ghế ${seat.seatNumber} (Đã đặt)`;
                } else if (seat.status === 'Holding') {
                    cell.className += ' bg-amber-500 text-gray-900 border-amber-500 cursor-not-allowed';
                    cell.title = `Ghế ${seat.seatNumber} (Giữ chỗ)`;
                } else {
                    cell.className += ' bg-gray-800 border-gray-600 text-gray-200 cursor-pointer hover:bg-amber-400 hover:text-gray-900 hover:border-amber-400';
                    cell.setAttribute('data-seat', seat.seatNumber);
                    cell.addEventListener('click', function () { toggleSeatSelection(this, seat.seatNumber); });
                }
                gridSeats.appendChild(cell);
            });
        } catch {
            alert('Lỗi hệ thống khi tải ma trận lưới ghế động!');
        }
    }

    function toggleSeatSelection(element, seatCode) {
        const index = selectedSeats.indexOf(seatCode);
        if (index > -1) {
            element.classList.remove('bg-amber-400', 'text-gray-900', 'border-amber-400', 'font-extrabold');
            element.classList.add('bg-gray-800', 'text-gray-200', 'border-gray-600');
            selectedSeats.splice(index, 1);
        } else {
            element.classList.remove('bg-gray-800', 'text-gray-200', 'border-gray-600');
            element.classList.add('bg-amber-400', 'text-gray-900', 'border-amber-400', 'font-extrabold');
            selectedSeats.push(seatCode);
        }

        txtSeatNum.value = selectedSeats.join(', ');
        container.innerHTML = '';
        selectedSeats.forEach(seat => {
            const input = document.createElement('input');
            input.type = 'hidden';
            input.name = 'seatNumbers';
            input.value = seat;
            container.appendChild(input);
        });
    }

    function clearBookingData() {
        document.getElementById('formBooking').reset();
        document.getElementById('hidTripId').value = '';
        txtSeatNum.value = '';
        container.innerHTML = '';
        selectedSeats.length = 0;
        gridSeats.innerHTML = '<p class="col-span-4 text-xs text-gray-500 py-8 text-center">Chưa có sơ đồ ghế</p>';
        document.getElementById('lblBusType').innerText = 'Chọn chuyến xe để hiển thị sơ đồ';
        document.querySelectorAll('.trip-row').forEach(r => {
            r.classList.remove('bg-amber-500/10', 'ring-1', 'ring-amber-400/50');
        });
    }

    document.getElementById('formBooking').addEventListener('submit', function (e) {
        if (!document.getElementById('hidTripId').value) {
            e.preventDefault();
            alert('Vui lòng click chọn một chuyến xe trong bảng trước!');
            return;
        }
        if (selectedSeats.length === 0) {
            e.preventDefault();
            alert('Vui lòng tích chọn ít nhất một ghế trên sơ đồ xe!');
        }
    });
</script>
