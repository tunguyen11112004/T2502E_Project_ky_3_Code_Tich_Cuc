@model List<Bus_ticket.Models.Trip>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Quản Lý Chuyến Xe & Đặt Vé";
}

<div class="p-4 sm:ml-64">
    <div class="p-4 mt-14">
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Booking CRUD</h1>
        <p class="mt-2 text-gray-600 dark:text-gray-400">Quản lý chuyến xe và đặt vé tại quầy.</p>

        <div class="p-4 bg-[#111827] text-gray-100 min-h-screen antialiased mt-6 rounded-xl">
            <div class="w-full bg-gradient-to-r from-blue-900 to-indigo-950 p-6 rounded-xl text-center shadow-lg border border-blue-800/40 mb-6">
                <h1 class="text-2xl md:text-3xl font-extrabold text-white tracking-wide">SRC Travel Agencies</h1>
                <p class="text-gray-300 text-xs mt-1 uppercase tracking-widest">Connecting destinations, elevating journeys.</p>
            </div>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="p-4 mb-4 text-sm rounded-lg bg-green-900/40 text-green-400 font-bold border border-green-800">
                    🎉 @TempData["SuccessMessage"]
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="p-4 mb-4 text-sm rounded-lg bg-red-900/40 text-red-400 font-bold border border-red-800">
                    🛑 @TempData["ErrorMessage"]
                </div>
            }

            <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">
                <!-- Cột trái: danh sách chuyến -->
                <div class="xl:col-span-2 bg-[#1f2937] border border-gray-700/60 rounded-xl p-5 shadow-xl">
                    <div class="flex justify-between items-center border-b border-gray-700 pb-3 mb-4">
                        <h2 class="text-md font-bold uppercase tracking-wider text-gray-200">🔍 Danh sách chuyến xe</h2>
                        <span class="text-xs text-gray-400">💡 Click dòng chuyến để tải sơ đồ ghế</span>
                    </div>

                    <div class="mb-4">
                        <input type="text" id="txtSearchTrip"
                               class="bg-[#111827] border border-gray-600 text-white text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5"
                               placeholder="Tìm kiếm chuyến xe...">
                    </div>

                    <div class="overflow-x-auto">
                        <table class="w-full text-sm text-left text-gray-400">
                            <thead class="text-xs uppercase bg-[#111827] text-gray-400 border-b border-gray-700">
                            <tr>
                                <th class="px-4 py-3">Mã Chuyến</th>
                                <th class="px-4 py-3">Giờ Đi</th>
                                <th class="px-4 py-3">Giá Vé</th>
                                <th class="px-4 py-3">Trạng Thái</th>
                            </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-700" id="trip-table-body">
                            @if (Model != null && Model.Any())
                            {
                                foreach (var trip in Model)
                                {
                                    var tripCode = trip.TripCode ?? "#" + trip.Id.Substring(trip.Id.Length - 6).ToUpper();
                                    <tr class="bg-[#1f2937] hover:bg-gray-800/60 transition cursor-pointer trip-row"
                                        data-trip-id="@trip.Id"
                                        onclick="loadSeatMatrix('@trip.Id')">
                                        <td class="px-4 py-3 font-bold text-white">@tripCode</td>
                                        <td class="px-4 py-3 text-blue-400 font-medium">@trip.DepartureTime.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                        <td class="px-4 py-3 font-semibold text-emerald-400">@trip.BaseFare.ToString("N0")đ</td>
                                        <td class="px-4 py-3">
                                            <span class="bg-green-900/40 text-green-400 text-xs font-medium px-2.5 py-0.5 rounded-full border border-green-800">@trip.Status</span>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="px-4 py-6 text-center text-gray-500">Không có chuyến xe nào trong Database.</td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Cột phải: sơ đồ ghế + booking form -->
                <div class="bg-[#1f2937] border border-gray-700/60 rounded-xl p-5 shadow-xl flex flex-col">
                    <h2 class="text-md font-bold uppercase tracking-wider text-gray-200 border-b border-gray-700 pb-3 mb-4">
                        💺 Sơ đồ ma trận ghế
                    </h2>

                    <div class="grid grid-cols-2 gap-2 text-xs font-medium mb-5 bg-[#111827] p-3 rounded-lg border border-gray-700/50">
                        <div class="flex items-center"><span class="w-3.5 h-3.5 bg-slate-700 border border-gray-500 rounded mr-2 inline-block"></span>Trống</div>
                        <div class="flex items-center"><span class="w-3.5 h-3.5 bg-amber-400 rounded mr-2 inline-block"></span>Đang chọn</div>
                        <div class="flex items-center"><span class="w-3.5 h-3.5 bg-amber-500 rounded mr-2 inline-block"></span>Giữ chỗ</div>
                        <div class="flex items-center"><span class="w-3.5 h-3.5 bg-gray-600 rounded mr-2 inline-block"></span>Đã đặt</div>
                    </div>

                    <p id="lblBusType" class="text-xs text-gray-400 mb-3 text-center">Chọn chuyến xe để hiển thị sơ đồ</p>

                    <div id="grid-seats" class="grid grid-cols-4 gap-2 text-center max-w-[280px] mx-auto bg-[#111827] p-3 rounded-xl border border-gray-700 min-h-[120px] mb-5">
                        <p class="col-span-4 text-xs text-gray-500 py-8">Chưa có sơ đồ ghế</p>
                    </div>

                    <form asp-action="BookTicket" asp-controller="Booking" method="post" id="formBooking" class="space-y-3 border-t border-gray-700 pt-4">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="tripId" id="hidTripId" />
                        <div id="hidden-seats-container"></div>

                        <h3 class="text-xs font-bold uppercase text-gray-300">Booking Form</h3>

                        <div>
                            <label class="block mb-1.5 text-xs font-semibold text-gray-400 uppercase">Tên hành khách</label>
                            <input type="text" name="passengerName" id="txtPassengerName" required
                                   class="bg-[#111827] border border-gray-600 text-white text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5"
                                   placeholder="Họ tên khách mua vé">
                        </div>
                        <div>
                            <label class="block mb-1.5 text-xs font-semibold text-gray-400 uppercase">Số điện thoại</label>
                            <input type="tel" name="passengerPhone" id="txtPassengerPhone" required pattern="[0-9]{9,11}"
                                   class="bg-[#111827] border border-gray-600 text-white text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5"
                                   placeholder="0912345678">
                        </div>
                        <div>
                            <label class="block mb-1.5 text-xs font-semibold text-gray-400 uppercase">Email</label>
                            <input type="email" name="passengerEmail" id="txtPassengerEmail"
                                   class="bg-[#111827] border border-gray-600 text-white text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5"
                                   placeholder="email@example.com">
                        </div>
                        <div>
                            <label class="block mb-1.5 text-xs font-semibold text-gray-400 uppercase">Tuổi</label>
                            <input type="number" name="passengerAge" id="txtPassengerAge" min="1" max="100" required value="20"
                                   class="bg-[#111827] border border-gray-600 text-white text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full p-2.5">
                            <p class="text-[10px] text-amber-500 mt-1">* Giảm 10% cho Trẻ em (&lt;12t) hoặc Người già (&gt;60t).</p>
                        </div>
                        <div>
                            <label class="block mb-1.5 text-xs font-semibold text-gray-400 uppercase">Số ghế chọn</label>
                            <input type="text" id="txtSeatNum" readonly
                                   class="bg-amber-900/30 border border-amber-600/50 text-amber-200 font-bold text-sm rounded-lg block w-full p-2.5"
                                   placeholder="Chọn trực tiếp trên sơ đồ xe">
                        </div>

                        <div class="flex justify-end gap-2 pt-2">
                            <button type="submit" class="bg-green-600 hover:bg-green-700 text-white text-xs font-bold py-2 px-4 rounded-lg transition">New (Đặt vé)</button>
                            <button type="button" onclick="alert('Tính năng nâng cao đang phát triển!')" class="bg-amber-500 hover:bg-amber-600 text-gray-900 text-xs font-bold py-2 px-4 rounded-lg transition">Update</button>
                            <button type="button" onclick="clearBookingData()" class="bg-red-600 hover:bg-red-700 text-white text-xs font-bold py-2 px-4 rounded-lg transition">Cancel</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const selectedSeats = [];
    const container = document.getElementById('hidden-seats-container');
    const txtSeatNum = document.getElementById('txtSeatNum');
    const gridSeats = document.getElementById('grid-seats');

    document.getElementById('txtSearchTrip')?.addEventListener('input', function () {
        const keyword = this.value.toLowerCase();
        document.querySelectorAll('#trip-table-body tr.trip-row').forEach(row => {
            row.style.display = row.textContent.toLowerCase().includes(keyword) ? '' : 'none';
        });
    });

    async function loadSeatMatrix(tripId) {
        document.querySelectorAll('.trip-row').forEach(r => r.classList.remove('ring-2', 'ring-blue-500'));
        document.querySelector(`[data-trip-id="${tripId}"]`)?.classList.add('ring-2', 'ring-blue-500');

        selectedSeats.length = 0;
        container.innerHTML = '';
        txtSeatNum.value = '';
        document.getElementById('hidTripId').value = tripId;

        try {
            const response = await fetch(`/Booking/GetSeats?tripId=${encodeURIComponent(tripId)}`, {
                credentials: 'same-origin'
            });
            if (!response.ok) {
                alert(`Không thể kết nối lấy dữ liệu ghế! (${response.status})`);
                return;
            }
            const data = await response.json();
            gridSeats.innerHTML = '';

            const columns = data.totalColumns || 4;
            gridSeats.style.gridTemplateColumns = `repeat(${columns}, minmax(0, 1fr))`;
            document.getElementById('lblBusType').innerText = `Sơ đồ xe: ${data.busType || 'Standard Layout'}`;

            const allSeats = data.realtimeSeats || data.seats || [];
            if (allSeats.length === 0) {
                gridSeats.innerHTML = '<p class="col-span-4 text-xs text-red-400 py-8 text-center">Chưa có dữ liệu ghế</p>';
                return;
            }

            allSeats.forEach(seat => {
                const cell = document.createElement('div');
                cell.textContent = seat.seatType === 'VIP' ? `${seat.seatNumber}⭐` : seat.seatNumber;
                cell.className = 'p-2 rounded font-bold text-xs border transition shadow-sm';

                if (seat.status === 'Booked') {
                    cell.className += ' bg-gray-600 text-gray-400 border-gray-600 cursor-not-allowed';
                    cell.title = `Ghế ${seat.seatNumber} (Đã đặt)`;
                } else if (seat.status === 'Holding') {
                    cell.className += ' bg-amber-500 text-gray-900 border-amber-500 cursor-not-allowed';
                    cell.title = `Ghế ${seat.seatNumber} (Giữ chỗ)`;
                } else {
                    cell.className += ' bg-slate-700 border-gray-600 text-white cursor-pointer hover:bg-amber-400 hover:text-gray-900';
                    cell.setAttribute('data-seat', seat.seatNumber);
                    cell.addEventListener('click', function () { toggleSeatSelection(this, seat.seatNumber); });
                }
                gridSeats.appendChild(cell);
            });
        } catch {
            alert('Lỗi hệ thống khi tải ma trận lưới ghế động!');
        }
    }

    function toggleSeatSelection(element, seatCode) {
        const index = selectedSeats.indexOf(seatCode);
        if (index > -1) {
            element.classList.remove('bg-amber-400', 'text-gray-900', 'border-amber-500', 'font-extrabold');
            element.classList.add('bg-slate-700', 'text-white', 'border-gray-600');
            selectedSeats.splice(index, 1);
        } else {
            element.classList.remove('bg-slate-700', 'text-white', 'border-gray-600');
            element.classList.add('bg-amber-400', 'text-gray-900', 'border-amber-500', 'font-extrabold');
            selectedSeats.push(seatCode);
        }

        txtSeatNum.value = selectedSeats.join(', ');
        container.innerHTML = '';
        selectedSeats.forEach(seat => {
            const input = document.createElement('input');
            input.type = 'hidden';
            input.name = 'seatNumbers';
            input.value = seat;
            container.appendChild(input);
        });
    }

    function clearBookingData() {
        document.getElementById('formBooking').reset();
        document.getElementById('hidTripId').value = '';
        txtSeatNum.value = '';
        container.innerHTML = '';
        selectedSeats.length = 0;
        gridSeats.innerHTML = '<p class="col-span-4 text-xs text-gray-500 py-8 text-center">Chưa có sơ đồ ghế</p>';
        document.getElementById('lblBusType').innerText = 'Chọn chuyến xe để hiển thị sơ đồ';
        document.querySelectorAll('.trip-row').forEach(r => r.classList.remove('ring-2', 'ring-blue-500'));
    }

    document.getElementById('formBooking').addEventListener('submit', function (e) {
        if (!document.getElementById('hidTripId').value) {
            e.preventDefault();
            alert('Vui lòng click chọn một chuyến xe trong bảng trước!');
            return;
        }
        if (selectedSeats.length === 0) {
            e.preventDefault();
            alert('Vui lòng tích chọn ít nhất một ghế trên sơ đồ xe!');
        }
    });
</script>
