@model Bus_ticket.ViewModels.BusFormViewModel
@{
    string prefix = ViewData["IdPrefix"] as string ?? string.Empty;
}

<div class="space-y-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Mã xe -->
        <div>
            <label class="block text-sm font-medium text-gray-300 mb-2">Mã xe</label>
            <input type="text" id="@(prefix)BusCode" name="BusCode" value="@Model.BusCode"
                   class="w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-4 py-3 focus:ring-2 focus:ring-amber-500"
                   placeholder="BUS-001" required />
        </div>

        <!-- Biển số -->
        <div>
            <label class="block text-sm font-medium text-gray-300 mb-2">Biển số xe</label>
            <input type="text" id="@(prefix)LicensePlate" name="LicensePlate" value="@Model.LicensePlate"
                   class="w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-4 py-3 focus:ring-2 focus:ring-amber-500"
                   placeholder="29A-123.45" required />
        </div>

        <!-- Loại xe -->
        <div class="md:col-span-2">
            <label class="block text-sm font-medium text-gray-300 mb-2">Loại xe</label>
            <select id="@(prefix)BusClassId" name="BusClassId" 
                    class="w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-4 py-3 focus:ring-2 focus:ring-amber-500" required>
                <option value="">-- Chọn loại xe --</option>
                @foreach (var opt in Model.BusClassOptions)
                {
                    <option value="@opt.Value" selected="@(opt.Value == Model.BusClassId)">@opt.Text</option>
                }
            </select>
        </div>

        <!-- Chi nhánh -->
        <div>
            <label class="block text-sm font-medium text-gray-300 mb-2">Chi nhánh</label>
            <select id="@(prefix)BranchId" name="BranchId" 
                    class="w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-4 py-3">
                <option value="">-- Không chọn --</option>
                @foreach (var opt in Model.BranchOptions)
                {
                    <option value="@opt.Value" selected="@(opt.Value == Model.BranchId)">@opt.Text</option>
                }
            </select>
        </div>

        <!-- Nhà xe -->
        <div>
            <label class="block text-sm font-medium text-gray-300 mb-2">Nhà xe / Đối tác</label>
            <select id="@(prefix)OperatorId" name="OperatorId" 
                    class="w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-4 py-3">
                <option value="">-- Không chọn --</option>
                @foreach (var opt in Model.OperatorOptions)
                {
                    <option value="@opt.Value" selected="@(opt.Value == Model.OperatorId)">@opt.Text</option>
                }
            </select>
        </div>

        <!-- Trạng thái -->
        <div class="md:col-span-2">
            <label class="block text-sm font-medium text-gray-300 mb-2">Trạng thái</label>
            <select id="@(prefix)Status" name="Status" 
                    class="w-full bg-gray-800 border border-gray-700 text-white rounded-lg px-4 py-3">
                <option value="Active" selected="@(Model.Status == "Active")">Hoạt động</option>
                <option value="Maintenance" selected="@(Model.Status == "Maintenance")">Bảo trì</option>
                <option value="Inactive" selected="@(Model.Status == "Inactive")">Ngưng hoạt động</option>
            </select>
        </div>
    </div>
</div>