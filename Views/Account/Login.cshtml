@model Bus_ticket.ViewModels.LoginViewModel

@{
    Layout = "_Layout";
    ViewData["Title"] = "Employee Login";
}

<main class="min-h-screen bg-priColor py-12">
    <section class="container mx-auto px-4">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">

            <div class="hidden lg:block">
                <div class="hero min-h-[70vh] rounded-[20px]"
                     style="background-image: url('/client-assets/images/banner.png'); background-position: center; background-size: cover;">
                    <div class="hero-overlay rounded-[20px] bg-opacity-60"></div>
                    <div class="hero-content text-neutral-content p-8">
                        <div>
                            <h1 class="mb-5 text-5xl font-bold text-white">
                                SRC Travel Agencies
                            </h1>
                            <p class="text-priColor text-lg">
                                Internal bus ticket reservation system for booking department employees.
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card bg-white shadow-xl rounded-3xl">
                <div class="card-body p-8 lg:p-10">
                    <h2 class="text-3xl font-bold text-titleColor text-center">
                        Employee Login
                    </h2>
                    <p class="text-center text-gray-500 mb-6">
                        Sign in to manage booking, enquiry and ticket operations.
                    </p>

                    <form asp-action="Login" asp-controller="Account" method="post" class="form-control gap-4">
                        <div asp-validation-summary="All" class="text-red-500 text-sm"></div>

                        <div>
                            <label asp-for="Email" class="font-semibold text-slate-700"></label>
                            <input asp-for="Email"
                                   class="input input-bordered w-full mt-2 border-gray-300"
                                   placeholder="Enter username" />
                            <span asp-validation-for="Email" class="text-red-500 text-sm"></span>
                        </div>

                        <div>
                            <label asp-for="Password" class="font-semibold text-slate-700"></label>
                            <input asp-for="Password"
                                   class="input input-bordered w-full mt-2 border-gray-300"
                                   placeholder="Enter password" />
                            <span asp-validation-for="Password" class="text-red-500 text-sm"></span>
                        </div>

                        <button type="submit"
                                class="btn bg-ternaryColor hover:bg-[#15b300] text-white border-none mt-4">
                            Login
                        </button>
                        
                        <div class="text-center mt-2">
                            <a asp-action="ForgotPassword"
                               asp-controller="Account"
                               class="text-ternaryColor hover:underline text-sm font-semibold">
                                Forgot Password?
                            </a>
                        </div>
                    </form>

                    <div class="divider"></div>

                    <p class="text-center text-sm text-gray-500">
                        Only Admin and Employee accounts can access this system.
                    </p>
                </div>
            </div>

        </div>
    </section>
</main>