@{
    ViewData["Title"] = "Access Denied";
}

<main class="min-h-screen bg-priColor flex items-center justify-center px-4">
    <div class="card bg-white shadow-2xl rounded-3xl max-w-lg w-full">
        <div class="card-body text-center p-10">

            <div class="text-7xl mb-4">
                🚫
            </div>

            <h1 class="text-4xl font-bold text-titleColor">
                Access Denied
            </h1>

            <p class="text-gray-500 mt-4">
                You do not have permission to access this page.
            </p>

            <p class="text-sm text-gray-400 mt-2">
                Please contact the administrator if you believe this is an error.
            </p>

            <div class="mt-8">
                <a asp-controller="Home"
                   asp-action="Index"
                   class="btn bg-ternaryColor hover:bg-[#15b300] text-white border-none px-8">
                    Back to Home
                </a>
            </div>

        </div>
    </div>
</main>