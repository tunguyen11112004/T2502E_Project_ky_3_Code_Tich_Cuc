@model Bus_ticket.ViewModels.ChangePasswordViewModel

@{
    ViewData["Title"] = "Change Password";
}

<main class="min-h-screen bg-priColor py-12">
    <section class="container mx-auto px-4">
        <div class="max-w-2xl mx-auto">

            <div class="card bg-white shadow-xl rounded-3xl">
                <div class="card-body p-8">

                    <div class="text-center mb-8">
                        <h2 class="text-4xl font-bold text-titleColor">
                            Change Password
                        </h2>
                        <p class="text-gray-500 mt-2">
                            Update your account password securely
                        </p>
                    </div>

                    @if (ViewBag.Message != null)
                    {
                        <div class="alert alert-success mb-5">
                            <span>@ViewBag.Message</span>
                        </div>
                    }

                    <form asp-action="ChangePassword"
                          asp-controller="Account"
                          method="post">

                        <div asp-validation-summary="All"
                             class="alert alert-error mb-5">
                        </div>

                        <div class="space-y-5">

                            <div>
                                <label asp-for="CurrentPassword"
                                       class="font-semibold text-slate-700"></label>

                                <input asp-for="CurrentPassword"
                                       type="password"
                                       class="input input-bordered w-full mt-2" />

                                <span asp-validation-for="CurrentPassword"
                                      class="text-error text-sm"></span>
                            </div>

                            <div>
                                <label asp-for="NewPassword"
                                       class="font-semibold text-slate-700"></label>

                                <input asp-for="NewPassword"
                                       type="password"
                                       class="input input-bordered w-full mt-2" />

                                <span asp-validation-for="NewPassword"
                                      class="text-error text-sm"></span>
                            </div>

                            <div>
                                <label asp-for="ConfirmNewPassword"
                                       class="font-semibold text-slate-700"></label>

                                <input asp-for="ConfirmNewPassword"
                                       type="password"
                                       class="input input-bordered w-full mt-2" />

                                <span asp-validation-for="ConfirmNewPassword"
                                      class="text-error text-sm"></span>
                            </div>

                        </div>

                        <div class="text-center mt-8">
                            <button type="submit"
                                    class="btn bg-ternaryColor hover:bg-[#15b300] text-white border-none px-10">
                                Change Password
                            </button>
                        </div>

                    </form>

                </div>
            </div>

        </div>
    </section>
</main>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}