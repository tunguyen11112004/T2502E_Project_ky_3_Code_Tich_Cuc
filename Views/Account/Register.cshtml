@model Bus_ticket.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Register Employee";
}

<main class="min-h-screen bg-priColor py-12">
    <section class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">

            <div class="card bg-white shadow-xl rounded-3xl">
                <div class="card-body p-8">

                    <div class="text-center mb-8">
                        <h2 class="text-4xl font-bold text-titleColor">
                            Employee Registration
                        </h2>
                        <p class="text-gray-500 mt-2">
                            Create a new employee account for the booking system
                        </p>
                    </div>

                    <form asp-action="Register" asp-controller="Account" method="post">

                        <div asp-validation-summary="All"
                             class="alert alert-error mb-4"></div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">

                            <div>
                                <label asp-for="Username"
                                       class="font-semibold text-slate-700"></label>
                                <input asp-for="Username"
                                       class="input input-bordered w-full mt-2" />
                                <span asp-validation-for="Username"
                                      class="text-error text-sm"></span>
                            </div>

                            <div>
                                <label asp-for="Email"
                                       class="font-semibold text-slate-700"></label>
                                <input asp-for="Email"
                                       class="input input-bordered w-full mt-2" />
                                <span asp-validation-for="Email"
                                      class="text-error text-sm"></span>
                            </div>

                            <div>
                                <label asp-for="FullName"
                                       class="font-semibold text-slate-700"></label>
                                <input asp-for="FullName"
                                       class="input input-bordered w-full mt-2" />
                                <span asp-validation-for="FullName"
                                      class="text-error text-sm"></span>
                            </div>

                            <div>
                                <label asp-for="PhoneNumber"
                                       class="font-semibold text-slate-700"></label>
                                <input asp-for="PhoneNumber"
                                       class="input input-bordered w-full mt-2" />
                                <span asp-validation-for="PhoneNumber"
                                      class="text-error text-sm"></span>
                            </div>

                            <div>
                                <label asp-for="Age"
                                       class="font-semibold text-slate-700"></label>
                                <input asp-for="Age"
                                       type="number"
                                       class="input input-bordered w-full mt-2" />
                                <span asp-validation-for="Age"
                                      class="text-error text-sm"></span>
                            </div>

                            <div>
                                <label asp-for="Education"
                                       class="font-semibold text-slate-700"></label>
                                <input asp-for="Education"
                                       class="input input-bordered w-full mt-2"
                                       placeholder="University / College..." />
                                <span asp-validation-for="Education"
                                      class="text-error text-sm"></span>
                            </div>

                            <div>
                                <label asp-for="Password"
                                       class="font-semibold text-slate-700"></label>
                                <input asp-for="Password"
                                       type="password"
                                       class="input input-bordered w-full mt-2" />
                                <span asp-validation-for="Password"
                                      class="text-error text-sm"></span>
                            </div>

                            <div>
                                <label asp-for="ConfirmPassword"
                                       class="font-semibold text-slate-700"></label>
                                <input asp-for="ConfirmPassword"
                                       type="password"
                                       class="input input-bordered w-full mt-2" />
                                <span asp-validation-for="ConfirmPassword"
                                      class="text-error text-sm"></span>
                            </div>

                        </div>

                        <div class="text-center mt-8">
                            <button type="submit"
                                    class="btn bg-ternaryColor hover:bg-[#15b300] text-white border-none px-10">
                                Register Employee
                            </button>
                        </div>

                    </form>

                </div>
            </div>

        </div>
    </section>
</main>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}