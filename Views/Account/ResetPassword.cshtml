@model Bus_ticket.ViewModels.ResetPasswordViewModel

@{
    ViewData["Title"] = "Reset Password";
}

<main class="min-h-screen bg-priColor py-12">
    <section class="container mx-auto px-4">
        <div class="max-w-xl mx-auto">
            <div class="card bg-white shadow-xl rounded-3xl">
                <div class="card-body p-8">

                    <div class="text-center mb-8">
                        <h2 class="text-4xl font-bold text-titleColor">
                            Reset Password
                        </h2>
                        <p class="text-gray-500 mt-2">
                            Create a new password for your account
                        </p>
                    </div>

                    @if (ViewBag.Message != null)
                    {
                        <div class="alert alert-info mb-5">
                            <span>@ViewBag.Message</span>
                        </div>
                    }

                    <form asp-action="ResetPassword" asp-controller="Account" method="post">
                        <div asp-validation-summary="All" class="text-error text-sm mb-4"></div>

                        <input asp-for="Email" type="hidden" />
                        <input asp-for="Token" type="hidden" />

                        <div class="mb-5">
                            <label asp-for="NewPassword" class="font-semibold text-slate-700"></label>
                            <input asp-for="NewPassword"
                                   type="password"
                                   class="input input-bordered w-full mt-2"
                                   placeholder="Enter new password" />
                            <span asp-validation-for="NewPassword" class="text-error text-sm"></span>
                        </div>

                        <div>
                            <label asp-for="ConfirmNewPassword" class="font-semibold text-slate-700"></label>
                            <input asp-for="ConfirmNewPassword"
                                   type="password"
                                   class="input input-bordered w-full mt-2"
                                   placeholder="Confirm new password" />
                            <span asp-validation-for="ConfirmNewPassword" class="text-error text-sm"></span>
                        </div>

                        <button type="submit"
                                class="btn bg-ternaryColor hover:bg-[#15b300] text-white border-none w-full mt-6">
                            Reset Password
                        </button>
                    </form>

                </div>
            </div>
        </div>
    </section>
</main>