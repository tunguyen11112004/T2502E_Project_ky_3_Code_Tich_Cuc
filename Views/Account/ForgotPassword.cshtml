@model Bus_ticket.ViewModels.ForgotPasswordViewModel

@{
    ViewData["Title"] = "Forgot Password";
}

<main class="min-h-screen bg-priColor py-12">
    <section class="container mx-auto px-4">
        <div class="max-w-xl mx-auto">
            <div class="card bg-white shadow-xl rounded-3xl">
                <div class="card-body p-8">

                    <div class="text-center mb-8">
                        <h2 class="text-4xl font-bold text-titleColor">
                            Forgot Password
                        </h2>
                        <p class="text-gray-500 mt-2">
                            Enter your email to generate a reset password link
                        </p>
                    </div>

                    @if (ViewBag.Message != null)
                    {
                        <div class="alert alert-info mb-5">
                            <span>@ViewBag.Message</span>
                        </div>
                    }

                    @if (ViewBag.ResetLink != null)
                    {
                        <div class="alert alert-success mb-5 break-all">
                            <a href="@ViewBag.ResetLink"
                               class="btn bg-ternaryColor text-white border-none">
                                Reset Password Now
                            </a>
                        </div>
                    }

                    <form asp-action="ForgotPassword" asp-controller="Account" method="post">
                        <div asp-validation-summary="All" class="text-error text-sm mb-4"></div>

                        <div>
                            <label asp-for="Email" class="font-semibold text-slate-700"></label>
                            <input asp-for="Email"
                                   class="input input-bordered w-full mt-2"
                                   placeholder="Enter your email" />
                            <span asp-validation-for="Email" class="text-error text-sm"></span>
                        </div>

                        <button type="submit"
                                class="btn bg-ternaryColor hover:bg-[#15b300] text-white border-none w-full mt-6">
                            Generate Reset Link
                        </button>
                    </form>

                    <div class="text-center mt-6">
                        <a asp-action="Login" asp-controller="Account"
                           class="text-ternaryColor hover:underline">
                            Back to Login
                        </a>
                    </div>

                </div>
            </div>
        </div>
    </section>
</main>